<Window
    x:Class="PodcastVideoEditor.Ui.Views.TransitionPickerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Transition Gallery"
    Width="480"
    Height="340"
    WindowStartupLocation="CenterOwner"
    Background="{StaticResource PrimaryBackgroundBrush}"
    Foreground="{StaticResource PanelForegroundBrush}"
    ShowInTaskbar="False"
    WindowStyle="SingleBorderWindow"
    ResizeMode="NoResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="Choose a transition for the selected segment"
                   FontSize="13" Foreground="{StaticResource AccentLightBlueBrush}" Margin="0,0,0,14"/>

        <!-- Transition tiles (2x2 grid) -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,14">
            <!-- Fade -->
            <Border x:Name="FadeTile" Margin="4" CornerRadius="6" Padding="8"
                    Background="{StaticResource TransitionTileBackgroundBrush}" BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="2"
                    Cursor="Hand" MouseLeftButtonUp="Tile_Click" Tag="fade">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Width="56" Height="36" CornerRadius="4" Background="#1a3a5c" Margin="0,0,0,6">
                        <Canvas>
                            <Rectangle Canvas.Left="0" Canvas.Top="0" Width="56" Height="36"
                                       Fill="#1a3a5c"/>
                            <!-- Simple gradient to simulate fade -->
                            <Rectangle Canvas.Left="0" Canvas.Top="0" Width="56" Height="36">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                        <GradientStop Color="#FF1a3a5cff" Offset="0"/>
                                        <GradientStop Color="#00ffffff" Offset="0.5"/>
                                        <GradientStop Color="#FF1a3a5cff" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                        </Canvas>
                    </Border>
                    <TextBlock Text="Fade" FontSize="11" Foreground="{StaticResource AccentLightBlueBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Wipe -->
            <Border x:Name="WipeTile" Margin="4" CornerRadius="6" Padding="8"
                    Background="{StaticResource TransitionTileBackgroundBrush}" BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="2"
                    Cursor="Hand" MouseLeftButtonUp="Tile_Click" Tag="wipe">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Width="56" Height="36" CornerRadius="4" Background="#1a3a5c" Margin="0,0,0,6">
                        <Canvas>
                            <Rectangle Canvas.Left="0" Canvas.Top="0" Width="28" Height="36" Fill="#2e7d32"/>
                            <Rectangle Canvas.Left="28" Canvas.Top="0" Width="28" Height="36" Fill="#1a3a5c"/>
                            <Rectangle Canvas.Left="27" Canvas.Top="0" Width="2" Height="36" Fill="White" Opacity="0.8"/>
                        </Canvas>
                    </Border>
                    <TextBlock Text="Wipe" FontSize="11" Foreground="{StaticResource ValueDisplayBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Zoom -->
            <Border x:Name="ZoomTile" Margin="4" CornerRadius="6" Padding="8"
                    Background="{StaticResource TransitionTileBackgroundBrush}" BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="2"
                    Cursor="Hand" MouseLeftButtonUp="Tile_Click" Tag="zoom">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Width="56" Height="36" CornerRadius="4" Background="#3a1a5c" Margin="0,0,0,6">
                        <Canvas>
                            <Ellipse Canvas.Left="14" Canvas.Top="4" Width="28" Height="28" Fill="#6a1b9a" Opacity="0.5"/>
                            <Ellipse Canvas.Left="22" Canvas.Top="10" Width="12" Height="12" Fill="#ce93d8"/>
                        </Canvas>
                    </Border>
                    <TextBlock Text="Zoom" FontSize="11" Foreground="{StaticResource AccentPurpleBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Dissolve -->
            <Border x:Name="DissolveTile" Margin="4" CornerRadius="6" Padding="8"
                    Background="{StaticResource TransitionTileBackgroundBrush}" BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="2"
                    Cursor="Hand" MouseLeftButtonUp="Tile_Click" Tag="dissolve">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Width="56" Height="36" CornerRadius="4" Background="#1a3a5c" Margin="0,0,0,6">
                        <Canvas>
                            <Rectangle Canvas.Left="0" Canvas.Top="0" Width="56" Height="36">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FF1a3a5c" Offset="0"/>
                                        <GradientStop Color="#AAe65100" Offset="0.5"/>
                                        <GradientStop Color="#FF1a3a5c" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                        </Canvas>
                    </Border>
                    <TextBlock Text="Dissolve" FontSize="11" Foreground="{StaticResource WarningForegroundBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Duration -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,14">
            <TextBlock Text="Duration (s):" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource MutedForegroundBrush}"/>
            <TextBox x:Name="DurationTextBox" Width="60" Height="28"
                     Background="{StaticResource SecondaryBackgroundBrush}" Foreground="{StaticResource PanelForegroundBrush}"
                     BorderBrush="#5c6bc0" VerticalContentAlignment="Center" Padding="6,0"
                     ToolTip="Transition duration in seconds (e.g. 0.5)"/>
            <TextBlock Text="Selected:" VerticalAlignment="Center" Margin="20,0,8,0" Foreground="{StaticResource MutedForegroundBrush}"/>
            <TextBlock x:Name="SelectedLabel" Text="(none)" VerticalAlignment="Center"
                       Foreground="{StaticResource AccentLightBlueBrush}" FontWeight="Bold"/>
        </StackPanel>

        <!-- OK / Cancel -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Apply" x:Name="OkButton" Width="80" Height="32" Margin="0,0,8,0"
                    Background="{StaticResource AccentBlueBrush}" Foreground="{StaticResource PrimaryForegroundBrush}" IsDefault="True"
                    Click="OkButton_Click"/>
            <Button Content="Cancel" Width="80" Height="32"
                    Background="{StaticResource AppCardBorderBrush}" Foreground="{StaticResource PrimaryForegroundBrush}" IsCancel="True"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
