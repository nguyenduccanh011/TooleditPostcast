<UserControl x:Class="PodcastVideoEditor.Ui.Views.TrackEditorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:PodcastVideoEditor.Ui.Controls"
             Background="Transparent"
             Foreground="#e0e0e0">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2d2d2d" Padding="10,8" MinHeight="44">
            <TextBlock Text="Track Properties"
                       FontSize="14" FontWeight="Bold" Foreground="#81c784" VerticalAlignment="Center"/>
        </Border>

        <!-- No selection -->
        <TextBlock x:Name="NoSelectionText"
                   Grid.Row="1"
                   Text="Click vào phần đầu track trên timeline để chỉnh thuộc tính"
                   Foreground="#7a8a96"
                   FontStyle="Italic"
                   TextWrapping="Wrap"
                   Margin="15,15,15,0"
                   Visibility="Visible"/>

        <!-- Properties (shown when a track is selected) -->
        <ScrollViewer x:Name="PropertiesPanel"
                      Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="Collapsed">
            <StackPanel Margin="15,12,15,12">

                <!-- Track name (read-only display) -->
                <TextBlock Text="Tên track:" Foreground="#b0bec5" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBlock x:Name="TrackNameText"
                           Foreground="#81c784"
                           FontFamily="Courier New"
                           Margin="0,0,0,15"/>

                <!-- Track type (read-only) -->
                <TextBlock Text="Loại track:" Foreground="#b0bec5" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBlock x:Name="TrackTypeText"
                           Foreground="#64b5f6"
                           FontFamily="Courier New"
                           Margin="0,0,0,15"/>

                <TextBlock Text="Vai trò track:" Foreground="#b0bec5" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="TrackRoleCombo"
                          Background="#2a2a2a" Foreground="#e0e0e0"
                          BorderBrush="#546e7a" BorderThickness="1"
                          Padding="8,5" Margin="0,0,0,8"
                          SelectionChanged="TrackRoleCombo_SelectionChanged">
                    <ComboBoxItem Content="Không chỉ định" Tag="unspecified" IsSelected="True"/>
                    <ComboBoxItem Content="Brand Overlay (logo/icon)" Tag="brand_overlay"/>
                    <ComboBoxItem Content="Title Overlay" Tag="title_overlay"/>
                    <ComboBoxItem Content="Script Text" Tag="script_text"/>
                    <ComboBoxItem Content="AI Content" Tag="ai_content"/>
                    <ComboBoxItem Content="Visualizer" Tag="visualizer"/>
                    <ComboBoxItem Content="Background Content" Tag="background_content"/>
                </ComboBox>

                <TextBlock Text="Chế độ thời lượng (Span):" Foreground="#b0bec5" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="TrackSpanCombo"
                          Background="#2a2a2a" Foreground="#e0e0e0"
                          BorderBrush="#546e7a" BorderThickness="1"
                          Padding="8,5" Margin="0,0,0,8"
                          SelectionChanged="TrackSpanCombo_SelectionChanged">
                    <ComboBoxItem Content="Segment Bound" Tag="segment_bound" IsSelected="True"/>
                    <ComboBoxItem Content="Project Duration (tự kéo dài)" Tag="project_duration"/>
                    <ComboBoxItem Content="Template Duration (giữ như mẫu)" Tag="template_duration"/>
                    <ComboBoxItem Content="Manual" Tag="manual"/>
                </ComboBox>

                <Border Background="#2a2a2a" CornerRadius="4" Padding="10,8" Margin="0,0,0,12">
                    <TextBlock x:Name="TrackPolicyHintText"
                               Text="Role quyết định track dùng để làm gì. Span quyết định track có tự kéo dài theo project hay giữ nguyên thời lượng mẫu."
                               Foreground="#7a8a96"
                               FontStyle="Italic"
                               TextWrapping="Wrap"
                               FontSize="11"/>
                </Border>

                <!-- Separator — only show image layout for visual tracks -->
                <StackPanel x:Name="ImageLayoutSection" Visibility="Collapsed">
                    <Separator Background="#37474f" Margin="0,0,0,12"/>

                    <TextBlock Text="📐  Layout ảnh:" Foreground="#b0bec5" FontWeight="Bold"
                               Margin="0,0,0,8" FontFamily="Segoe UI Emoji"/>

                    <!-- Radio buttons for common presets -->
                    <RadioButton x:Name="RadioFullFrame"
                                 Content="Full Frame  (ảnh phủ toàn khung)"
                                 Foreground="#e0e0e0" Margin="0,0,0,6"
                                 GroupName="LayoutPreset"
                                 Checked="RadioPreset_Checked" Tag="FullFrame"/>

                    <RadioButton x:Name="RadioSquareCenter"
                                 Content="1:1 Giữa khung  (để trống trên/dưới cho title + sub)"
                                 Foreground="#e0e0e0" Margin="0,0,0,6"
                                 GroupName="LayoutPreset"
                                 Checked="RadioPreset_Checked" Tag="Square_Center"/>

                    <RadioButton x:Name="RadioWidescreenCenter"
                                 Content="16:9 Giữa khung  (letterbox trong frame dọc)"
                                 Foreground="#e0e0e0" Margin="0,0,0,14"
                                 GroupName="LayoutPreset"
                                 Checked="RadioPreset_Checked" Tag="Widescreen_Center"/>

                    <!-- Visual preview hint -->
                    <Border Background="#2a2a2a" CornerRadius="4" Padding="10,8" Margin="0,0,0,12">
                        <TextBlock x:Name="PresetHintText"
                                   Foreground="#7a8a96"
                                   FontStyle="Italic"
                                   TextWrapping="Wrap"
                                   FontSize="11"/>
                    </Border>

                    <!-- Auto-motion (Ken Burns) -->
                    <Separator Background="#37474f" Margin="0,0,0,12"/>

                    <TextBlock Text="🎬  Hiệu ứng chuyển động (Ken Burns):" Foreground="#b0bec5" FontWeight="Bold"
                               Margin="0,0,0,8" FontFamily="Segoe UI Emoji"/>

                    <CheckBox x:Name="AutoMotionCheckBox"
                              Content="Tự động áp dụng hiệu ứng ngẫu nhiên cho ảnh"
                              Foreground="#e0e0e0" Margin="0,0,0,8"
                              Checked="AutoMotionCheckBox_Changed"
                              Unchecked="AutoMotionCheckBox_Changed"/>

                    <StackPanel x:Name="MotionIntensityPanel" Visibility="Collapsed" Margin="0,0,0,8">
                        <TextBlock Foreground="#b0bec5" Margin="0,0,0,4" FontSize="12">
                            <Run Text="Cường độ: "/><Run x:Name="MotionIntensityValueText" Text="30%"/>
                        </TextBlock>
                        <Slider x:Name="MotionIntensitySlider"
                                Minimum="0" Maximum="100" Value="30"
                                TickFrequency="10" IsSnapToTickEnabled="False"
                                ValueChanged="MotionIntensitySlider_ValueChanged"/>
                    </StackPanel>

                    <Border Background="#2a2a2a" CornerRadius="4" Padding="10,8" Margin="0,0,0,12">
                        <TextBlock x:Name="MotionHintText"
                                   Text="Khi bật, mỗi ảnh tĩnh sẽ tự động có hiệu ứng zoom/pan ngẫu nhiên. Hiệu ứng cố định theo segment (render lại cho kết quả giống nhau)."
                                   Foreground="#7a8a96"
                                   FontStyle="Italic"
                                   TextWrapping="Wrap"
                                   FontSize="11"/>
                    </Border>

                    <!-- Color Overlay (darken / tint) -->
                    <Separator Background="#37474f" Margin="0,0,0,12"/>

                    <TextBlock Text="🎨  Lớp phủ màu (Overlay):" Foreground="#b0bec5" FontWeight="Bold"
                               Margin="0,0,0,8" FontFamily="Segoe UI Emoji"/>

                    <TextBlock Foreground="#b0bec5" Margin="0,0,0,4" FontSize="12">
                        <Run Text="Độ mờ: "/><Run x:Name="OverlayOpacityValueText" Text="0%"/>
                    </TextBlock>
                    <Slider x:Name="OverlayOpacitySlider"
                            Minimum="0" Maximum="100" Value="0"
                            TickFrequency="5" IsSnapToTickEnabled="False"
                            ValueChanged="OverlayOpacitySlider_ValueChanged"/>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Màu:" Foreground="#b0bec5" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                        <Border x:Name="OverlayColorSwatch"
                                Width="28" Height="28" CornerRadius="4"
                                Background="Black" BorderBrush="#546e7a" BorderThickness="1"
                                Cursor="Hand"
                                MouseLeftButtonDown="OverlayColorSwatch_Click"/>
                        <TextBlock x:Name="OverlayColorHexText"
                                   Text="#000000" Foreground="#81c784"
                                   FontFamily="Courier New" FontSize="12"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>

                    <!-- Color picker popup -->
                    <Popup x:Name="OverlayColorPopup"
                           PlacementTarget="{Binding ElementName=OverlayColorSwatch}"
                           Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
                           PopupAnimation="Fade">
                        <Border Background="#252530" BorderBrush="#546e7a" BorderThickness="1"
                                CornerRadius="6" Padding="2">
                            <controls:ColorPickerPopup x:Name="OverlayColorPicker"/>
                        </Border>
                    </Popup>

                    <Border Background="#2a2a2a" CornerRadius="4" Padding="10,8" Margin="0,8,0,12">
                        <TextBlock Text="Lớp phủ màu áp dụng cho toàn bộ segment trong track. Segment có thể ghi đè riêng trong Segment Properties."
                                   Foreground="#7a8a96"
                                   FontStyle="Italic"
                                   TextWrapping="Wrap"
                                   FontSize="11"/>
                    </Border>

                    <!-- Scale Mode (batch apply to all segments) -->
                    <Separator Background="#37474f" Margin="0,0,0,12"/>

                    <TextBlock Text="🖼  Chế độ co giãn ảnh (Scale Mode):" Foreground="#b0bec5" FontWeight="Bold"
                               Margin="0,0,0,8" FontFamily="Segoe UI Emoji"/>

                    <ComboBox x:Name="ScaleModeCombo"
                              Background="#2a2a2a" Foreground="#e0e0e0"
                              BorderBrush="#546e7a" BorderThickness="1"
                              Padding="8,5" Margin="0,0,0,8"
                              SelectionChanged="ScaleModeCombo_SelectionChanged">
                        <ComboBoxItem Content="Fill  (lấp đầy, có thể crop)" Tag="Fill" IsSelected="True"/>
                        <ComboBoxItem Content="Fit  (vừa khung, giữ tỉ lệ)" Tag="Fit"/>
                        <ComboBoxItem Content="Stretch  (kéo giãn, có thể méo)" Tag="Stretch"/>
                    </ComboBox>

                    <Button x:Name="ApplyScaleModeBtn"
                            Content="Áp dụng cho toàn bộ segment"
                            Background="#455a64" Foreground="White" BorderThickness="0"
                            Padding="10,6" Cursor="Hand" HorizontalAlignment="Left"
                            Click="ApplyScaleModeBtn_Click"/>

                    <Border Background="#2a2a2a" CornerRadius="4" Padding="10,8" Margin="0,8,0,12">
                        <TextBlock Text="Chọn chế độ co giãn rồi nhấn nút để áp dụng cho tất cả ảnh trong track này."
                                   Foreground="#7a8a96"
                                   FontStyle="Italic"
                                   TextWrapping="Wrap"
                                   FontSize="11"/>
                    </Border>
                </StackPanel>

                <!-- Lock / Visibility -->
                <Separator Background="#37474f" Margin="0,0,0,12"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button x:Name="LockBtn" Width="100" Padding="8,5" Margin="0,0,8,0"
                            Background="#455a64" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Click="LockBtn_Click">
                        <TextBlock x:Name="LockBtnText" Text="🔓 Mở khóa" FontFamily="Segoe UI Emoji"/>
                    </Button>
                    <Button x:Name="VisibilityBtn" Width="100" Padding="8,5"
                            Background="#455a64" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Click="VisibilityBtn_Click">
                        <TextBlock x:Name="VisBtnText" Text="👁 Hiện" FontFamily="Segoe UI Emoji"/>
                    </Button>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
