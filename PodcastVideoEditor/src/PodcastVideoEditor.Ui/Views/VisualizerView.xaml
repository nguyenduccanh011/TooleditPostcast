<UserControl x:Class="PodcastVideoEditor.Ui.Views.VisualizerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="800"
             Background="{StaticResource PrimaryBackgroundBrush}" Foreground="{StaticResource PrimaryForegroundBrush}"
             Loaded="OnVisualizerLoaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Settings Toolbar -->
        <ToolBar Grid.Row="0" Background="{StaticResource CardHeaderBackgroundBrush}" ToolBarTray.IsLocked="True" Padding="5">
            <Label Content="Style:" Foreground="{StaticResource PrimaryForegroundBrush}"/>
            <ComboBox ItemsSource="{Binding AvailableStyles}" 
                      SelectedItem="{Binding SelectedStyle}"
                      Width="100" Background="{StaticResource AppCardBorderBrush}" Foreground="{StaticResource PrimaryForegroundBrush}"/>
            
            <Separator/>
            <Label Content="Palette:" Foreground="{StaticResource PrimaryForegroundBrush}"/>
            <ComboBox ItemsSource="{Binding AvailablePalettes}" 
                      SelectedItem="{Binding SelectedPalette}"
                      Width="100" Background="{StaticResource AppCardBorderBrush}" Foreground="{StaticResource PrimaryForegroundBrush}"/>
            
            <Separator/>
            <Label Content="Bands:" Foreground="{StaticResource PrimaryForegroundBrush}"/>
            <ComboBox ItemsSource="{Binding AvailableBandCounts}" 
                      SelectedItem="{Binding SelectedBandCount}"
                      Width="80" Background="{StaticResource AppCardBorderBrush}" Foreground="{StaticResource PrimaryForegroundBrush}"/>
            
            <Separator/>
            <Label Content="Status:" Foreground="{StaticResource PrimaryForegroundBrush}"/>
            <TextBlock Text="{Binding StatusMessage}" 
                       VerticalAlignment="Center" Foreground="{StaticResource ValueDisplayBrush}" Margin="5,0"/>
        </ToolBar>

        <!-- Visualizer Canvas -->
        <Border Grid.Row="1" Background="{StaticResource CardHeaderBackgroundBrush}" BorderBrush="{StaticResource AppCardBorderBrush}" BorderThickness="1" MinHeight="220">
            <skia:SKElement x:Name="VisualizerCanvas"
                            MinHeight="200"
                            PaintSurface="OnPaintSurface"/>
        </Border>

        <!-- Info Bar -->
        <StatusBar Grid.Row="2" Background="{StaticResource CardHeaderBackgroundBrush}" Foreground="{StaticResource MutedForegroundBrush}" Padding="5">
            <StatusBarItem>
                <TextBlock Text="{Binding VisualizerWidth, StringFormat='Width: {0}px'}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding VisualizerHeight, StringFormat='Height: {0}px'}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding CurrentConfig.BandCount, StringFormat='Bands: {0}'}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding IsVisualizerRunning, StringFormat='Running: {0}'}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>
