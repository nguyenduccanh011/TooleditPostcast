<UserControl x:Class="PodcastVideoEditor.Ui.Views.UnifiedPropertiesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:PodcastVideoEditor.Ui.Views"
             Background="Transparent"
             Foreground="{StaticResource PanelForegroundBrush}"
             MinWidth="220">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- No selection message -->
        <TextBlock x:Name="NoSelectionText"
                   Grid.Row="0"
                   Text="Chọn segment trên timeline hoặc element trên preview để chỉnh thuộc tính"
                   Style="{StaticResource NoSelectionTextStyle}"
                   VerticalAlignment="Top"
                   Visibility="Visible"/>

        <!-- Element properties (primary — shown when element is selected, full space) -->
        <views:PropertyEditorView x:Name="ElementPanel"
                                  Grid.Row="0"
                                  DataContext="{Binding CanvasViewModel.PropertyEditor}"
                                  Visibility="Collapsed"/>

        <!-- Segment properties (fallback — shown only for segments without linked elements) -->
        <views:SegmentEditorPanel x:Name="SegmentPanel"
                                 Grid.Row="0"
                                 DataContext="{Binding TimelineViewModel}"
                                 Visibility="Collapsed"/>

        <!-- Track properties (shown when a track header is clicked) -->
        <views:TrackEditorPanel x:Name="TrackPanel"
                                Grid.Row="0"
                                DataContext="{Binding TimelineViewModel}"
                                Visibility="Collapsed"/>
    </Grid>
</UserControl>
