<UserControl x:Class="PodcastVideoEditor.Ui.Views.UnifiedPropertiesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:PodcastVideoEditor.Ui.Views"
             Background="#1e1e1e"
             Foreground="#e0e0e0"
             MinWidth="220">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition x:Name="SegmentRow" Height="Auto" MaxHeight="300"/>
            <RowDefinition x:Name="ElementRow" Height="*"/>
        </Grid.RowDefinitions>

        <!-- No selection message -->
        <TextBlock x:Name="NoSelectionText"
                   Grid.Row="0" Grid.RowSpan="2"
                   Text="Chọn segment trên timeline hoặc element trên preview để chỉnh thuộc tính"
                   Foreground="#7a8a96"
                   FontStyle="Italic"
                   TextWrapping="Wrap"
                   Margin="15,15,15,0"
                   VerticalAlignment="Top"
                   Visibility="Visible"/>

        <!-- Segment properties (top section — scrolls independently) -->
        <views:SegmentEditorPanel x:Name="SegmentPanel"
                                 Grid.Row="0"
                                 DataContext="{Binding TimelineViewModel}"
                                 Visibility="Collapsed"/>

        <!-- Element properties (bottom section — fills remaining space, scrolls independently) -->
        <views:PropertyEditorView x:Name="ElementPanel"
                                  Grid.Row="1"
                                  DataContext="{Binding CanvasViewModel.PropertyEditor}"
                                  Visibility="Collapsed"/>

        <!-- Track properties (shown when a track header is clicked — full span) -->
        <views:TrackEditorPanel x:Name="TrackPanel"
                                Grid.Row="0" Grid.RowSpan="2"
                                DataContext="{Binding TimelineViewModel}"
                                Visibility="Collapsed"/>
    </Grid>
</UserControl>
