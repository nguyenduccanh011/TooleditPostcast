<UserControl x:Class="PodcastVideoEditor.Ui.Views.UnifiedPropertiesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:PodcastVideoEditor.Ui.Views"
             Background="#1e1e1e"
             Foreground="#e0e0e0"
             MinWidth="220">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
            <!-- No selection message (visibility set in code-behind) -->
            <TextBlock x:Name="NoSelectionText"
                       Text="Chọn segment trên timeline hoặc element trên preview để chỉnh thuộc tính"
                       Foreground="#7a8a96"
                       FontStyle="Italic"
                       TextWrapping="Wrap"
                       Margin="15,15,15,0"
                       VerticalAlignment="Top"
                       Visibility="Visible"/>

            <!-- Segment properties (SegmentEditorPanel) — shown at the top when a segment is selected -->
            <views:SegmentEditorPanel x:Name="SegmentPanel"
                                     DataContext="{Binding TimelineViewModel}"
                                     Visibility="Collapsed"/>

            <!-- Element properties (PropertyEditorView) — shown below segment props when linked element exists -->
            <views:PropertyEditorView x:Name="ElementPanel"
                                      DataContext="{Binding CanvasViewModel.PropertyEditor}"
                                      Visibility="Collapsed"/>

            <!-- Track properties (TrackEditorPanel) — shown when a track header is clicked -->
            <views:TrackEditorPanel x:Name="TrackPanel"
                                    DataContext="{Binding TimelineViewModel}"
                                    Visibility="Collapsed"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
