<UserControl x:Class="PodcastVideoEditor.Ui.Views.SegmentEditorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PodcastVideoEditor.Ui.Converters"
             Background="#1e1e1e"
             Foreground="#e0e0e0">

    <UserControl.Resources>
        <conv:TransitionDurationConverter x:Key="TransitionDurationConverter"/>
        <conv:TimeValueConverter x:Key="TimeValueConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Bar (matching TimelineView status bar height) -->
        <Border Grid.Row="0" Background="#2d2d2d" Padding="10,8" MinHeight="44">
            <TextBlock Text="Segment Properties" 
                      FontSize="14" FontWeight="Bold" Foreground="#64b5f6" VerticalAlignment="Center"/>
        </Border>

        <!-- No Selection Message -->
        <TextBlock x:Name="NoSelectionText"
                  Grid.Row="1"
                  Text="Select a segment from timeline to edit properties"
                  Foreground="#7a8a96"
                  FontStyle="Italic"
                  Margin="15,15,15,0"
                  Visibility="Visible"/>

        <!-- Properties Panel -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" x:Name="PropertiesPanel">
            <StackPanel Margin="15,10,15,10">
                <!-- Start / End time (read-only) -->
                <TextBlock Text="Start / End time:" Foreground="#b0bec5" FontWeight="Bold" Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Foreground="#81c784" FontFamily="Courier New">
                        <Run Text="Start: "/>
                        <Run Text="{Binding SelectedSegment.StartTime, Converter={StaticResource TimeValueConverter}}"/>
                        <Run Text=" s"/>
                    </TextBlock>
                    <TextBlock Grid.Column="1" Text=" → " Foreground="#546e7a" Margin="4,0"/>
                    <TextBlock Grid.Column="2" Foreground="#81c784" FontFamily="Courier New">
                        <Run Text="End: "/>
                        <Run Text="{Binding SelectedSegment.EndTime, Converter={StaticResource TimeValueConverter}}"/>
                        <Run Text=" s"/>
                    </TextBlock>
                </Grid>

                <!-- Description -->
                <TextBlock Text="Description:" Foreground="#b0bec5" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox Text="{Binding SelectedSegment.Text, UpdateSourceTrigger=PropertyChanged}"
                        Background="#2d2d2d" Foreground="#e0e0e0"
                        Padding="8,5" BorderThickness="1" BorderBrush="#546e7a"
                        TextWrapping="Wrap" AcceptsReturn="True" Height="70"
                        VerticalScrollBarVisibility="Auto" Margin="0,0,0,15"/>

                <!-- Background media (visual segments only) -->
                <StackPanel x:Name="BackgroundSection" Margin="0,0,0,15">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSegment.Kind}" Value="visual">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Background media:" Foreground="#b0bec5" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock x:Name="BackgroundPathText" Text="No asset selected"
                               Foreground="#81c784" FontFamily="Courier New"
                               TextTrimming="CharacterEllipsis" MaxWidth="220"/>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Button Content="Choose file" Click="ChooseBackgroundButton_Click"
                               Background="#007acc" Foreground="White" Padding="10,6" MinHeight="30" Margin="0,0,8,0"/>
                        <Button Content="Clear" Click="ClearBackgroundButton_Click"
                               Background="#6d4c41" Foreground="White" Padding="10,6" MinHeight="30"/>
                    </StackPanel>
                </StackPanel>

                <!-- Transition Type -->
                <TextBlock Text="Transition:" Foreground="#b0bec5" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox SelectedItem="{Binding SelectedSegment.TransitionType, UpdateSourceTrigger=PropertyChanged}"
                         Background="#2d2d2d" Foreground="#e0e0e0"
                         BorderBrush="#546e7a" BorderThickness="1" Padding="8,5" Margin="0,0,0,15">
                    <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">fade</System:String>
                    <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">cut</System:String>
                    <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">slide-left</System:String>
                    <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">slide-right</System:String>
                    <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">zoom-in</System:String>
                </ComboBox>

                <!-- Transition Duration -->
                <TextBlock Text="Transition Duration:" Foreground="#b0bec5" FontWeight="Bold" Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="70"/>
                    </Grid.ColumnDefinitions>
                    <Slider Grid.Column="0"
                           Value="{Binding SelectedSegment.TransitionDuration, UpdateSourceTrigger=PropertyChanged}"
                           Minimum="0.0" Maximum="3.0" IsMoveToPointEnabled="True"
                           Height="20" Background="#37474f" Foreground="#64b5f6" Margin="0,0,10,0"/>
                    <TextBlock Grid.Column="1"
                              Text="{Binding SelectedSegment.TransitionDuration, Converter={StaticResource TransitionDurationConverter}}"
                              Foreground="#81c784" FontFamily="Courier New" FontWeight="Bold"
                              TextAlignment="Right" VerticalAlignment="Center"/>
                </Grid>

                <!-- Volume -->
                <TextBlock Text="Volume:" Foreground="#b0bec5" FontWeight="Bold" Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="70"/>
                    </Grid.ColumnDefinitions>
                    <Slider Grid.Column="0"
                           Value="{Binding SelectedSegment.Volume, UpdateSourceTrigger=PropertyChanged}"
                           Minimum="0.0" Maximum="1.0"
                           SmallChange="0.05" LargeChange="0.1"
                           IsMoveToPointEnabled="True"
                           Height="20" Background="#37474f" Foreground="#64b5f6" Margin="0,0,10,0"/>
                    <TextBlock Grid.Column="1"
                              Foreground="#81c784" FontFamily="Courier New" FontWeight="Bold"
                              TextAlignment="Right" VerticalAlignment="Center">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0:P0}">
                                <Binding Path="SelectedSegment.Volume"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </Grid>

                <!-- Fade In -->
                <TextBlock Text="Fade In:" Foreground="#b0bec5" FontWeight="Bold" Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="70"/>
                    </Grid.ColumnDefinitions>
                    <Slider Grid.Column="0"
                           Value="{Binding SelectedSegment.FadeInDuration, UpdateSourceTrigger=PropertyChanged}"
                           Minimum="0.0" Maximum="5.0"
                           SmallChange="0.1" LargeChange="0.5"
                           IsMoveToPointEnabled="True"
                           Height="20" Background="#37474f" Foreground="#64b5f6" Margin="0,0,10,0"/>
                    <TextBlock Grid.Column="1"
                              Text="{Binding SelectedSegment.FadeInDuration, Converter={StaticResource TransitionDurationConverter}}"
                              Foreground="#81c784" FontFamily="Courier New" FontWeight="Bold"
                              TextAlignment="Right" VerticalAlignment="Center"/>
                </Grid>

                <!-- Fade Out -->
                <TextBlock Text="Fade Out:" Foreground="#b0bec5" FontWeight="Bold" Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="70"/>
                    </Grid.ColumnDefinitions>
                    <Slider Grid.Column="0"
                           Value="{Binding SelectedSegment.FadeOutDuration, UpdateSourceTrigger=PropertyChanged}"
                           Minimum="0.0" Maximum="5.0"
                           SmallChange="0.1" LargeChange="0.5"
                           IsMoveToPointEnabled="True"
                           Height="20" Background="#37474f" Foreground="#64b5f6" Margin="0,0,10,0"/>
                    <TextBlock Grid.Column="1"
                              Text="{Binding SelectedSegment.FadeOutDuration, Converter={StaticResource TransitionDurationConverter}}"
                              Foreground="#81c784" FontFamily="Courier New" FontWeight="Bold"
                              TextAlignment="Right" VerticalAlignment="Center"/>
                </Grid>

                <!-- Source Start Offset (audio segments only) -->
                <StackPanel Margin="0,0,0,15">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSegment.Kind}" Value="audio">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Source Offset:" Foreground="#b0bec5" FontWeight="Bold" Margin="0,0,0,5"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0"
                               Value="{Binding SelectedSegment.SourceStartOffset, UpdateSourceTrigger=PropertyChanged}"
                               Minimum="0.0" Maximum="300.0"
                               SmallChange="0.1" LargeChange="1.0"
                               IsMoveToPointEnabled="True"
                               Height="20" Background="#37474f" Foreground="#ff9800" Margin="0,0,10,0"/>
                        <TextBlock Grid.Column="1"
                                  Text="{Binding SelectedSegment.SourceStartOffset, Converter={StaticResource TransitionDurationConverter}}"
                                  Foreground="#ff9800" FontFamily="Courier New" FontWeight="Bold"
                                  TextAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <TextBlock Text="Offset into source audio file (seconds). Adjusted automatically when left-trimming."
                               Foreground="#546e7a" FontSize="10" TextWrapping="Wrap" Margin="0,3,0,0"/>
                </StackPanel>

                <!-- Motion Preset (visual segments only) -->
                <StackPanel Margin="0,0,0,15">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSegment.Kind}" Value="visual">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <Separator Background="#37474f" Margin="0,0,0,12"/>

                    <TextBlock Text="🎬  Hiệu ứng chuyển động:" Foreground="#b0bec5" FontWeight="Bold"
                               Margin="0,0,0,8" FontFamily="Segoe UI Emoji"/>

                    <ComboBox x:Name="MotionPresetComboBox"
                              SelectedItem="{Binding SelectedSegment.MotionPreset, UpdateSourceTrigger=PropertyChanged}"
                              Background="#2d2d2d" Foreground="#e0e0e0"
                              BorderBrush="#546e7a" BorderThickness="1" Padding="8,5" Margin="0,0,0,8">
                        <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">None</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">ZoomIn</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">ZoomOut</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">PanLeft</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">PanRight</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">PanUp</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">PanDown</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">ZoomInPanLeft</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">ZoomInPanRight</System:String>
                    </ComboBox>

                    <TextBlock Text="Cường độ hiệu ứng:" Foreground="#b0bec5" Margin="0,0,0,5" FontSize="12"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0"
                                x:Name="SegMotionIntensitySlider"
                                Value="{Binding SelectedSegment.MotionIntensity, UpdateSourceTrigger=PropertyChanged, TargetNullValue=0.3}"
                                Minimum="0.0" Maximum="1.0"
                                SmallChange="0.05" LargeChange="0.1"
                                IsMoveToPointEnabled="True"
                                Height="20" Background="#37474f" Foreground="#ff9800" Margin="0,0,10,0"/>
                        <TextBlock Grid.Column="1"
                                   Foreground="#ff9800" FontFamily="Courier New" FontWeight="Bold"
                                   TextAlignment="Right" VerticalAlignment="Center">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0:P0}">
                                    <Binding Path="SelectedSegment.MotionIntensity" TargetNullValue="0.3"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </Grid>

                    <Border Background="#2a2a2a" CornerRadius="4" Padding="10,8">
                        <TextBlock Text="Chọn None để dùng hiệu ứng tự động từ Track (nếu Track bật auto-motion). Chọn preset cụ thể để ghi đè."
                                   Foreground="#546e7a" FontSize="10" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>

                <!-- Action Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Split (Ctrl+B)" Command="{Binding SplitSelectedSegmentAtPlayheadCommand}"
                           Background="#007acc" Foreground="White" Padding="10,8" MinHeight="32" Margin="0,0,8,0" VerticalContentAlignment="Center"/>
                    <Button Content="Duplicate" Command="{Binding DuplicateSelectedSegmentCommand}"
                           Background="#43a047" Foreground="White" Padding="12,8" MinHeight="32" Margin="0,0,8,0" VerticalContentAlignment="Center"/>
                    <Button Content="Delete" Command="{Binding DeleteSelectedSegmentCommand}"
                           Background="#e53935" Foreground="White" Padding="12,8" MinHeight="32" VerticalContentAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>

</UserControl>
