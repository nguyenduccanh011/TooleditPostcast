<UserControl x:Class="PodcastVideoEditor.Ui.Views.SegmentEditorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PodcastVideoEditor.Ui.Converters"
             xmlns:controls="clr-namespace:PodcastVideoEditor.Ui.Controls"
             Background="Transparent"
             Foreground="{StaticResource PanelForegroundBrush}">

    <UserControl.Resources>
        <conv:TransitionDurationConverter x:Key="TransitionDurationConverter"/>
        <conv:TimeValueConverter x:Key="TimeValueConverter"/>
        <!-- Implicit overrides: make all controls inside match PropertyEditorView's flat compact style -->
        <Style TargetType="{x:Type ComboBox}"  BasedOn="{StaticResource FlatComboBoxStyle}"/>
        <Style TargetType="{x:Type ComboBoxItem}" BasedOn="{StaticResource FlatComboBoxItemStyle}"/>
        <Style TargetType="{x:Type TextBox}"   BasedOn="{StaticResource FlatTextBoxStyle}"/>
        <Style TargetType="{x:Type Slider}"    BasedOn="{StaticResource CompactSliderStyle}"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Bar (matching TimelineView status bar height) -->
        <Border Grid.Row="0" Style="{StaticResource PropertyPanelHeaderBorderStyle}">
            <TextBlock Text="Segment Properties" 
                       Style="{StaticResource PropertyPanelHeaderTextStyle}"/>
        </Border>

        <!-- No Selection Message -->
        <TextBlock x:Name="NoSelectionText"
                  Grid.Row="1"
                  Text="Select a segment from timeline to edit properties"
                  Style="{StaticResource NoSelectionTextStyle}"
                  Visibility="Visible"/>

        <!-- Properties Panel -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" x:Name="PropertiesPanel">
            <StackPanel Margin="12,10,12,10">

                <!-- Time (read-only inline) -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Time:" Style="{StaticResource CompactPropertyLabelStyle}"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBlock Style="{StaticResource PropertyValueTextStyle}" FontSize="11" VerticalAlignment="Center">
                            <Run Text="{Binding SelectedSegment.StartTime, Converter={StaticResource TimeValueConverter}}"/><Run Text=" s"/>
                        </TextBlock>
                        <TextBlock Text=" â†’ " Foreground="{StaticResource MutedBorderBrush}" Margin="4,0" VerticalAlignment="Center"/>
                        <TextBlock Style="{StaticResource PropertyValueTextStyle}" FontSize="11" VerticalAlignment="Center">
                            <Run Text="{Binding SelectedSegment.EndTime, Converter={StaticResource TimeValueConverter}}"/><Run Text=" s"/>
                        </TextBlock>
                    </StackPanel>
                </Grid>

                <!-- Description (textarea stays 2-row) -->
                <TextBlock Text="Description:" Style="{StaticResource CompactPropertyLabelStyle}" VerticalAlignment="Top" Margin="0,0,0,3"/>
                <TextBox Text="{Binding SelectedSegment.Text, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap" AcceptsReturn="True" Height="60"
                        VerticalScrollBarVisibility="Auto" Margin="0,0,0,10"/>

                <!-- Background media (visual only) -->
                <StackPanel x:Name="BackgroundSection">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSegment.Kind}" Value="visual">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Grid Margin="0,0,0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="BG Media:" Style="{StaticResource CompactPropertyLabelStyle}" VerticalAlignment="Top" Margin="0,2,0,0"/>
                        <TextBlock x:Name="BackgroundPathText" Grid.Column="1" Text="No asset selected"
                                   Style="{StaticResource PropertyValueTextStyle}" FontSize="11"
                                   TextTrimming="CharacterEllipsis"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="90,3,0,10">
                        <Button Content="Choose file" Click="ChooseBackgroundButton_Click"
                               Style="{StaticResource PrimaryActionButtonStyle}" Padding="8,4" Height="26" Margin="0,0,6,0"/>
                        <Button Content="Clear" Click="ClearBackgroundButton_Click"
                               Style="{StaticResource NeutralActionButtonStyle}" Padding="8,4" Height="26"/>
                    </StackPanel>
                </StackPanel>

                <!-- Transition type -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Transition:" Style="{StaticResource CompactPropertyLabelStyle}"/>
                    <ComboBox Grid.Column="1" SelectedItem="{Binding SelectedSegment.TransitionType, UpdateSourceTrigger=PropertyChanged}">
                        <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">fade</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">cut</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">slide-left</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">slide-right</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">zoom-in</System:String>
                    </ComboBox>
                </Grid>

                <!-- Transition Duration -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="48"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Tr. Duration:" Style="{StaticResource CompactPropertyLabelStyle}"/>
                    <Slider Grid.Column="1"
                           Value="{Binding SelectedSegment.TransitionDuration, UpdateSourceTrigger=PropertyChanged}"
                           Minimum="0.0" Maximum="3.0" IsMoveToPointEnabled="True"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Grid.Column="2"
                              Text="{Binding SelectedSegment.TransitionDuration, Converter={StaticResource TransitionDurationConverter}}"
                              Style="{StaticResource PropertyValueTextStyle}" FontSize="11"
                              TextAlignment="Right" VerticalAlignment="Center"/>
                </Grid>

                <!-- Volume -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="48"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Volume:" Style="{StaticResource CompactPropertyLabelStyle}"/>
                    <Slider Grid.Column="1"
                           Value="{Binding SelectedSegment.Volume, UpdateSourceTrigger=PropertyChanged}"
                           Minimum="0.0" Maximum="1.0" SmallChange="0.05" LargeChange="0.1"
                           IsMoveToPointEnabled="True" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Grid.Column="2" Style="{StaticResource PropertyValueTextStyle}" FontSize="11"
                              TextAlignment="Right" VerticalAlignment="Center">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0:P0}">
                                <Binding Path="SelectedSegment.Volume"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </Grid>

                <!-- Fade In -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="48"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Fade In:" Style="{StaticResource CompactPropertyLabelStyle}"/>
                    <Slider Grid.Column="1"
                           Value="{Binding SelectedSegment.FadeInDuration, UpdateSourceTrigger=PropertyChanged}"
                           Minimum="0.0" Maximum="5.0" SmallChange="0.1" LargeChange="0.5"
                           IsMoveToPointEnabled="True" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Grid.Column="2"
                              Text="{Binding SelectedSegment.FadeInDuration, Converter={StaticResource TransitionDurationConverter}}"
                              Style="{StaticResource PropertyValueTextStyle}" FontSize="11"
                              TextAlignment="Right" VerticalAlignment="Center"/>
                </Grid>

                <!-- Fade Out -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="48"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Fade Out:" Style="{StaticResource CompactPropertyLabelStyle}"/>
                    <Slider Grid.Column="1"
                           Value="{Binding SelectedSegment.FadeOutDuration, UpdateSourceTrigger=PropertyChanged}"
                           Minimum="0.0" Maximum="5.0" SmallChange="0.1" LargeChange="0.5"
                           IsMoveToPointEnabled="True" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Grid.Column="2"
                              Text="{Binding SelectedSegment.FadeOutDuration, Converter={StaticResource TransitionDurationConverter}}"
                              Style="{StaticResource PropertyValueTextStyle}" FontSize="11"
                              TextAlignment="Right" VerticalAlignment="Center"/>
                </Grid>

                <!-- Source Start Offset (audio only) -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSegment.Kind}" Value="audio">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Grid Margin="0,0,0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="48"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Src Offset:" Style="{StaticResource CompactPropertyLabelStyle}"/>
                        <Slider Grid.Column="1"
                               Value="{Binding SelectedSegment.SourceStartOffset, UpdateSourceTrigger=PropertyChanged}"
                               Minimum="0.0" Maximum="300.0" SmallChange="0.1" LargeChange="1.0"
                               IsMoveToPointEnabled="True" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Grid.Column="2"
                                  Text="{Binding SelectedSegment.SourceStartOffset, Converter={StaticResource TransitionDurationConverter}}"
                                  Style="{StaticResource PropertyValueTextStyle}" FontSize="11"
                                  TextAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <TextBlock Text="Offset vÃ o file audio nguá»“n (giÃ¢y)."
                               Style="{StaticResource MutedHintTextStyle}" Margin="0,2,0,8"/>
                </StackPanel>

                <!-- Motion Preset (visual only) -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSegment.Kind}" Value="visual">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Separator Style="{StaticResource PropertySeparatorStyle}"/>
                    <TextBlock Text="ðŸŽ¬  Motion" Style="{StaticResource PropertySectionHeaderTextStyle}"/>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Preset:" Style="{StaticResource CompactPropertyLabelStyle}"/>
                        <ComboBox x:Name="MotionPresetComboBox" Grid.Column="1"
                                  SelectedItem="{Binding SelectedSegment.MotionPreset, UpdateSourceTrigger=PropertyChanged}">
                            <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">None</System:String>
                            <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">ZoomIn</System:String>
                            <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">ZoomOut</System:String>
                            <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">PanLeft</System:String>
                            <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">PanRight</System:String>
                            <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">PanUp</System:String>
                            <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">PanDown</System:String>
                            <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">ZoomInPanLeft</System:String>
                            <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">ZoomInPanRight</System:String>
                        </ComboBox>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="48"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Intensity:" Style="{StaticResource CompactPropertyLabelStyle}"/>
                        <Slider Grid.Column="1" x:Name="SegMotionIntensitySlider"
                                Value="{Binding SelectedSegment.MotionIntensity, UpdateSourceTrigger=PropertyChanged, TargetNullValue=0.3}"
                                Minimum="0.0" Maximum="1.0" SmallChange="0.05" LargeChange="0.1"
                                IsMoveToPointEnabled="True" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Grid.Column="2" Style="{StaticResource PropertyValueTextStyle}" FontSize="11"
                                   TextAlignment="Right" VerticalAlignment="Center">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0:P0}">
                                    <Binding Path="SelectedSegment.MotionIntensity" TargetNullValue="0.3"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </Grid>
                    <Border Style="{StaticResource PropertyHintCardStyle}" Margin="0,0,0,8">
                        <TextBlock Text="None = dÃ¹ng hiá»‡u á»©ng tá»« Track. Chá»n preset Ä‘á»ƒ ghi Ä‘Ã¨."
                                   Style="{StaticResource PropertyHintTextStyle}" FontStyle="Normal" Foreground="{StaticResource MutedBorderBrush}"/>
                    </Border>
                </StackPanel>

                <!-- Overlay Override (visual only) -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSegment.Kind}" Value="visual">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Separator Style="{StaticResource PropertySeparatorStyle}"/>
                    <TextBlock Text="ðŸŽ¨  Overlay" Style="{StaticResource PropertySectionHeaderTextStyle}"/>
                    <CheckBox x:Name="OverlayOverrideCheckBox"
                              Content="Ghi Ä‘Ã¨ overlay cá»§a Track" Margin="0,0,0,8"
                              Checked="OverlayOverrideCheckBox_Changed"
                              Unchecked="OverlayOverrideCheckBox_Changed"/>
                    <StackPanel x:Name="SegOverlayControlsPanel" Visibility="Collapsed">
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="48"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Opacity:" Style="{StaticResource CompactPropertyLabelStyle}"/>
                            <Slider Grid.Column="1" x:Name="SegOverlayOpacitySlider"
                                    Minimum="0" Maximum="100" Value="0"
                                    TickFrequency="5" IsSnapToTickEnabled="False"
                                    VerticalAlignment="Center" Margin="0,0,6,0"
                                    ValueChanged="SegOverlayOpacitySlider_ValueChanged"/>
                            <TextBlock x:Name="SegOverlayOpacityValueText" Grid.Column="2"
                                       Text="0%" Style="{StaticResource PropertyValueTextStyle}" FontSize="11"
                                       TextAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="MÃ u:" Style="{StaticResource CompactPropertyLabelStyle}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Border x:Name="SegOverlayColorSwatch"
                                        Width="22" Height="22" CornerRadius="4"
                                        Background="Black" BorderBrush="{StaticResource MutedBorderBrush}" BorderThickness="1"
                                        Cursor="Hand" VerticalAlignment="Center"
                                        MouseLeftButtonDown="SegOverlayColorSwatch_Click"/>
                                <TextBlock x:Name="SegOverlayColorHexText"
                                           Text="#000000" Foreground="{StaticResource ValueDisplayBrush}"
                                           FontFamily="Courier New" FontSize="11"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Grid>
                        <Popup x:Name="SegOverlayColorPopup"
                               PlacementTarget="{Binding ElementName=SegOverlayColorSwatch}"
                               Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
                               PopupAnimation="Fade">
                            <Border Style="{StaticResource PropertyPopupBorderStyle}">
                                <controls:ColorPickerPopup x:Name="SegOverlayColorPicker"/>
                            </Border>
                        </Popup>
                    </StackPanel>
                    <Border Style="{StaticResource PropertyHintCardStyle}" Margin="0,4,0,8">
                        <TextBlock Text="Báº­t Ä‘á»ƒ ghi Ä‘Ã¨ overlay cá»§a Track cho riÃªng segment nÃ y."
                                   Style="{StaticResource PropertyHintTextStyle}" FontStyle="Normal" Foreground="{StaticResource MutedBorderBrush}"/>
                    </Border>
                </StackPanel>

                <!-- Action Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                    <Button Content="Split (Ctrl+B)" Command="{Binding SplitSelectedSegmentAtPlayheadCommand}"
                          Style="{StaticResource PrimaryActionButtonStyle}" Padding="10,6" MinHeight="28" Margin="0,0,6,0"/>
                    <Button Content="Duplicate" Command="{Binding DuplicateSelectedSegmentCommand}"
                          Style="{StaticResource SuccessActionButtonStyle}" Padding="10,6" MinHeight="28" Margin="0,0,6,0"/>
                    <Button Content="Delete" Command="{Binding DeleteSelectedSegmentCommand}"
                          Style="{StaticResource DangerActionButtonStyle}" Padding="10,6" MinHeight="28"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>

</UserControl>
