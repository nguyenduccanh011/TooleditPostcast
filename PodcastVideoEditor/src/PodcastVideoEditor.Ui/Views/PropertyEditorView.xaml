<UserControl x:Class="PodcastVideoEditor.Ui.Views.PropertyEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:PodcastVideoEditor.Ui.Views"
             xmlns:conv="clr-namespace:PodcastVideoEditor.Ui.Converters"
             xmlns:controls="clr-namespace:PodcastVideoEditor.Ui.Controls"
             xmlns:media="clr-namespace:System.Windows.Media;assembly=PresentationCore"
             xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
             Background="Transparent"
             Foreground="#e0e0e0"
             MinWidth="220">

    <UserControl.Resources>
        <DropShadowEffect x:Key="PopupDropShadow" ShadowDepth="4" BlurRadius="12" Color="Black" Opacity="0.5"/>
        <ObjectDataProvider x:Key="SystemFontFamiliesProvider"
                            ObjectType="{x:Type media:Fonts}"
                            MethodName="get_SystemFontFamilies"/>

        <!-- Unique interaction state brushes \u2014 no App.xaml equivalent -->
        <SolidColorBrush x:Key="SegmentHoverBrush"  Color="#3f4349"/>
        <SolidColorBrush x:Key="SegmentActiveBrush" Color="#5b6068"/>

        <!-- Override default WPF selection colors in this panel to avoid bright blue/white artifacts -->
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#5b6068"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}"   Color="#2a2e35"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}"    Color="#2a2e35"/>

        <!-- FlatTextBoxStyle, FlatComboBoxStyle, FlatComboBoxItemStyle,
             CompactSliderStyle live in App.xaml — referenced here by key.
             Local implicit overrides so every ComboBox/TextBox/Slider in
             this panel automatically picks them up without explicit Style=. -->
        <Style TargetType="{x:Type TextBox}"     BasedOn="{StaticResource FlatTextBoxStyle}"/>
        <Style TargetType="{x:Type ComboBox}"    BasedOn="{StaticResource FlatComboBoxStyle}"/>
        <Style TargetType="{x:Type ComboBoxItem}" BasedOn="{StaticResource FlatComboBoxItemStyle}"/>
        <Style TargetType="{x:Type Slider}"      BasedOn="{StaticResource CompactSliderStyle}"/>

        <!-- SliderThumbStyle alias for local DataTemplates that reference it by this key -->
        <Style x:Key="SliderThumbStyle" TargetType="{x:Type Thumb}" BasedOn="{StaticResource FlatSliderThumbStyle}"/>

        <Style x:Key="SegmentToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{StaticResource PanelFieldBackgroundBrush}"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource SegmentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{StaticResource SegmentActiveBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SegmentListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="1,0,1,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="{StaticResource PanelFieldBackgroundBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource SegmentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{StaticResource SegmentActiveBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- String -->
        <DataTemplate x:Key="PropertyFieldStringTemplate">
            <Grid Margin="0,0,0,5"
                  Visibility="{Binding IsFieldVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="92"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Name}" Foreground="#b0bec5" FontWeight="SemiBold" FontSize="10" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FlatTextBoxStyle}"/>
            </Grid>
        </DataTemplate>

        <!-- TextArea -->
        <DataTemplate x:Key="PropertyFieldTextAreaTemplate">
            <Grid Margin="0,0,0,5"
                  Visibility="{Binding IsFieldVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="92"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Name}" Foreground="#b0bec5" FontWeight="SemiBold" FontSize="10" VerticalAlignment="Top" Margin="0,4,0,0"/>
                <TextBox Grid.Column="1" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FlatTextBoxStyle}"
                         TextWrapping="Wrap" AcceptsReturn="True" Height="52" VerticalContentAlignment="Top"
                         VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </DataTemplate>

        <!-- Int -->
        <DataTemplate x:Key="PropertyFieldIntTemplate">
            <Grid Margin="0,0,0,5"
                  Visibility="{Binding IsFieldVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="92"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Name}" Foreground="#b0bec5" FontWeight="SemiBold" FontSize="10" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FlatTextBoxStyle}"/>
            </Grid>
        </DataTemplate>

        <!-- Float -->
        <DataTemplate x:Key="PropertyFieldFloatTemplate">
            <Grid Margin="0,0,0,5"
                  Visibility="{Binding IsFieldVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="92"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Name}" Foreground="#b0bec5" FontWeight="SemiBold" FontSize="10" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0}}"
                         Style="{StaticResource FlatTextBoxStyle}"/>
            </Grid>
        </DataTemplate>

        <!-- Color (hex string + preview + popup picker) -->
        <DataTemplate x:Key="PropertyFieldColorTemplate">
            <Grid Margin="0,0,0,5"
                  Visibility="{Binding IsFieldVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="92"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Name}" Foreground="#b0bec5" FontWeight="SemiBold" FontSize="10" VerticalAlignment="Center"/>
                <Grid Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <!-- Clickable color preview that opens color picker popup -->
                    <ToggleButton x:Name="ColorPickerToggle" Width="32" Height="26" Margin="0,0,6,0"
                                  Background="Transparent" BorderBrush="{StaticResource PanelFieldBorderBrush}" BorderThickness="1"
                                  Cursor="Hand" ToolTip="Click to pick color">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Grid>
                                    <Border CornerRadius="2" BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}">
                                        <Grid>
                                            <!-- Checkerboard for transparency indication -->
                                            <Border CornerRadius="2"
                                                    Background="{Binding Value, Converter={StaticResource HexToBrushConverter}}"/>
                                            <!-- Small dropdown arrow indicator -->
                                            <TextBlock Text="▼" FontSize="7" Foreground="#80FFFFFF"
                                                       HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                       Margin="0,0,2,1"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>
                    <Popup IsOpen="{Binding IsChecked, ElementName=ColorPickerToggle, Mode=TwoWay}"
                           PlacementTarget="{Binding ElementName=ColorPickerToggle}"
                           Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
                           PopupAnimation="Fade">
                        <Border Background="#252530" BorderBrush="#546e7a" BorderThickness="1"
                                CornerRadius="6" Padding="2"
                                Effect="{StaticResource PopupDropShadow}">
                            <controls:ColorPickerPopup
                                SelectedColor="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Border>
                    </Popup>
                    <!-- Hex input kept for power users -->
                    <TextBox Grid.Column="1" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FlatTextBoxStyle}" FontFamily="Consolas" FontSize="12"/>
                </Grid>
            </Grid>
        </DataTemplate>

        <!-- Enum -->
        <DataTemplate x:Key="PropertyFieldEnumTemplate">
            <Grid Margin="0,0,0,5"
                  Visibility="{Binding IsFieldVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="92"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Name}" Foreground="#b0bec5" FontWeight="SemiBold" FontSize="10" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding EnumValues}"
                          SelectedItem="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                          Style="{StaticResource FlatComboBoxStyle}"/>
            </Grid>
        </DataTemplate>

        <!-- Font family -->
        <DataTemplate x:Key="PropertyFieldFontFamilyTemplate">
            <Grid Margin="0,0,0,5"
                  Visibility="{Binding IsFieldVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="92"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Name}" Foreground="#b0bec5" FontWeight="SemiBold" FontSize="10" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding Source={StaticResource SystemFontFamiliesProvider}}"
                          SelectedValuePath="Source"
                          SelectedValue="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                          IsTextSearchEnabled="True"
                          Style="{StaticResource FlatComboBoxStyle}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Source}" FontFamily="{Binding}" Foreground="#ffffff"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>
        </DataTemplate>

        <!-- Alignment as icon row -->
        <DataTemplate x:Key="PropertyFieldAlignmentRowTemplate">
            <Grid Margin="0,0,0,5"
                  Visibility="{Binding IsFieldVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="92"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Name}" Foreground="#b0bec5" FontWeight="SemiBold" FontSize="10" VerticalAlignment="Center"/>
                <ListBox Grid.Column="1"
                         ItemsSource="{Binding EnumValues}"
                         SelectedItem="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                         BorderThickness="0"
                         Background="{StaticResource PanelFieldBackgroundBrush}"
                         Height="30"
                         Width="126"
                         HorizontalAlignment="Left"
                         HorizontalContentAlignment="Center"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1" Columns="3"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <StaticResource ResourceKey="SegmentListBoxItemStyle"/>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel x:Name="AlignBars" Width="16" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Border x:Name="Bar1" Height="2" Width="14" Background="#f0f3f6" CornerRadius="1" Margin="0,0,0,2" HorizontalAlignment="Left"/>
                                <Border x:Name="Bar2" Height="2" Width="10" Background="#f0f3f6" CornerRadius="1" Margin="0,0,0,2" HorizontalAlignment="Left"/>
                                <Border x:Name="Bar3" Height="2" Width="12" Background="#f0f3f6" CornerRadius="1" HorizontalAlignment="Left"/>
                            </StackPanel>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding}" Value="Center">
                                    <Setter TargetName="Bar1" Property="HorizontalAlignment" Value="Center"/>
                                    <Setter TargetName="Bar2" Property="HorizontalAlignment" Value="Center"/>
                                    <Setter TargetName="Bar3" Property="HorizontalAlignment" Value="Center"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding}" Value="Right">
                                    <Setter TargetName="Bar1" Property="HorizontalAlignment" Value="Right"/>
                                    <Setter TargetName="Bar2" Property="HorizontalAlignment" Value="Right"/>
                                    <Setter TargetName="Bar3" Property="HorizontalAlignment" Value="Right"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </DataTemplate>

        <!-- Formatting row (Bold / Italic / Underline) -->
        <DataTemplate x:Key="PropertyFieldFormattingRowTemplate">
            <Grid Margin="0,0,0,5"
                  Visibility="{Binding IsFieldVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="92"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Name}" Foreground="#b0bec5" FontWeight="SemiBold" FontSize="10" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Left">
                    <ToggleButton Width="28" Height="28" Margin="0,0,8,0"
                                  IsChecked="{Binding CompositeFields[0].Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource SegmentToggleButtonStyle}"
                                  FontWeight="Bold" Content="B" ToolTip="Bold"/>
                    <ToggleButton Width="28" Height="28" Margin="0,0,8,0"
                                  IsChecked="{Binding CompositeFields[1].Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource SegmentToggleButtonStyle}"
                                  FontStyle="Italic" Content="I" ToolTip="Italic"/>
                    <ToggleButton Width="28" Height="28"
                        IsChecked="{Binding CompositeFields[2].Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource SegmentToggleButtonStyle}" Content="U" ToolTip="Underline">
                        <ToggleButton.ContentTemplate>
                            <DataTemplate>
                                <TextBlock Text="U" TextDecorations="Underline" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </ToggleButton.ContentTemplate>
                    </ToggleButton>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- Transform row (X/Y/W/H/R) -->
        <DataTemplate x:Key="PropertyFieldTransformRowTemplate">
            <Grid Margin="0,0,0,5"
                  Visibility="{Binding IsFieldVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="92"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Name}" Foreground="#b0bec5" FontWeight="SemiBold" FontSize="10" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="X" Foreground="#9fb0be" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox Width="48" Margin="0,0,8,0" Text="{Binding CompositeFields[0].Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0}}" Style="{StaticResource FlatTextBoxStyle}" FontSize="11"/>
                    <TextBlock Text="Y" Foreground="#9fb0be" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox Width="48" Margin="0,0,8,0" Text="{Binding CompositeFields[1].Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0}}" Style="{StaticResource FlatTextBoxStyle}" FontSize="11"/>
                    <TextBlock Text="W" Foreground="#9fb0be" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox Width="48" Margin="0,0,8,0" Text="{Binding CompositeFields[2].Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0}}" Style="{StaticResource FlatTextBoxStyle}" FontSize="11"/>
                    <TextBlock Text="H" Foreground="#9fb0be" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox Width="48" Margin="0,0,8,0" Text="{Binding CompositeFields[3].Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0}}" Style="{StaticResource FlatTextBoxStyle}" FontSize="11"/>
                    <TextBlock Text="R" Foreground="#9fb0be" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox Width="48" Text="{Binding CompositeFields[4].Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0}}" Style="{StaticResource FlatTextBoxStyle}" FontSize="11"/>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- Bool -->
        <DataTemplate x:Key="PropertyFieldBoolTemplate">
            <Grid Margin="0,0,0,5"
                  Visibility="{Binding IsFieldVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="92"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Name}" Foreground="#b0bec5" FontWeight="SemiBold" FontSize="10" VerticalAlignment="Center"/>
                <CheckBox Grid.Column="1" IsChecked="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                          HorizontalAlignment="Left" VerticalAlignment="Center"/>
            </Grid>
        </DataTemplate>

        <!-- Slider -->
        <DataTemplate x:Key="PropertyFieldSliderTemplate">
            <Grid Margin="0,0,0,5"
                  Visibility="{Binding IsFieldVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="92"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Name}" Foreground="#b0bec5" FontWeight="SemiBold" FontSize="10" VerticalAlignment="Center"/>
                <Grid Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Slider Minimum="{Binding MinValue}" Maximum="{Binding MaxValue}"
                            Value="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                            IsMoveToPointEnabled="True" Height="12" VerticalAlignment="Center"
                            IsSnapToTickEnabled="True" TickFrequency="1" SmallChange="1" LargeChange="1"
                            Style="{StaticResource CompactSliderStyle}" Margin="0,0,6,0"/>
                    <TextBox Grid.Column="1" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0}}"
                             Foreground="#ffffff" FontFamily="Consolas" FontSize="12"
                             MinWidth="52" Height="22" HorizontalContentAlignment="Right"
                             Style="{StaticResource FlatTextBoxStyle}" Padding="4,1"/>
                </Grid>
            </Grid>
        </DataTemplate>

        <views:PropertyFieldTemplateSelector x:Key="PropertyFieldTemplateSelector"
            StringTemplate="{StaticResource PropertyFieldStringTemplate}"
            TextAreaTemplate="{StaticResource PropertyFieldTextAreaTemplate}"
            IntTemplate="{StaticResource PropertyFieldIntTemplate}"
            FloatTemplate="{StaticResource PropertyFieldFloatTemplate}"
            ColorTemplate="{StaticResource PropertyFieldColorTemplate}"
            EnumTemplate="{StaticResource PropertyFieldEnumTemplate}"
            FontFamilyTemplate="{StaticResource PropertyFieldFontFamilyTemplate}"
            AlignmentRowTemplate="{StaticResource PropertyFieldAlignmentRowTemplate}"
            FormattingRowTemplate="{StaticResource PropertyFieldFormattingRowTemplate}"
            TransformRowTemplate="{StaticResource PropertyFieldTransformRowTemplate}"
            BoolTemplate="{StaticResource PropertyFieldBoolTemplate}"
            SliderTemplate="{StaticResource PropertyFieldSliderTemplate}"/>

    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" FontSize="14" FontWeight="Bold" Foreground="#64b5f6"
                   Margin="0,0,0,8" Text="{Binding HeaderText}"/>

        <!-- Timing badge (visible only when element is bound to a segment) -->
        <Border Grid.Row="1" CornerRadius="4" Background="#252530" Padding="8,5"
                Margin="0,0,0,10"
                Visibility="{Binding SegmentTimingText, Converter={StaticResource ObjectToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⏱" FontSize="12" Foreground="#90caf9" Margin="0,0,6,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding SegmentTimingText}" FontSize="12" FontFamily="Courier New"
                           Foreground="#81c784" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Track style sharing badge (visible when editing a text element on a shared track) -->
        <Border Grid.Row="1" CornerRadius="4" Background="#2a2535" Padding="8,5"
                Margin="0,0,0,6"
                Visibility="{Binding TrackStyleInfoText, Converter={StaticResource ObjectToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🔗" FontSize="12" Foreground="#ce93d8" Margin="0,0,6,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding TrackStyleInfoText}" FontSize="11"
                           Foreground="#ce93d8" VerticalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- No selection -->
        <TextBlock Grid.Row="2" Text="Select an element on canvas to edit properties"
                   Foreground="#7a8a96" FontStyle="Italic"
                   Visibility="{Binding SelectedElement, Converter={StaticResource NullToVisibilityConverter}}"/>

        <!-- Grouped properties (headers hidden for compact layout) -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                     Visibility="{Binding SelectedElement, Converter={StaticResource ObjectToVisibilityConverter}}">
            <ItemsControl ItemsSource="{Binding PropertyGroups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ItemsControl ItemsSource="{Binding Fields}" Margin="0,0,0,2"
                                      ItemTemplateSelector="{StaticResource PropertyFieldTemplateSelector}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
