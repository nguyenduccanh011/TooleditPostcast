<Window
    x:Class="PodcastVideoEditor.Ui.Views.RenderDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:PodcastVideoEditor.Ui.Converters"
    Title="Render Video"
    Width="500" Height="420"
    WindowStartupLocation="CenterOwner"
    WindowStyle="ToolWindow"
    ResizeMode="NoResize"
    Background="#1E1E1E"
    Foreground="#FFFFFF">

    <Window.Resources>
        <!-- Compact outline dropdown button -->
        <Style x:Key="DropBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="7,3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#3A3D3F"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="Render Video" FontSize="18" FontWeight="Bold"
                   Margin="0,0,0,16" Foreground="#007ACC"/>

        <!-- Resolution / Quality / Scale -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Resolution:" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#CCCCCC" FontSize="12"/>
            <Button x:Name="ResolutionButton" Content="{Binding SelectedResolution}"
                    Style="{StaticResource DropBtn}" Click="DropdownButton_Click">
                <Button.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="480p"  Command="{Binding SetResolutionCommand}" CommandParameter="480p"/>
                        <MenuItem Header="720p"  Command="{Binding SetResolutionCommand}" CommandParameter="720p"/>
                        <MenuItem Header="1080p" Command="{Binding SetResolutionCommand}" CommandParameter="1080p"/>
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>

            <TextBlock Text="Quality:" Margin="16,0,8,0" VerticalAlignment="Center" Foreground="#CCCCCC" FontSize="12"/>
            <Button x:Name="QualityButton" Content="{Binding SelectedQuality}"
                    Style="{StaticResource DropBtn}" Click="DropdownButton_Click">
                <Button.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="Low"    Command="{Binding SetQualityCommand}" CommandParameter="Low"/>
                        <MenuItem Header="Medium" Command="{Binding SetQualityCommand}" CommandParameter="Medium"/>
                        <MenuItem Header="High"   Command="{Binding SetQualityCommand}" CommandParameter="High"/>
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>

            <TextBlock Text="Scale:" Margin="16,0,8,0" VerticalAlignment="Center" Foreground="#CCCCCC" FontSize="12"/>
            <Button x:Name="ScaleModeButton" Content="{Binding SelectedScaleMode}"
                    Style="{StaticResource DropBtn}" Click="DropdownButton_Click">
                <Button.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="Fill"    Command="{Binding SetScaleModeCommand}" CommandParameter="Fill"/>
                        <MenuItem Header="Fit"     Command="{Binding SetScaleModeCommand}" CommandParameter="Fit"/>
                        <MenuItem Header="Stretch" Command="{Binding SetScaleModeCommand}" CommandParameter="Stretch"/>
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>
        </StackPanel>

        <!-- Output Folder -->
        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Output:" VerticalAlignment="Center" Foreground="#CCCCCC" FontSize="12" Margin="0,0,8,0"/>
            <TextBox Grid.Column="1" Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}"
                     Height="26" VerticalContentAlignment="Center"
                     Background="#252526" Foreground="#CCCCCC" BorderBrush="#3E3E42" BorderThickness="1"
                     FontSize="11" Padding="4,0"/>
            <Button Grid.Column="2" Content="Browse…" Command="{Binding BrowseOutputFolderCommand}"
                    Style="{StaticResource DropBtn}" Margin="6,0,0,0" Padding="8,4" Height="26"/>
        </Grid>

        <!-- Progress Bar -->
        <StackPanel Grid.Row="3" Margin="0,0,0,12">
            <TextBlock Text="Progress:" Margin="0,0,0,4" Foreground="#CCCCCC" FontSize="12"/>
            <ProgressBar Height="20" Maximum="100"
                         Value="{Binding RenderProgress}"
                         Background="#252526" Foreground="#28A745"/>
        </StackPanel>

        <!-- Status Message -->
        <Border Grid.Row="4" Padding="8" Background="#252526" BorderBrush="#3E3E42" BorderThickness="1"
                Margin="0,0,0,12" MinHeight="40">
            <TextBox Text="{Binding StatusMessage}" TextWrapping="Wrap"
                     Foreground="#FFFFFF" Background="Transparent" BorderThickness="0"
                     IsReadOnly="True" VerticalScrollBarVisibility="Auto" MaxHeight="80"/>
        </Border>

        <!-- Error notification -->
        <Border Grid.Row="5" Background="#3A1010" BorderBrush="#C0392B" BorderThickness="1"
                CornerRadius="3" Padding="8,4" VerticalAlignment="Top"
                Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#FF6B6B"
                       FontSize="12" TextWrapping="Wrap"/>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Start Render" Width="110" Height="32"
                    Background="#007ACC" Foreground="White" BorderThickness="0"
                    Command="{Binding StartRenderCommand}"
                    CommandParameter="{Binding Project, RelativeSource={RelativeSource AncestorType=Window}}"
                    Cursor="Hand" Margin="0,0,8,0">
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRendering}" Value="True">
                                <Setter Property="Content" Value="Rendering…"/>
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="Cancel" Width="90" Height="32"
                    Background="#C0392B" Foreground="White" BorderThickness="0"
                    IsEnabled="{Binding CanCancel}"
                    Command="{Binding CancelRenderCommand}"
                    Visibility="{Binding IsRendering, Converter={StaticResource BoolToVisibilityConverter}}"
                    Cursor="Hand" Margin="0,0,8,0"/>
            <Button Content="Close" Width="80" Height="32"
                    Background="#3E3E42" Foreground="White" BorderThickness="0"
                    Click="CloseButton_Click" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
