<UserControl x:Class="PodcastVideoEditor.Ui.Views.ElementsMediaPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PodcastVideoEditor.Ui.Converters"
             Background="#1e1e1e"
             Foreground="#e0e0e0">

    <UserControl.Resources>
        <conv:FilePathToImageConverter x:Key="FilePathToImageConverter"/>

        <!-- Tab header style (CapCut-like compact) -->
        <Style x:Key="PanelTabItem" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8a9aa8"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" Cursor="Hand">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#2d3a4a"/>
                                <Setter Property="Foreground" Value="#64b5f6"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#2a2d2e"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Asset item template (list-style, used for Audio tab) -->
        <DataTemplate x:Key="AssetItemTemplate">
            <Border Background="#2d2d2d" BorderBrush="#546e7a" BorderThickness="1" Padding="8" Margin="0,0,0,6"
                    MouseMove="AssetItem_MouseMove" MouseLeftButtonDown="AssetItem_MouseLeftButtonDown"
                    Cursor="Hand" Tag="{Binding}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#e0e0e0" TextTrimming="CharacterEllipsis" MaxWidth="220"/>
                    <TextBlock Grid.Row="1" Foreground="#78909c" FontSize="10" Margin="0,2,0,0">
                        <Run Text="{Binding Type, Mode=OneWay}"/>
                        <Run Text=" · Kéo thả vào timeline"/>
                    </TextBlock>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,6,0,0">
                        <Button Content="Thêm vào timeline"
                                Command="{Binding DataContext.TimelineViewModel.AddSegmentWithAssetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                Background="#43a047" Foreground="White" Padding="8,4" FontSize="11" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Thumbnail card template for Media tab -->
        <DataTemplate x:Key="MediaThumbnailTemplate">
            <Border Width="110" Background="#2d2d2d" BorderBrush="#546e7a" BorderThickness="1"
                    Margin="0,0,6,6" CornerRadius="4"
                    MouseMove="AssetItem_MouseMove" MouseLeftButtonDown="AssetItem_MouseLeftButtonDown"
                    Cursor="Hand" Tag="{Binding}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="75"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- Thumbnail preview -->
                    <Border Background="#1a1a1a" CornerRadius="4,4,0,0" ClipToBounds="True">
                        <Grid>
                            <Image Source="{Binding FilePath, Converter={StaticResource FilePathToImageConverter}}"
                                   Stretch="UniformToFill" RenderOptions.BitmapScalingMode="Fant"/>
                            <!-- Fallback icon for non-image assets -->
                            <TextBlock Text="🎬" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="#546e7a" FontFamily="Segoe UI Emoji">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Type}" Value="Video">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Setter Property="Text" Value="🎬"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                    <!-- Asset name -->
                    <TextBlock Grid.Row="1" Text="{Binding Name}" FontSize="10" FontWeight="SemiBold"
                               Foreground="#e0e0e0" TextTrimming="CharacterEllipsis"
                               Margin="4,4,4,0" ToolTip="{Binding Name}"/>
                    <!-- Type + duration -->
                    <TextBlock Grid.Row="2" Foreground="#78909c" FontSize="9" Margin="4,1,4,4">
                        <Run Text="{Binding Type, Mode=OneWay}"/>
                    </TextBlock>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Text="Elements / Media" FontSize="14" FontWeight="Bold" Foreground="#64b5f6" Margin="8,8,8,4"/>

        <!-- Tab-based panel (CapCut-style: Media | Audio | Text | Script) -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0"
                    Padding="0" Margin="0">
            <TabControl.Resources>
                <Style TargetType="TabItem" BasedOn="{StaticResource PanelTabItem}"/>
            </TabControl.Resources>

            <!-- Tab 1: Media (Image/Video assets) -->
            <TabItem Header="Media">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8,8,8,0">
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Hình ảnh / Video" Foreground="#b0bec5" FontSize="11" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="Import Media"
                                    Click="ImportMediaButton_Click"
                                    Background="#007acc" Foreground="White" Padding="10,4" FontSize="11" Cursor="Hand"/>
                        </Grid>
                        <ItemsControl x:Name="MediaAssetsList"
                                      ItemsSource="{Binding ProjectViewModel.CurrentProject.Assets}"
                                      ItemTemplate="{StaticResource MediaThumbnailTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <!-- Filtered in code-behind to Image/Video only -->
                        </ItemsControl>
                        <TextBlock x:Name="NoMediaText" Text="Chưa có media. Nhấn Import Media để thêm ảnh hoặc video."
                                   Foreground="#546e7a" FontStyle="Italic" Margin="0,8,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 2: Audio -->
            <TabItem Header="Audio">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8,8,8,0">
                        <TextBlock Text="Audio clips" Foreground="#b0bec5" FontSize="11" Margin="0,0,0,6"/>
                        <ItemsControl x:Name="AudioAssetsList"
                                      ItemsSource="{Binding ProjectViewModel.AudioAssets}"
                                      ItemTemplate="{StaticResource AssetItemTemplate}">
                        </ItemsControl>
                        <Button Content="Import Audio"
                                Click="ImportAudioButton_Click"
                                Background="#007acc" Foreground="White" Padding="10,6" Margin="0,8,0,0"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 3: Text (draggable text presets) -->
            <TabItem Header="Text">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8,8,8,0">
                        <TextBlock Text="Kéo thả vào timeline hoặc nhấn để thêm tại playhead"
                                   Foreground="#546e7a" FontSize="10" FontStyle="Italic" Margin="0,0,0,8" TextWrapping="Wrap"/>

                        <TextBlock Text="Text Presets" Foreground="#b0bec5" FontSize="11" Margin="0,0,0,6"/>

                        <!-- Draggable: Title -->
                        <Border Background="#2d3a4a" BorderBrush="#546e7a" BorderThickness="1" CornerRadius="4"
                                Padding="10,8" Margin="0,0,0,6" Cursor="Hand"
                                Tag="Title"
                                MouseLeftButtonDown="ElementItem_MouseLeftButtonDown"
                                MouseMove="ElementItem_MouseMove"
                                MouseLeftButtonUp="ElementItem_MouseLeftButtonUp">
                            <StackPanel>
                                <TextBlock Text="Aa Title" FontSize="16" FontWeight="Bold" Foreground="#64b5f6"/>
                                <TextBlock Text="Tiêu đề lớn, đậm" Foreground="#78909c" FontSize="10" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Draggable: Subtitle -->
                        <Border Background="#2d3a4a" BorderBrush="#546e7a" BorderThickness="1" CornerRadius="4"
                                Padding="10,8" Margin="0,0,0,6" Cursor="Hand"
                                Tag="Subtitle"
                                MouseLeftButtonDown="ElementItem_MouseLeftButtonDown"
                                MouseMove="ElementItem_MouseMove"
                                MouseLeftButtonUp="ElementItem_MouseLeftButtonUp">
                            <StackPanel>
                                <TextBlock Text="Aa Subtitle" FontSize="13" FontWeight="SemiBold" Foreground="#b0bec5"/>
                                <TextBlock Text="Phụ đề, chữ vừa" Foreground="#78909c" FontSize="10" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Draggable: Lower Third -->
                        <Border Background="#2d3a4a" BorderBrush="#546e7a" BorderThickness="1" CornerRadius="4"
                                Padding="10,8" Margin="0,0,0,6" Cursor="Hand"
                                Tag="LowerThird"
                                MouseLeftButtonDown="ElementItem_MouseLeftButtonDown"
                                MouseMove="ElementItem_MouseMove"
                                MouseLeftButtonUp="ElementItem_MouseLeftButtonUp">
                            <StackPanel>
                                <TextBlock Text="▬ Lower Third" FontSize="12" Foreground="#81c784"/>
                                <TextBlock Text="Thanh chữ phía dưới" Foreground="#78909c" FontSize="10" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Draggable: Body Text -->
                        <Border Background="#2d3a4a" BorderBrush="#546e7a" BorderThickness="1" CornerRadius="4"
                                Padding="10,8" Margin="0,0,0,6" Cursor="Hand"
                                Tag="Caption"
                                MouseLeftButtonDown="ElementItem_MouseLeftButtonDown"
                                MouseMove="ElementItem_MouseMove"
                                MouseLeftButtonUp="ElementItem_MouseLeftButtonUp">
                            <StackPanel>
                                <TextBlock Text="Aa Body Text" FontSize="12" Foreground="#e0e0e0"/>
                                <TextBlock Text="Nội dung, caption" Foreground="#78909c" FontSize="10" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 4: Effects (Visualizer and overlays) -->
            <TabItem Header="Effects">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8,8,8,0">
                        <TextBlock Text="Kéo thả vào timeline hoặc nhấn để thêm tại playhead"
                                   Foreground="#546e7a" FontSize="10" FontStyle="Italic" Margin="0,0,0,8" TextWrapping="Wrap"/>

                        <TextBlock Text="Audio Effects" Foreground="#b0bec5" FontSize="11" Margin="0,0,0,6"/>

                        <!-- Draggable: Visualizer -->
                        <Border Background="#2d3a4a" BorderBrush="#546e7a" BorderThickness="1" CornerRadius="4"
                                Padding="10,8" Margin="0,0,0,6" Cursor="Hand"
                                Tag="Visualizer"
                                MouseLeftButtonDown="ElementItem_MouseLeftButtonDown"
                                MouseMove="ElementItem_MouseMove"
                                MouseLeftButtonUp="ElementItem_MouseLeftButtonUp">
                            <StackPanel>
                                <TextBlock Text="🎵 Audio Visualizer" FontSize="13" FontWeight="SemiBold" Foreground="#ce93d8"/>
                                <TextBlock Text="Spectrum, bars, waveform" Foreground="#78909c" FontSize="10" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 5: Library (Global asset library) -->
            <TabItem Header="📚 Library">
                <Grid Margin="8,8,8,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Category filter + Search -->
                    <Grid Grid.Row="0" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="LibraryCategoryFilter"
                                  ItemsSource="{Binding LibraryViewModel.Categories}"
                                  SelectedItem="{Binding LibraryViewModel.SelectedCategory}"
                                  Background="#2d2d2d" Foreground="#e0e0e0"
                                  MinWidth="90" Margin="0,0,6,0" FontSize="11"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding LibraryViewModel.SearchText, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                                 Background="#1e1e1e" Foreground="#e0e0e0"
                                 BorderBrush="#546e7a" BorderThickness="1"
                                 Padding="6,4" FontSize="11"
                                 Tag="🔍 Search library..."/>
                    </Grid>

                    <!-- Section label -->
                    <TextBlock Grid.Row="1" Foreground="#b0bec5" FontSize="11" Margin="0,0,0,4">
                        <Run Text="Library assets ("/>
                        <Run Text="{Binding LibraryViewModel.Assets.Count, Mode=OneWay}"/>
                        <Run Text=")"/>
                    </TextBlock>

                    <!-- Thumbnail grid -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="LibraryAssetsList"
                                      ItemsSource="{Binding LibraryViewModel.Assets}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="110" Background="#2d2d2d" BorderBrush="#546e7a" BorderThickness="1"
                                            Margin="0,0,6,6" CornerRadius="4" Cursor="Hand"
                                            Tag="{Binding}"
                                            MouseLeftButtonDown="LibraryAssetItem_MouseLeftButtonDown"
                                            MouseMove="LibraryAssetItem_MouseMove"
                                            MouseRightButtonUp="LibraryAssetItem_RightClick">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="75"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <!-- Thumbnail -->
                                            <Border Background="#1a1a1a" CornerRadius="4,4,0,0" ClipToBounds="True">
                                                <Image Source="{Binding FilePath, Converter={StaticResource FilePathToImageConverter}}"
                                                       Stretch="UniformToFill" RenderOptions.BitmapScalingMode="Fant"/>
                                            </Border>
                                            <!-- Name -->
                                            <TextBlock Grid.Row="1" Text="{Binding Name}" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="#e0e0e0" TextTrimming="CharacterEllipsis"
                                                       Margin="4,4,4,0" ToolTip="{Binding Name}"/>
                                            <!-- Category + built-in badge -->
                                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="4,1,4,4">
                                                <TextBlock Foreground="#78909c" FontSize="9" Text="{Binding Category}"/>
                                                <TextBlock Foreground="#64b5f6" FontSize="9" Margin="4,0,0,0"
                                                           Text="built-in">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsBuiltIn}" Value="False">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Import + status -->
                    <StackPanel Grid.Row="3" Margin="0,6,0,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Content="+ Import"
                                    Click="ImportLibraryButton_Click"
                                    Background="#007acc" Foreground="White" Padding="10,4" FontSize="11" Cursor="Hand"/>
                            <ComboBox x:Name="ImportCategoryCombo" Grid.Column="1"
                                      ItemsSource="{Binding LibraryViewModel.Categories}"
                                      SelectedIndex="0"
                                      Background="#2d2d2d" Foreground="#e0e0e0"
                                      MinWidth="90" Margin="6,0,0,0" FontSize="11"/>
                        </Grid>
                        <TextBlock Text="{Binding LibraryViewModel.StatusMessage}" Foreground="#78909c"
                                   FontSize="10" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Tab 6: Script (paste-format editor) -->
            <TabItem Header="Script">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8,8,8,0">
                        <TextBlock Text="Script (dán định dạng [start → end] text)" Foreground="#b0bec5" FontSize="11"
                                   TextWrapping="Wrap" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding TimelineViewModel.ScriptPasteText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#1e1e1e" Foreground="#e0e0e0" Padding="8,6"
                                 BorderBrush="#546e7a" BorderThickness="1"
                                 TextWrapping="Wrap" AcceptsReturn="True" Height="120" VerticalScrollBarVisibility="Auto"
                                 VerticalContentAlignment="Top"
                                 ToolTip="Ví dụ: [0.00 → 6.04]  Chào mừng đến với podcast..."/>
                        <Button Content="Áp dụng script" Command="{Binding TimelineViewModel.ApplyScriptCommand}"
                                HorizontalAlignment="Left" Margin="0,8,0,0"
                                Background="#43a047" Foreground="White" Padding="12,8" MinHeight="32"/>
                        <Button Content="✦ Phân tích AI" Command="{Binding TimelineViewModel.AnalyzeWithAICommand}"
                                HorizontalAlignment="Left" Margin="0,6,0,0"
                                Background="#7b1fa2" Foreground="White" Padding="12,8" MinHeight="32"
                                ToolTip="Normalize script → tách đoạn + keywords → tìm 60 ảnh/đoạn → AI chọn ảnh tốt nhất"/>
                        <CheckBox Content="Tự động xóa khoảng trống"
                                  IsChecked="{Binding TimelineViewModel.AutoCloseGaps}"
                                  Foreground="#b0bec5" FontSize="11" Margin="0,8,0,0"
                                  ToolTip="Tự động mở rộng EndTime mỗi segment để liền mạch với segment kế tiếp (không có khung đen giữa các cảnh)"/>
                        <TextBlock Text="{Binding TimelineViewModel.AIAnalysisStatus}"
                                   Foreground="#b0bec5" FontSize="11" TextWrapping="Wrap"
                                   Margin="0,4,0,0"
                                   Visibility="{Binding TimelineViewModel.AIAnalysisStatus, Converter={StaticResource NullOrEmptyToCollapsedConverter}}"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
