<UserControl x:Class="PodcastVideoEditor.Ui.Views.ElementsMediaPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PodcastVideoEditor.Ui.Converters"
             Background="#1e1e1e"
             Foreground="#e0e0e0">

    <UserControl.Resources>
        <conv:FilePathToImageConverter x:Key="FilePathToImageConverter"/>

        <!-- Tab header style (CapCut-like compact) -->
        <Style x:Key="PanelTabItem" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8a9aa8"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" Cursor="Hand">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#2d3a4a"/>
                                <Setter Property="Foreground" Value="#64b5f6"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#2a2d2e"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Asset item template (list-style, used for Audio tab) -->
        <DataTemplate x:Key="AssetItemTemplate">
            <Border Background="#2d2d2d" BorderBrush="#546e7a" BorderThickness="1" Padding="8" Margin="0,0,0,6"
                    MouseMove="AssetItem_MouseMove" MouseLeftButtonDown="AssetItem_MouseLeftButtonDown"
                    Cursor="Hand" Tag="{Binding}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#e0e0e0" TextTrimming="CharacterEllipsis" MaxWidth="220"/>
                    <TextBlock Grid.Row="1" Foreground="#78909c" FontSize="10" Margin="0,2,0,0">
                        <Run Text="{Binding Type, Mode=OneWay}"/>
                        <Run Text=" · Kéo thả vào timeline"/>
                    </TextBlock>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,6,0,0">
                        <Button Content="Thêm vào timeline"
                                Command="{Binding DataContext.TimelineViewModel.AddSegmentWithAssetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                Background="#43a047" Foreground="White" Padding="8,4" FontSize="11" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Thumbnail card template for Media tab -->
        <DataTemplate x:Key="MediaThumbnailTemplate">
            <Border Width="110" Background="#2d2d2d" BorderBrush="#546e7a" BorderThickness="1"
                    Margin="0,0,6,6" CornerRadius="4"
                    MouseMove="AssetItem_MouseMove" MouseLeftButtonDown="AssetItem_MouseLeftButtonDown"
                    Cursor="Hand" Tag="{Binding}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="75"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- Thumbnail preview -->
                    <Border Background="#1a1a1a" CornerRadius="4,4,0,0" ClipToBounds="True">
                        <Grid>
                            <Image Source="{Binding FilePath, Converter={StaticResource FilePathToImageConverter}}"
                                   Stretch="UniformToFill" RenderOptions.BitmapScalingMode="Fant"/>
                            <!-- Fallback icon for non-image assets -->
                            <TextBlock Text="🎬" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="#546e7a" FontFamily="Segoe UI Emoji">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Type}" Value="Video">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Setter Property="Text" Value="🎬"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                    <!-- Asset name -->
                    <TextBlock Grid.Row="1" Text="{Binding Name}" FontSize="10" FontWeight="SemiBold"
                               Foreground="#e0e0e0" TextTrimming="CharacterEllipsis"
                               Margin="4,4,4,0" ToolTip="{Binding Name}"/>
                    <!-- Type + duration -->
                    <TextBlock Grid.Row="2" Foreground="#78909c" FontSize="9" Margin="4,1,4,4">
                        <Run Text="{Binding Type, Mode=OneWay}"/>
                    </TextBlock>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Text="Elements / Media" FontSize="14" FontWeight="Bold" Foreground="#64b5f6" Margin="8,8,8,4"/>

        <!-- Tab-based panel (CapCut-style: Media | Audio | Text | Script) -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0"
                    Padding="0" Margin="0">
            <TabControl.Resources>
                <Style TargetType="TabItem" BasedOn="{StaticResource PanelTabItem}"/>
            </TabControl.Resources>

            <!-- Tab 1: Media (Image/Video assets) -->
            <TabItem Header="Media">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8,8,8,0">
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Hình ảnh / Video" Foreground="#b0bec5" FontSize="11" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="Import Media"
                                    Click="ImportMediaButton_Click"
                                    Background="#007acc" Foreground="White" Padding="10,4" FontSize="11" Cursor="Hand"/>
                        </Grid>
                        <ItemsControl x:Name="MediaAssetsList"
                                      ItemsSource="{Binding ProjectViewModel.CurrentProject.Assets}"
                                      ItemTemplate="{StaticResource MediaThumbnailTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <!-- Filtered in code-behind to Image/Video only -->
                        </ItemsControl>
                        <TextBlock x:Name="NoMediaText" Text="Chưa có media. Nhấn Import Media để thêm ảnh hoặc video."
                                   Foreground="#546e7a" FontStyle="Italic" Margin="0,8,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 2: Audio (Audio assets + BGM) -->
            <TabItem Header="Audio">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8,8,8,0">
                        <TextBlock Text="Audio clips" Foreground="#b0bec5" FontSize="11" Margin="0,0,0,6"/>
                        <ItemsControl x:Name="AudioAssetsList"
                                      ItemsSource="{Binding ProjectViewModel.AudioAssets}"
                                      ItemTemplate="{StaticResource AssetItemTemplate}">
                        </ItemsControl>
                        <Button Content="Import Audio"
                                Click="ImportAudioButton_Click"
                                Background="#007acc" Foreground="White" Padding="10,6" Margin="0,8,0,0"
                                HorizontalAlignment="Left"/>

                        <!-- BGM (Background Music) Section -->
                        <Border Margin="0,16,0,0" BorderBrush="#37474f" BorderThickness="0,1,0,0" Padding="0,12,0,0">
                            <StackPanel>
                                <TextBlock Text="Background Music (BGM)" Foreground="#ff9800" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                                <ItemsControl x:Name="BgmTracksList"
                                              ItemsSource="{Binding ProjectViewModel.CurrentProject.BgmTracks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#2d3a4a" CornerRadius="4" Padding="8,6" Margin="0,0,0,6"
                                                    BorderBrush="#546e7a" BorderThickness="1">
                                                <StackPanel>
                                                    <!-- Header: Name + Enabled toggle -->
                                                    <Grid Margin="0,0,0,4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Name}" Foreground="#e0e0e0" FontWeight="SemiBold" FontSize="11"
                                                                   VerticalAlignment="Center"/>
                                                        <CheckBox Grid.Column="1" IsChecked="{Binding IsEnabled}" Content="On"
                                                                  Foreground="#81c784" VerticalAlignment="Center" FontSize="10"/>
                                                    </Grid>
                                                    <!-- File path -->
                                                    <TextBlock Text="{Binding AudioPath}" Foreground="#7a8a96" FontSize="10"
                                                               TextTrimming="CharacterEllipsis" ToolTip="{Binding AudioPath}" Margin="0,0,0,4"/>
                                                    <!-- Volume -->
                                                    <Grid Margin="0,2,0,2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="55"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="40"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Volume:" Foreground="#b0bec5" FontSize="10" VerticalAlignment="Center"/>
                                                        <Slider Grid.Column="1" Value="{Binding Volume}" Minimum="0" Maximum="1"
                                                                SmallChange="0.05" LargeChange="0.1" IsMoveToPointEnabled="True"
                                                                Height="16" Background="#37474f" Foreground="#ff9800"/>
                                                        <TextBlock Grid.Column="2" Foreground="#ff9800" FontSize="10" FontFamily="Courier New"
                                                                   TextAlignment="Right" VerticalAlignment="Center">
                                                            <TextBlock.Text>
                                                                <MultiBinding StringFormat="{}{0:P0}">
                                                                    <Binding Path="Volume"/>
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </Grid>
                                                    <!-- Fade In / Fade Out -->
                                                    <Grid Margin="0,2,0,2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="55"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="40"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Fade In:" Foreground="#b0bec5" FontSize="10" VerticalAlignment="Center"/>
                                                        <Slider Grid.Column="1" Value="{Binding FadeInSeconds}" Minimum="0" Maximum="10"
                                                                SmallChange="0.5" LargeChange="1" IsMoveToPointEnabled="True"
                                                                Height="16" Background="#37474f" Foreground="#64b5f6"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding FadeInSeconds, StringFormat={}{0:F1}s}"
                                                                   Foreground="#64b5f6" FontSize="10" FontFamily="Courier New"
                                                                   TextAlignment="Right" VerticalAlignment="Center"/>
                                                    </Grid>
                                                    <Grid Margin="0,2,0,2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="55"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="40"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Fade Out:" Foreground="#b0bec5" FontSize="10" VerticalAlignment="Center"/>
                                                        <Slider Grid.Column="1" Value="{Binding FadeOutSeconds}" Minimum="0" Maximum="10"
                                                                SmallChange="0.5" LargeChange="1" IsMoveToPointEnabled="True"
                                                                Height="16" Background="#37474f" Foreground="#64b5f6"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding FadeOutSeconds, StringFormat={}{0:F1}s}"
                                                                   Foreground="#64b5f6" FontSize="10" FontFamily="Courier New"
                                                                   TextAlignment="Right" VerticalAlignment="Center"/>
                                                    </Grid>
                                                    <!-- Loop + Start Time row -->
                                                    <Grid Margin="0,2,0,2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <CheckBox IsChecked="{Binding IsLooping}" Content="Loop"
                                                                  Foreground="#b0bec5" FontSize="10" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                                            <TextBlock Text="Start:" Foreground="#b0bec5" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                            <TextBlock Text="{Binding StartTime, StringFormat={}{0:F1}s}" Foreground="#81c784"
                                                                       FontSize="10" FontFamily="Courier New" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Grid>
                                                    <!-- Remove button -->
                                                    <Button Content="Remove" Click="RemoveBgmButton_Click"
                                                            Tag="{Binding Id}"
                                                            Background="#6d4c41" Foreground="White" Padding="6,3"
                                                            FontSize="10" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Content="+ Add BGM Track"
                                        Click="AddBgmButton_Click"
                                        Background="#ff9800" Foreground="White" Padding="10,6" Margin="0,4,0,8"
                                        HorizontalAlignment="Left" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 3: Visual (All overlay elements) -->
            <TabItem Header="Visual">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8,8,8,0">
                        <TextBlock Text="Text Elements" Foreground="#b0bec5" FontSize="11" Margin="0,0,0,6"/>
                        <Button Content="+ Title" Command="{Binding CanvasViewModel.AddTitleElementCommand}"
                                Background="#007acc" Foreground="White" Padding="10,6" Margin="0,0,0,6" HorizontalAlignment="Stretch"/>
                        <Button Content="+ Text" Command="{Binding CanvasViewModel.AddTextElementCommand}"
                                Background="#007acc" Foreground="White" Padding="10,6" Margin="0,0,0,6" HorizontalAlignment="Stretch"/>

                        <TextBlock Text="Visual Elements" Foreground="#b0bec5" FontSize="11" Margin="0,10,0,6"/>
                        <Button Content="+ Logo" Command="{Binding CanvasViewModel.AddLogoElementCommand}"
                                Background="#6F42C1" Foreground="White" Padding="10,6" Margin="0,0,0,6" HorizontalAlignment="Stretch"/>
                        <Button Content="+ Image" Command="{Binding CanvasViewModel.AddImageElementCommand}"
                                Background="#6F42C1" Foreground="White" Padding="10,6" Margin="0,0,0,6" HorizontalAlignment="Stretch"/>
                        <Button Content="+ Visualizer" Command="{Binding CanvasViewModel.AddVisualizerElementCommand}"
                                Background="#6F42C1" Foreground="White" Padding="10,6" Margin="0,0,0,6" HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 4: Script (paste-format editor) -->
            <TabItem Header="Script">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8,8,8,0">
                        <TextBlock Text="Script (dán định dạng [start → end] text)" Foreground="#b0bec5" FontSize="11"
                                   TextWrapping="Wrap" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding TimelineViewModel.ScriptPasteText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#1e1e1e" Foreground="#e0e0e0" Padding="8,6"
                                 BorderBrush="#546e7a" BorderThickness="1"
                                 TextWrapping="Wrap" AcceptsReturn="True" Height="120" VerticalScrollBarVisibility="Auto"
                                 VerticalContentAlignment="Top"
                                 ToolTip="Ví dụ: [0.00 → 6.04]  Chào mừng đến với podcast..."/>
                        <Button Content="Áp dụng script" Command="{Binding TimelineViewModel.ApplyScriptCommand}"
                                HorizontalAlignment="Left" Margin="0,8,0,0"
                                Background="#43a047" Foreground="White" Padding="12,8" MinHeight="32"/>
                        <Button Content="✦ Phân tích AI" Command="{Binding TimelineViewModel.AnalyzeWithAICommand}"
                                HorizontalAlignment="Left" Margin="0,6,0,0"
                                Background="#7b1fa2" Foreground="White" Padding="12,8" MinHeight="32"
                                ToolTip="Normalize script → tách đoạn + keywords → tìm 60 ảnh/đoạn → AI chọn ảnh tốt nhất"/>
                        <TextBlock Text="{Binding TimelineViewModel.AIAnalysisStatus}"
                                   Foreground="#b0bec5" FontSize="11" TextWrapping="Wrap"
                                   Margin="0,4,0,0"
                                   Visibility="{Binding TimelineViewModel.AIAnalysisStatus, Converter={StaticResource NullOrEmptyToCollapsedConverter}}"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
