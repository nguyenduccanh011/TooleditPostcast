<UserControl x:Class="PodcastVideoEditor.Ui.Views.CanvasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dd="urn:gong-wpf-dragdrop"
             xmlns:views="clr-namespace:PodcastVideoEditor.Ui.Views"
             xmlns:conv="clr-namespace:PodcastVideoEditor.Ui.Converters"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900"
             Background="Transparent" Foreground="White"
             KeyDown="OnCanvasKeyDown"
             FocusManager.FocusedElement="{Binding RelativeSource={RelativeSource Self}}">

    <UserControl.Resources>
        <conv:FilePathToImageConverter x:Key="FilePathToImageConverter"/>
        <conv:ScaleModeConverter x:Key="ScaleModeConverter"/>
        <conv:BoolToFlipScaleConverter x:Key="BoolToFlipScaleConverter"/>

        <!-- Shared style for resize handle thumbs (4 corners) — larger hit area for usability -->
        <Style x:Key="ResizeHandleStyle" TargetType="Thumb"
               xmlns:sys="clr-namespace:System;assembly=mscorlib">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Grid Background="Transparent">
                            <Border Width="14" Height="14" Background="White" BorderBrush="#333333"
                                    BorderThickness="1" CornerRadius="2"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Horizontal-only resize handle (middle left/right for text) -->
        <Style x:Key="HorizontalResizeHandleStyle" TargetType="Thumb">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Grid Background="Transparent">
                            <Border Width="10" Height="20" Background="White" BorderBrush="#333333"
                                    BorderThickness="1" CornerRadius="2"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Edge resize handle (middle top/bottom) -->
        <Style x:Key="VerticalResizeHandleStyle" TargetType="Thumb">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Grid Background="Transparent">
                            <Border Width="20" Height="10" Background="White" BorderBrush="#333333"
                                    BorderThickness="1" CornerRadius="2"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Rotation handle: circular, positioned above element -->
        <Style x:Key="RotationHandleStyle" TargetType="Thumb">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Grid Background="Transparent">
                            <Ellipse Width="16" Height="16" Fill="#0E639C" Stroke="White" StrokeThickness="2"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="↻" Foreground="White" FontSize="10" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Margin="0,-1,0,0"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Template for generic elements — shows Name -->
        <DataTemplate x:Key="DefaultElementTemplate">
            <Grid Width="{Binding Width}" Height="{Binding Height}" MouseDown="OnCanvasElementMouseDown"
                  RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="{Binding FlipH, Converter={StaticResource BoolToFlipScaleConverter}}"
                                        ScaleY="{Binding FlipV, Converter={StaticResource BoolToFlipScaleConverter}}"/>
                        <RotateTransform Angle="{Binding Rotation}"/>
                    </TransformGroup>
                </Grid.RenderTransform>
                <Border Background="#333333"
                        BorderBrush="{Binding IsSelected, Converter={StaticResource BoolToColorConverter}}"
                        BorderThickness="2">
                    <TextBlock Text="{Binding Name}" Foreground="White"
                               VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="12"/>
                </Border>
                <!-- Rotation handle -->
                <Thumb Tag="Rotate" Style="{StaticResource RotationHandleStyle}"
                       HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-40,0,0"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnRotationHandleDrag" DragCompleted="OnRotationHandleCompleted"/>
                <!-- Rotation connector line -->
                <Line X1="0" Y1="0" X2="0" Y2="16" Stroke="#0E639C" StrokeThickness="2"
                      HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-16,0,0"
                      Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                      IsHitTestVisible="False"/>
                <!-- Corner resize handles -->
                <Thumb Tag="TopLeft" Style="{StaticResource ResizeHandleStyle}" Cursor="SizeNWSE"
                       HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-12,-12,0,0"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnResizeHandleDrag" DragCompleted="OnResizeHandleCompleted"/>
                <Thumb Tag="TopRight" Style="{StaticResource ResizeHandleStyle}" Cursor="SizeNESW"
                       HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-12,-12,0"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnResizeHandleDrag" DragCompleted="OnResizeHandleCompleted"/>
                <Thumb Tag="BottomLeft" Style="{StaticResource ResizeHandleStyle}" Cursor="SizeNESW"
                       HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-12,0,0,-12"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnResizeHandleDrag" DragCompleted="OnResizeHandleCompleted"/>
                <Thumb Tag="BottomRight" Style="{StaticResource ResizeHandleStyle}" Cursor="SizeNWSE"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-12,-12"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnResizeHandleDrag" DragCompleted="OnResizeHandleCompleted"/>
                <!-- Edge resize handles -->
                <Thumb Tag="MiddleTop" Style="{StaticResource VerticalResizeHandleStyle}" Cursor="SizeNS"
                       HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-10,0,0"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnResizeHandleDrag" DragCompleted="OnResizeHandleCompleted"/>
                <Thumb Tag="MiddleBottom" Style="{StaticResource VerticalResizeHandleStyle}" Cursor="SizeNS"
                       HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-10"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnResizeHandleDrag" DragCompleted="OnResizeHandleCompleted"/>
                <Thumb Tag="MiddleLeft" Style="{StaticResource HorizontalResizeHandleStyle}" Cursor="SizeWE"
                       HorizontalAlignment="Left" VerticalAlignment="Center" Margin="-10,0,0,0"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnResizeHandleDrag" DragCompleted="OnResizeHandleCompleted"/>
                <Thumb Tag="MiddleRight" Style="{StaticResource HorizontalResizeHandleStyle}" Cursor="SizeWE"
                       HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,-10,0"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnResizeHandleDrag" DragCompleted="OnResizeHandleCompleted"/>
            </Grid>
        </DataTemplate>

        <!-- ImageElement: displays actual image file -->
        <DataTemplate x:Key="ImageElementTemplate">
            <Grid Width="{Binding Width}" Height="{Binding Height}" MouseDown="OnCanvasElementMouseDown"
                  RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="{Binding FlipH, Converter={StaticResource BoolToFlipScaleConverter}}"
                                        ScaleY="{Binding FlipV, Converter={StaticResource BoolToFlipScaleConverter}}"/>
                        <RotateTransform Angle="{Binding Rotation}"/>
                    </TransformGroup>
                </Grid.RenderTransform>
                <Border Background="Transparent"
                        BorderBrush="{Binding IsSelected, Converter={StaticResource BoolToColorConverter}}"
                        BorderThickness="2"
                        ClipToBounds="True">
                    <Grid ClipToBounds="True">
                        <Image Source="{Binding FilePath, Converter={StaticResource FilePathToImageConverter}}"
                               Stretch="{Binding ScaleMode, Converter={StaticResource ScaleModeConverter}}"
                               Opacity="{Binding Opacity}"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               RenderTransformOrigin="0.5,0.5">
                            <Image.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="{Binding MotionScaleX}" ScaleY="{Binding MotionScaleY}"/>
                                    <TranslateTransform X="{Binding MotionTranslateX}" Y="{Binding MotionTranslateY}"/>
                                </TransformGroup>
                            </Image.RenderTransform>
                        </Image>
                        <!-- Color overlay tint (darken/tint effect) -->
                        <Rectangle Fill="{Binding OverlayColorHex, Converter={StaticResource HexToBrushConverter}}"
                                   Opacity="{Binding OverlayOpacity}"
                                   IsHitTestVisible="False"/>
                        <!-- Fallback label when no image loaded -->
                        <TextBlock Text="{Binding Name}" Foreground="#888888" FontSize="11"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                   Visibility="{Binding FilePath, Converter={StaticResource NullToVisibilityConverter}}"/>
                    </Grid>
                </Border>
                <!-- Rotation handle -->
                <Thumb Tag="Rotate" Style="{StaticResource RotationHandleStyle}"
                       HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-40,0,0"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnRotationHandleDrag" DragCompleted="OnRotationHandleCompleted"/>
                <Line X1="0" Y1="0" X2="0" Y2="16" Stroke="#0E639C" StrokeThickness="2"
                      HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-16,0,0"
                      Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                      IsHitTestVisible="False"/>
                <!-- Corner resize handles -->
                <Thumb Tag="TopLeft" Style="{StaticResource ResizeHandleStyle}" Cursor="SizeNWSE"
                       HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-12,-12,0,0"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnResizeHandleDrag" DragCompleted="OnResizeHandleCompleted"/>
                <Thumb Tag="TopRight" Style="{StaticResource ResizeHandleStyle}" Cursor="SizeNESW"
                       HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-12,-12,0"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnResizeHandleDrag" DragCompleted="OnResizeHandleCompleted"/>
                <Thumb Tag="BottomLeft" Style="{StaticResource ResizeHandleStyle}" Cursor="SizeNESW"
                       HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-12,0,0,-12"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnResizeHandleDrag" DragCompleted="OnResizeHandleCompleted"/>
                <Thumb Tag="BottomRight" Style="{StaticResource ResizeHandleStyle}" Cursor="SizeNWSE"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-12,-12"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnResizeHandleDrag" DragCompleted="OnResizeHandleCompleted"/>
                <!-- Edge resize handles -->
                <Thumb Tag="MiddleTop" Style="{StaticResource VerticalResizeHandleStyle}" Cursor="SizeNS"
                       HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-10,0,0"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnResizeHandleDrag" DragCompleted="OnResizeHandleCompleted"/>
                <Thumb Tag="MiddleBottom" Style="{StaticResource VerticalResizeHandleStyle}" Cursor="SizeNS"
                       HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-10"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnResizeHandleDrag" DragCompleted="OnResizeHandleCompleted"/>
                <Thumb Tag="MiddleLeft" Style="{StaticResource HorizontalResizeHandleStyle}" Cursor="SizeWE"
                       HorizontalAlignment="Left" VerticalAlignment="Center" Margin="-10,0,0,0"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnResizeHandleDrag" DragCompleted="OnResizeHandleCompleted"/>
                <Thumb Tag="MiddleRight" Style="{StaticResource HorizontalResizeHandleStyle}" Cursor="SizeWE"
                       HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,-10,0"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnResizeHandleDrag" DragCompleted="OnResizeHandleCompleted"/>
            </Grid>
        </DataTemplate>

        <!-- LogoElement: displays logo image file -->
        <DataTemplate x:Key="LogoElementTemplate">
            <Grid Width="{Binding Width}" Height="{Binding Height}" MouseDown="OnCanvasElementMouseDown"
                  RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="{Binding FlipH, Converter={StaticResource BoolToFlipScaleConverter}}"
                                        ScaleY="{Binding FlipV, Converter={StaticResource BoolToFlipScaleConverter}}"/>
                        <RotateTransform Angle="{Binding Rotation}"/>
                    </TransformGroup>
                </Grid.RenderTransform>
                <Border Background="Transparent"
                        BorderBrush="{Binding IsSelected, Converter={StaticResource BoolToColorConverter}}"
                        BorderThickness="2">
                    <Grid>
                        <Image Source="{Binding ImagePath, Converter={StaticResource FilePathToImageConverter}}"
                               Stretch="{Binding ScaleMode, Converter={StaticResource ScaleModeConverter}}"
                               Opacity="{Binding Opacity}"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="{Binding Name}" Foreground="#888888" FontSize="11"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                   Visibility="{Binding ImagePath, Converter={StaticResource NullToVisibilityConverter}}"/>
                    </Grid>
                </Border>
                <!-- Rotation handle -->
                <Thumb Tag="Rotate" Style="{StaticResource RotationHandleStyle}"
                       HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-40,0,0"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnRotationHandleDrag" DragCompleted="OnRotationHandleCompleted"/>
                <Line X1="0" Y1="0" X2="0" Y2="16" Stroke="#0E639C" StrokeThickness="2"
                      HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-16,0,0"
                      Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                      IsHitTestVisible="False"/>
                <Thumb Tag="TopLeft" Style="{StaticResource ResizeHandleStyle}" Cursor="SizeNWSE"
                       HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-12,-12,0,0"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnResizeHandleDrag" DragCompleted="OnResizeHandleCompleted"/>
                <Thumb Tag="TopRight" Style="{StaticResource ResizeHandleStyle}" Cursor="SizeNESW"
                       HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-12,-12,0"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnResizeHandleDrag" DragCompleted="OnResizeHandleCompleted"/>
                <Thumb Tag="BottomLeft" Style="{StaticResource ResizeHandleStyle}" Cursor="SizeNESW"
                       HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-12,0,0,-12"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnResizeHandleDrag" DragCompleted="OnResizeHandleCompleted"/>
                <Thumb Tag="BottomRight" Style="{StaticResource ResizeHandleStyle}" Cursor="SizeNWSE"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-12,-12"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnResizeHandleDrag" DragCompleted="OnResizeHandleCompleted"/>
                <Thumb Tag="MiddleTop" Style="{StaticResource VerticalResizeHandleStyle}" Cursor="SizeNS"
                       HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-10,0,0"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnResizeHandleDrag" DragCompleted="OnResizeHandleCompleted"/>
                <Thumb Tag="MiddleBottom" Style="{StaticResource VerticalResizeHandleStyle}" Cursor="SizeNS"
                       HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-10"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnResizeHandleDrag" DragCompleted="OnResizeHandleCompleted"/>
                <Thumb Tag="MiddleLeft" Style="{StaticResource HorizontalResizeHandleStyle}" Cursor="SizeWE"
                       HorizontalAlignment="Left" VerticalAlignment="Center" Margin="-10,0,0,0"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnResizeHandleDrag" DragCompleted="OnResizeHandleCompleted"/>
                <Thumb Tag="MiddleRight" Style="{StaticResource HorizontalResizeHandleStyle}" Cursor="SizeWE"
                       HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,-10,0"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnResizeHandleDrag" DragCompleted="OnResizeHandleCompleted"/>
            </Grid>
        </DataTemplate>

        <!-- TextOverlayElement: unified text element with shadow/outline/background support -->
        <DataTemplate x:Key="TextOverlayElementTemplate">
            <Grid Width="{Binding Width}" MouseDown="OnCanvasElementMouseDown"
                  SizeChanged="OnTextElementGridSizeChanged"
                  RenderTransformOrigin="0.5,0.5">
                <!-- Height adapts to SizingMode: NaN (auto) = AutoHeight, fixed value = Fixed -->
                <Grid.Height>
                    <MultiBinding Converter="{StaticResource TextElementHeightConverter}">
                        <Binding Path="SizingMode"/>
                        <Binding Path="Height"/>
                    </MultiBinding>
                </Grid.Height>
                <Grid.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="{Binding FlipH, Converter={StaticResource BoolToFlipScaleConverter}}"
                                        ScaleY="{Binding FlipV, Converter={StaticResource BoolToFlipScaleConverter}}"/>
                        <RotateTransform Angle="{Binding Rotation}"/>
                    </TransformGroup>
                </Grid.RenderTransform>
                <!-- Background layer (only rendered when HasBackground=true) -->
                <Border Background="{Binding BackgroundColorHex, Converter={StaticResource HexToBrushConverter}}"
                        Opacity="{Binding BackgroundOpacity}"
                        CornerRadius="4"
                        Visibility="{Binding HasBackground, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <!-- Text border: clips content in Fixed mode -->
                <Border BorderBrush="{Binding IsSelected, Converter={StaticResource BoolToColorConverter}}"
                        BorderThickness="2"
                        Background="Transparent">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="ClipToBounds" Value="False"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SizingMode}" Value="Fixed">
                                    <Setter Property="ClipToBounds" Value="True"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <TextBlock Text="{Binding Content}"
                                   Tag="InlineDisplay"
                                   Foreground="{Binding ColorHex, Converter={StaticResource HexToBrushConverter}}"
                                   FontFamily="{Binding FontFamily}"
                                   FontSize="{Binding FontSize}"
                                   FontWeight="{Binding IsBold, Converter={StaticResource BoolToFontWeightConverter}}"
                                   FontStyle="{Binding IsItalic, Converter={StaticResource BoolToFontStyleConverter}}"
                                   TextDecorations="{Binding IsUnderline, Converter={StaticResource BoolToUnderlineConverter}}"
                                   TextAlignment="{Binding Alignment, Converter={StaticResource AlignmentToTextAlignmentConverter}}"
                                   VerticalAlignment="Top"
                                   HorizontalAlignment="{Binding Alignment, Converter={StaticResource TextAlignmentConverter}}"
                                   TextWrapping="Wrap"
                                   Padding="8,4"
                                   MouseDown="OnInlineTextDisplayMouseDown"
                                   SizeChanged="OnTextBlockSizeChanged">
                            <TextBlock.LineHeight>
                                <MultiBinding Converter="{StaticResource FontLineHeightConverter}">
                                    <Binding Path="FontSize"/>
                                    <Binding Path="LineHeight"/>
                                </MultiBinding>
                            </TextBlock.LineHeight>
                        </TextBlock>

                        <TextBox Tag="InlineEditor"
                                 Visibility="Collapsed"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Hidden"
                                 HorizontalScrollBarVisibility="Disabled"
                                 BorderThickness="0"
                                 Background="#CC151515"
                                 Foreground="{Binding ColorHex, Converter={StaticResource HexToBrushConverter}}"
                                 FontFamily="{Binding FontFamily}"
                                 FontSize="{Binding FontSize}"
                                 FontWeight="{Binding IsBold, Converter={StaticResource BoolToFontWeightConverter}}"
                                 FontStyle="{Binding IsItalic, Converter={StaticResource BoolToFontStyleConverter}}"
                                 TextAlignment="{Binding Alignment, Converter={StaticResource AlignmentToTextAlignmentConverter}}"
                                 VerticalContentAlignment="Top"
                                 Padding="8,4"
                                 PreviewMouseDown="OnInlineTextEditorPreviewMouseDown"
                                 KeyDown="OnInlineTextEditorKeyDown"
                                 LostKeyboardFocus="OnInlineTextEditorLostKeyboardFocus"/>
                    </Grid>
                </Border>
                <!-- Overflow indicator: visible in Fixed mode when content is taller than the box -->
                <Border Background="#CC550000" CornerRadius="3" Padding="3,1"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,4,4"
                        IsHitTestVisible="False"
                        Visibility="{Binding IsOverflowing, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="✂" Foreground="#FFAAAA" FontSize="10" FontFamily="Segoe UI Symbol"/>
                </Border>
                <!-- Rotation handle -->
                <Thumb Tag="Rotate" Style="{StaticResource RotationHandleStyle}"
                       HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-40,0,0"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnRotationHandleDrag" DragCompleted="OnRotationHandleCompleted"/>
                <Line X1="0" Y1="0" X2="0" Y2="16" Stroke="#0E639C" StrokeThickness="2"
                      HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-16,0,0"
                      Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                      IsHitTestVisible="False"/>
                <Thumb Tag="TopLeft" Style="{StaticResource ResizeHandleStyle}" Cursor="SizeNWSE"
                       HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-12,-12,0,0"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnResizeHandleDrag" DragCompleted="OnResizeHandleCompleted"/>
                <Thumb Tag="TopRight" Style="{StaticResource ResizeHandleStyle}" Cursor="SizeNESW"
                       HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-12,-12,0"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnResizeHandleDrag" DragCompleted="OnResizeHandleCompleted"/>
                <Thumb Tag="BottomLeft" Style="{StaticResource ResizeHandleStyle}" Cursor="SizeNESW"
                       HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-12,0,0,-12"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnResizeHandleDrag" DragCompleted="OnResizeHandleCompleted"/>
                <Thumb Tag="BottomRight" Style="{StaticResource ResizeHandleStyle}" Cursor="SizeNWSE"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-12,-12"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnResizeHandleDrag" DragCompleted="OnResizeHandleCompleted"/>
                <Thumb Tag="MiddleLeft" Style="{StaticResource HorizontalResizeHandleStyle}" Cursor="SizeWE"
                       HorizontalAlignment="Left" VerticalAlignment="Center" Margin="-10,0,0,0"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnResizeHandleDrag" DragCompleted="OnResizeHandleCompleted"/>
                <Thumb Tag="MiddleRight" Style="{StaticResource HorizontalResizeHandleStyle}" Cursor="SizeWE"
                       HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,-10,0"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnResizeHandleDrag" DragCompleted="OnResizeHandleCompleted"/>
            </Grid>
        </DataTemplate>

        <!-- Template for VisualizerElement: live spectrum bitmap + 4 corner handles -->
        <DataTemplate x:Key="VisualizerElementTemplate">
            <Grid Width="{Binding Width}" Height="{Binding Height}" MouseDown="OnCanvasElementMouseDown"
                  RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="{Binding FlipH, Converter={StaticResource BoolToFlipScaleConverter}}"
                                        ScaleY="{Binding FlipV, Converter={StaticResource BoolToFlipScaleConverter}}"/>
                        <RotateTransform Angle="{Binding Rotation}"/>
                    </TransformGroup>
                </Grid.RenderTransform>
                <Border Background="Transparent"
                        BorderBrush="{Binding IsSelected, Converter={StaticResource BoolToColorConverter}}"
                        BorderThickness="2">
                    <Image Source="{Binding DataContext.VisualizerBitmapSource, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                           Stretch="Fill"
                           RenderOptions.BitmapScalingMode="LowQuality"/>
                </Border>
                <!-- Rotation handle -->
                <Thumb Tag="Rotate" Style="{StaticResource RotationHandleStyle}"
                       HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-40,0,0"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnRotationHandleDrag" DragCompleted="OnRotationHandleCompleted"/>
                <Line X1="0" Y1="0" X2="0" Y2="16" Stroke="#0E639C" StrokeThickness="2"
                      HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-16,0,0"
                      Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                      IsHitTestVisible="False"/>
                <Thumb Tag="TopLeft" Style="{StaticResource ResizeHandleStyle}" Cursor="SizeNWSE"
                       HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-12,-12,0,0"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnResizeHandleDrag" DragCompleted="OnResizeHandleCompleted"/>
                <Thumb Tag="TopRight" Style="{StaticResource ResizeHandleStyle}" Cursor="SizeNESW"
                       HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-12,-12,0"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnResizeHandleDrag" DragCompleted="OnResizeHandleCompleted"/>
                <Thumb Tag="BottomLeft" Style="{StaticResource ResizeHandleStyle}" Cursor="SizeNESW"
                       HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-12,0,0,-12"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnResizeHandleDrag" DragCompleted="OnResizeHandleCompleted"/>
                <Thumb Tag="BottomRight" Style="{StaticResource ResizeHandleStyle}" Cursor="SizeNWSE"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-12,-12"
                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                       DragDelta="OnResizeHandleDrag" DragCompleted="OnResizeHandleCompleted"/>
            </Grid>
        </DataTemplate>

        <views:ElementTemplateSelector x:Key="ElementTemplateSelector"
                                       DefaultTemplate="{StaticResource DefaultElementTemplate}"
                                       VisualizerTemplate="{StaticResource VisualizerElementTemplate}"
                                       TextOverlayTemplate="{StaticResource TextOverlayElementTemplate}"
                                       ImageTemplate="{StaticResource ImageElementTemplate}"
                                       LogoTemplate="{StaticResource LogoElementTemplate}"/>
        <!-- Compact outline ratio button for status bar -->
        <Style x:Key="RatioButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#999999"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2A2D2E"/>
                                <Setter Property="Foreground" Value="#CCCCCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Play/Pause Button Style - ensures icon is always visible -->
        <Style x:Key="PlayPauseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="2">
                            <TextBlock Text="{TemplateBinding Content}"
                                      FontSize="12"
                                      Foreground="White"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0E639C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Converters for play/pause toggle -->
        <conv:PlayStateToIconConverter x:Key="PlayStateToIconConverter"/>
        <conv:PlayStateToTooltipConverter x:Key="PlayStateToTooltipConverter"/>

        <!-- Loop Button Style: highlights when loop is active -->
        <Style x:Key="LoopButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ToolTip" Value="Loop playback"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="2">
                            <TextBlock Text="⟲"
                                      FontSize="13"
                                      x:Name="icon"
                                      Foreground="#888888"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#404040"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- Highlight icon in accent color when loop is active -->
                <DataTrigger Binding="{Binding IsLoopPlayback}" Value="True">
                    <Setter Property="Background" Value="#1a3a55"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Canvas Area: Viewbox scale-to-fit (CapCut style — no scrollbars, preview fits in frame) -->
        <Border Grid.Row="0" Background="#252526">
            <Grid>
                <!-- Viewbox for preview -->
                <Viewbox Stretch="Uniform" StretchDirection="Both">
                    <Grid Width="{Binding CanvasWidth}" Height="{Binding CanvasHeight}">
                        <Border Background="#1e1e1e" />

                        <TextBlock Text="No active visual segment"
                                   Foreground="#cccccc"
                                   FontStyle="Italic"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Background="#33000000"
                                   Padding="12,6"
                                   IsHitTestVisible="False"
                                   Visibility="{Binding IsVisualPlaceholderVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <!-- Unified compositing canvas: ALL visual content (video, images, visualizer, text)
                             shares a single z-order space via Canvas.ZIndex computed from Track.Order.
                             Video MediaElement participates in the same z-order as ImageElements etc.
                             This matches commercial editors (CapCut, Premiere, DaVinci) where moving
                             a track up/down directly changes its visual stacking in the composite. -->
                        <Canvas x:Name="MainCanvas"
                                Background="Transparent"
                                Width="{Binding CanvasWidth}"
                                Height="{Binding CanvasHeight}"
                                AllowDrop="True"
                                DragOver="MainCanvas_DragOver"
                                Drop="MainCanvas_Drop"
                                MouseDown="OnCanvasMouseDown">
                            <!-- Video preview: participates in unified z-order -->
                            <Border Canvas.Left="{Binding ActiveVisualX}"
                                    Canvas.Top="{Binding ActiveVisualY}"
                                    Canvas.ZIndex="{Binding PrimaryVideoZIndex}"
                                    Width="{Binding ActiveVisualWidth}"
                                    Height="{Binding ActiveVisualHeight}"
                                    ClipToBounds="True"
                                    IsHitTestVisible="False"
                                    Visibility="{Binding IsVideoMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                <MediaElement x:Name="VideoPreview"
                                              LoadedBehavior="Manual"
                                              ScrubbingEnabled="True"
                                              IsMuted="True"
                                              Stretch="UniformToFill"
                                              Width="{Binding ActiveVisualWidth}"
                                              Height="{Binding ActiveVisualHeight}"
                                              IsHitTestVisible="False"
                                              RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>

                            <!-- All other elements: images, visualizers, text, logos -->
                            <ItemsControl ItemsSource="{Binding Elements}"
                                         ItemTemplateSelector="{StaticResource ElementTemplateSelector}">
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                        <Setter Property="Canvas.ZIndex" Value="{Binding ZIndex}"/>
                                        <Setter Property="Visibility" Value="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>

                            <!-- Snap guide lines (managed from code-behind) -->
                            <Line x:Name="SnapGuideH" Stroke="#FF00AAFF" StrokeThickness="1.5"
                                  StrokeDashArray="4,3" IsHitTestVisible="False" Visibility="Collapsed"
                                  Canvas.ZIndex="9999"/>
                            <Line x:Name="SnapGuideV" Stroke="#FF00AAFF" StrokeThickness="1.5"
                                  StrokeDashArray="4,3" IsHitTestVisible="False" Visibility="Collapsed"
                                  Canvas.ZIndex="9999"/>
                        </Canvas>
                    </Grid>
                </Viewbox>
            </Grid>
        </Border>

        <!-- Status Bar: Playback controls + Time display + Status message + Ratio selector -->
        <Border Grid.Row="1" Background="#252526" Padding="8,0" Height="40">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Col 0: Spacer (left) -->

                <!-- Col 1: Play/Pause Toggle Button (Icon only) -->
                <Button Grid.Column="1" 
                       Command="{Binding TogglePlayPauseCommand}"
                       Content="{Binding IsPlaying, Converter={StaticResource PlayStateToIconConverter}}"
                       Style="{StaticResource PlayPauseButtonStyle}"
                       ToolTip="{Binding IsPlaying, Converter={StaticResource PlayStateToTooltipConverter}}"/>

                <!-- Col 2: Time display (compact) -->
                <TextBlock Grid.Column="2" Margin="6,0,0,0" VerticalAlignment="Center"
                          Foreground="#FFFFFF" FontSize="9" FontFamily="Courier New">
                    <Run Text="{Binding AudioPlaybackTime, Mode=OneWay, FallbackValue='00:00'}"/>
                    <Run Text="/"/>
                    <Run Text="{Binding AudioDuration, Mode=OneWay, FallbackValue='00:00'}"/>
                </TextBlock>

                <!-- Col 3: Loop toggle button -->
                <Button Grid.Column="3" Margin="6,0,0,0"
                        Command="{Binding ToggleLoopPlaybackCommand}"
                        Style="{StaticResource LoopButtonStyle}"/>

                <!-- Col 4: Spacer (right) -->

                <!-- Col 5: Ratio button (right align) -->
                <Button x:Name="RatioButton" Grid.Column="5" Content="{Binding SelectedAspectRatio}" 
                       Style="{StaticResource RatioButtonStyle}"
                       Foreground="#999999" VerticalAlignment="Center" Click="RatioButton_Click">
                    <Button.ContextMenu>
                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                            <MenuItem Header="9:16" Command="{Binding SetAspectRatioCommand}" CommandParameter="9:16"/>
                            <MenuItem Header="16:9" Command="{Binding SetAspectRatioCommand}" CommandParameter="16:9"/>
                            <MenuItem Header="1:1" Command="{Binding SetAspectRatioCommand}" CommandParameter="1:1"/>
                            <MenuItem Header="4:5" Command="{Binding SetAspectRatioCommand}" CommandParameter="4:5"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
