<Window x:Class="PodcastVideoEditor.Ui.Views.CapCutExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Xuất sang CapCut" Width="520" Height="420"
        WindowStyle="ToolWindow" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource PrimaryBackgroundBrush}"
        Foreground="{StaticResource PrimaryForegroundBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- Action button style matching RenderDialog -->
        <Style x:Key="CapCutActionBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBlueBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CancelBtn" TargetType="Button">
            <Setter Property="Background" Value="#44ffffff"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryForegroundBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="📦 Xuất dự án sang CapCut" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>

        <!-- Settings -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Tên draft:" VerticalAlignment="Center" Margin="0,0,10,6"/>
            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding DraftName, UpdateSourceTrigger=PropertyChanged}"
                     Background="#33ffffff" Foreground="{StaticResource PrimaryForegroundBrush}"
                     Padding="6,4" Margin="0,0,0,6"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Kích thước:" VerticalAlignment="Center" Margin="0,0,10,6"/>
            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,6">
                <TextBox Width="60" Text="{Binding ExportWidth}" Background="#33ffffff"
                         Foreground="{StaticResource PrimaryForegroundBrush}" Padding="6,4"/>
                <TextBlock Text=" × " VerticalAlignment="Center"/>
                <TextBox Width="60" Text="{Binding ExportHeight}" Background="#33ffffff"
                         Foreground="{StaticResource PrimaryForegroundBrush}" Padding="6,4"/>
            </StackPanel>

            <CheckBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                      IsChecked="{Binding RenderVisualizerAsVideo}"
                      Content="Render visualizer thành video (thêm vào CapCut dạng video track)"
                      Foreground="{StaticResource PrimaryForegroundBrush}" Margin="0,4,0,0"/>
        </Grid>

        <!-- Progress -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <ProgressBar Height="8" Minimum="0" Maximum="100" Value="{Binding ExportProgress}"
                         Background="#33ffffff" Foreground="{StaticResource AccentBlueBrush}"/>
        </StackPanel>

        <!-- Status -->
        <Border Grid.Row="3" Background="#22ffffff" CornerRadius="4" Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" FontSize="12"/>
            </ScrollViewer>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="📂 Mở thư mục Draft" Style="{StaticResource CancelBtn}"
                    Command="{Binding OpenDraftFolderCommand}" Margin="0,0,8,0"
                    Visibility="{Binding ExportCompleted, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <Button Content="Huỷ" Style="{StaticResource CancelBtn}"
                    Command="{Binding CancelExportCommand}" Margin="0,0,8,0"
                    Visibility="{Binding IsExporting, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <Button Content="🚀 Xuất sang CapCut" Style="{StaticResource CapCutActionBtn}"
                    Command="{Binding ExportToCapCutCommand}"/>
        </StackPanel>
    </Grid>
</Window>
