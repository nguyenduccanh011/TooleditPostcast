<UserControl x:Class="PodcastVideoEditor.Ui.Views.TimelineView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PodcastVideoEditor.Ui.Views"
             xmlns:conv="clr-namespace:PodcastVideoEditor.Ui.Converters"
             xmlns:controls="clr-namespace:PodcastVideoEditor.Ui.Controls"
             Background="#1e1e1e"
             Foreground="#e0e0e0"
             Focusable="True">
    <UserControl.InputBindings>
        <KeyBinding Key="Delete" Command="{Binding DeleteSelectedSegmentCommand}"/>
        <KeyBinding Modifiers="Ctrl" Key="A" Command="{Binding SelectAllSegmentsCommand}"/>
        <!-- Space bar for playback control is now handled by CanvasView to avoid conflicts -->
    </UserControl.InputBindings>

    <UserControl.Resources>
        <conv:DurationDisplayConverter x:Key="DurationDisplayConverter"/>
        <conv:PixelsPerSecondConverter x:Key="PixelsPerSecondConverter"/>
        <conv:TimeValueConverter x:Key="TimeValueConverter"/>
        <conv:TrackHeightConverter x:Key="TrackHeightConverter"/>
        <conv:TrackTypeToIconConverter x:Key="TrackTypeToIconConverter"/>
        <conv:SegmentNoImagePlaceholderVisibilityConverter x:Key="SegmentNoImagePlaceholderVisibilityConverter"/>
        <conv:SegmentThumbnailSourceConverter x:Key="SegmentThumbnailSourceConverter"/>
        <conv:SegmentThumbnailBrushConverter x:Key="SegmentThumbnailBrushConverter"/>
        <conv:SegmentVideoPlaceholderVisibilityConverter x:Key="SegmentVideoPlaceholderVisibilityConverter"/>
        <conv:AssetIdToSingleThumbVisibilityConverter x:Key="AssetIdToSingleThumbVisibilityConverter"/>
        <conv:SegmentStripTimesConverter x:Key="SegmentStripTimesConverter"/>
        <conv:VideoFrameAtTimeConverter x:Key="VideoFrameAtTimeConverter"/>
        <conv:KindToVisibilityConverter x:Key="KindToVisibilityConverter"/>
        <conv:KindToVisibilityInverseConverter x:Key="KindToVisibilityInverseConverter"/>
        <conv:SecondsToTimecodeConverter x:Key="SecondsToTimecodeConverter"/>
        <!-- Thumb template tối giản: bỏ template mặc định gây khối trắng -->
        <Style x:Key="TransparentThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#2d3a4a"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ResizeThumbStyle" TargetType="Thumb" BasedOn="{StaticResource TransparentThumbStyle}"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Status Bar: MinHeight so buttons and text are not clipped -->
        <Border Grid.Row="0" Background="#2d2d2d" Padding="10,8" MinHeight="44">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Timeline:" Margin="0,0,10,0" VerticalAlignment="Center" FontWeight="Bold"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#a0a0a0" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <TextBlock Text="Playhead:" Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding PlayheadPosition, Converter={StaticResource SecondsToTimecodeConverter}}" 
                               Foreground="#4fc3f7" VerticalAlignment="Center" FontFamily="Courier New" FontWeight="Bold"/>
                    <TextBlock Text=" / " VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalDuration, Converter={StaticResource SecondsToTimecodeConverter}}" VerticalAlignment="Center" FontFamily="Courier New"/>
                    <TextBlock Text=" (" Margin="5,0,0,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding PixelsPerSecond, Converter={StaticResource PixelsPerSecondConverter}}" 
                               Foreground="#81c784" VerticalAlignment="Center" FontFamily="Courier New"/>
                    <TextBlock Text=")" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <!-- Zoom controls -->
                    <Button Content="−" x:Name="ZoomOutButton" ToolTip="Zoom Out (Ctrl+ScrollDown)"
                            Background="#37474f" Foreground="White" Padding="8,8" MinHeight="32" MinWidth="32" Margin="0,0,2,0"
                            FontSize="14" FontWeight="Bold" VerticalContentAlignment="Center"
                            Click="ZoomOutButton_Click"/>
                    <Button Content="1x" x:Name="ZoomResetButton" ToolTip="Reset Zoom (fit all)"
                            Background="#37474f" Foreground="#81c784" Padding="8,8" MinHeight="32" Margin="0,0,2,0"
                            FontFamily="Courier New" FontWeight="Bold" VerticalContentAlignment="Center"
                            Click="ZoomResetButton_Click"/>
                    <Button Content="+" x:Name="ZoomInButton" ToolTip="Zoom In (Ctrl+ScrollUp)"
                            Background="#37474f" Foreground="White" Padding="8,8" MinHeight="32" MinWidth="32" Margin="0,0,16,0"
                            FontSize="14" FontWeight="Bold" VerticalContentAlignment="Center"
                            Click="ZoomInButton_Click"/>
                    <!-- Segment controls only - Playback controls moved to CanvasView -->
                    <Button Content="Add" Command="{Binding AddSegmentAtPlayheadCommand}"
                            Background="#43a047" Foreground="White" Padding="12,8" MinHeight="32" Margin="0,0,6,0" VerticalContentAlignment="Center"/>
                    <Button Content="Duplicate" Command="{Binding DuplicateSelectedSegmentCommand}"
                            Background="#1e88e5" Foreground="White" Padding="12,8" MinHeight="32" Margin="0,0,6,0" VerticalContentAlignment="Center"/>
                    <Button Content="Delete" Command="{Binding DeleteSelectedSegmentCommand}"
                            ToolTip="Delete selected (or all Ctrl+A selected) segments"
                            Background="#e53935" Foreground="White" Padding="12,8" MinHeight="32" Margin="0,0,6,0" VerticalContentAlignment="Center"/>
                    <Button Content="Sel All" Command="{Binding SelectAllSegmentsCommand}"
                            ToolTip="Select all segments (Ctrl+A)"
                            Background="#6d4c41" Foreground="White" Padding="12,8" MinHeight="32" Margin="0,0,6,0" VerticalContentAlignment="Center"/>
                    <Button Content="Clear All" Command="{Binding ClearAllSegmentsCommand}"
                            Background="#6d4c41" Foreground="White" Padding="12,8" MinHeight="32" VerticalContentAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Timeline Content: Fixed headers + scrollable content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" 
                     HorizontalScrollBarVisibility="Disabled"
                     x:Name="OuterScroller"
                     Background="#252525">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="56"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Col 0: Fixed Track Headers (no horizontal scroll) - MUST use same structure as Col 1 -->
                <Grid Grid.Column="0" Background="#252525">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="48"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: Ruler header -->
                    <Border Grid.Row="0" Height="40" Background="#1a1a1a" BorderBrush="#37474f" BorderThickness="0,0,1,0">
                        <TextBlock Text="Timeline" VerticalAlignment="Center" Margin="8,0"
                                   Foreground="#81c784" FontWeight="SemiBold" FontSize="11"/>
                    </Border>

                    <!-- Row 1: Track headers (generated from Tracks collection) -->
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Tracks}"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.CanContentScroll="True">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Height="{Binding TrackType, Converter={StaticResource TrackHeightConverter}}"
                                    Background="#3d3d3d" BorderBrush="#37474f" BorderThickness="0,0,1,0">
                                    <!-- Single-row: [type icon] [lock] [eye] all on one line -->
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                                VerticalAlignment="Center" Margin="2,0">
                                        <!-- Track type icon (T / 🖼 / ♪) — tooltip shows full name -->
                                        <TextBlock Text="{Binding TrackType, Converter={StaticResource TrackTypeToIconConverter}}"
                                                   ToolTip="{Binding Name}"
                                                   FontFamily="Segoe UI Emoji" FontSize="11" FontWeight="Bold"
                                                   Foreground="#81c784"
                                                   VerticalAlignment="Center" Margin="0,0,3,0"
                                                   Width="14" TextAlignment="Center"/>
                                        <!-- Lock toggle -->
                                        <Button x:Name="LockBtn" Width="14" Height="14" Margin="0,0,2,0"
                                                ToolTip="Lock/Unlock track"
                                                Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand"
                                                Click="TrackLockButton_Click" Tag="{Binding}">
                                            <TextBlock FontFamily="Segoe UI Emoji" FontSize="9" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="🔓"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                                <Setter Property="Text" Value="🔒"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Button>
                                        <!-- Visibility toggle -->
                                        <Button x:Name="VisBtn" Width="14" Height="14"
                                                ToolTip="Show/Hide track"
                                                Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand"
                                                Click="TrackVisibilityButton_Click" Tag="{Binding}">
                                            <TextBlock FontFamily="Segoe UI Emoji" FontSize="9" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="👁"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsVisible}" Value="False">
                                                                <Setter Property="Text" Value="🚫"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Row 2: Waveform header + Track management -->
                    <StackPanel Grid.Row="2">
                        <Border Height="48" Background="#2a2a2a" BorderBrush="#37474f" BorderThickness="0,1,1,0">
                            <TextBlock Text="Audio" VerticalAlignment="Center" Margin="8,0"
                                       Foreground="#81c784" FontWeight="SemiBold" FontSize="11"/>
                        </Border>
                        <Border Height="26" Background="#2a2a2a" BorderBrush="#37474f" BorderThickness="0,1,1,0">
                            <StackPanel Orientation="Horizontal" Margin="2,0">
                                <Button Content="+" Click="AddTrack_Click" ToolTip="Add track"
                                        Width="20" Height="20" FontSize="12" FontWeight="Bold"
                                        Background="#43a047" Foreground="White" BorderThickness="0"
                                        Cursor="Hand" Padding="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Col 1: Scrollable Content (horizontal scroll only) -->
                <ScrollViewer Grid.Column="1" 
                             HorizontalScrollBarVisibility="Auto" 
                             VerticalScrollBarVisibility="Disabled"
                             x:Name="TimelineScroller"
                             CanContentScroll="True"
                             PanningMode="HorizontalOnly"
                             PanningDeceleration="0.001"
                             PanningRatio="1"
                             CacheMode="BitmapCache">
                    <Grid Width="{Binding TimelineWidth}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="48"/>
                        </Grid.RowDefinitions>

                        <!-- Row 0: Ruler -->
                        <Border Grid.Row="0" Background="#1a1a1a" Height="40"
                                MouseDown="RulerBorder_MouseDown"
                                MouseMove="RulerBorder_MouseMove"
                                MouseUp="RulerBorder_MouseUp"
                                Cursor="Hand"
                                BorderBrush="#37474f" BorderThickness="0">
                            <controls:TimelineRulerControl x:Name="RulerControl"
                                                           HorizontalAlignment="Left"
                                                           Height="40"
                                                           ClipToBounds="True"
                                                           Width="{Binding TimelineWidth}"
                                                           PixelsPerSecond="{Binding PixelsPerSecond}"
                                                           TotalDuration="{Binding TotalDuration}"/>
                        </Border>

                        <!-- Row 1: Track Contents -->
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding Tracks}" x:Name="TracksItemsControl"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                      ScrollViewer.CanContentScroll="True">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel Orientation="Vertical"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                        <Border Height="{Binding TrackType, Converter={StaticResource TrackHeightConverter}}"
                                            Background="#2d2d2d" BorderBrush="#37474f" BorderThickness="0">
                                        <Canvas Background="#2d2d2d" 
                                               ClipToBounds="True"
                                               Width="{Binding DataContext.TimelineWidth, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue=800}"
                                               MouseDown="TimelineCanvas_MouseDown"
                                               MouseMove="TimelineCanvas_MouseMove"
                                               MouseUp="TimelineCanvas_MouseUp"
                                               AllowDrop="True"
                                               DragOver="TrackCanvas_DragOver"
                                               DragLeave="TrackCanvas_DragLeave"
                                               Drop="TrackCanvas_Drop">
                                        <ItemsControl ItemsSource="{Binding Segments}" x:Name="SegmentsItemsControl">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Canvas Background="Transparent" Width="{Binding RelativeSource={RelativeSource AncestorType=Canvas}, Path=Width}"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid x:Name="SegmentRoot"
                                                          Height="{Binding DataContext.TrackType,
                                                                   RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}},
                                                                   Converter={StaticResource TrackHeightConverter},
                                                                   FallbackValue=36}"
                                                          Cursor="Hand">
                                                        <!-- Kind-based color: visual=blue, text=green, audio=teal; multi-select=orange -->
                                                        <Border x:Name="SegmentFill" BorderThickness="0,2,0,0"
                                                                CornerRadius="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#1e2a38"/>
                                                                    <Setter Property="BorderBrush" Value="#1565c0"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Kind}" Value="text">
                                                                            <Setter Property="Background" Value="#1a2a1a"/>
                                                                            <Setter Property="BorderBrush" Value="#43a047"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Kind}" Value="audio">
                                                                            <Setter Property="Background" Value="#1a2a2d"/>
                                                                            <Setter Property="BorderBrush" Value="#00acc1"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsMultiSelected}" Value="True">
                                                                            <Setter Property="Background" Value="#3a3a2a"/>
                                                                            <Setter Property="BorderBrush" Value="#FF9800"/>
                                                                            <Setter Property="BorderThickness" Value="2,2,2,2"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <Grid x:Name="SegmentContentLayer">
                                                                <Thumb x:Name="MoveThumb" Style="{StaticResource TransparentThumbStyle}"
                                                                      Cursor="SizeAll"
                                                                      HorizontalAlignment="Stretch"
                                                                      VerticalAlignment="Stretch"
                                                                      Panel.ZIndex="0"
                                                                      MouseDown="MoveThumb_MouseDown"
                                                                      MouseRightButtonUp="MoveThumb_MouseRightButtonUp"
                                                                      DragStarted="MoveThumb_DragStarted"
                                                                      DragDelta="MoveThumb_DragDelta"
                                                                      DragCompleted="MoveThumb_DragCompleted"/>
                                                                <Grid Panel.ZIndex="1" IsHitTestVisible="False" Margin="2,0">
                                                                    <!-- Single full-width column: preview fills segment; floating label overlaid -->
                                                                    <!-- Visual/Text segments: show thumbnail/video strip -->
                                                                    <Border Grid.Column="0" CornerRadius="3" VerticalAlignment="Stretch" MinWidth="60"
                                                                            Visibility="{Binding Kind, Converter={StaticResource KindToVisibilityInverseConverter}, ConverterParameter=audio}">
                                                                        <Border.Background>
                                                                            <MultiBinding Converter="{StaticResource SegmentThumbnailBrushConverter}">
                                                                                <Binding Path="BackgroundAssetId"/>
                                                                                <Binding Path="DataContext.ProjectViewModel.CurrentProject.Assets" RelativeSource="{RelativeSource AncestorType={x:Type local:TimelineView}}"/>
                                                                            </MultiBinding>
                                                                        </Border.Background>
                                                                        <Grid>
                                                                            <!-- Layer 0: "Video" placeholder text (behind thumbnails so thumbnails draw on top) -->
                                                                            <TextBlock Text="Video" Foreground="#64b5f6" FontSize="9" VerticalAlignment="Center" HorizontalAlignment="Center" Panel.ZIndex="0">
                                                                                <TextBlock.Visibility>
                                                                                    <MultiBinding Converter="{StaticResource SegmentVideoPlaceholderVisibilityConverter}">
                                                                                        <Binding Path="BackgroundAssetId"/>
                                                                                        <Binding Path="DataContext.ProjectViewModel.CurrentProject.Assets" RelativeSource="{RelativeSource AncestorType={x:Type local:TimelineView}}"/>
                                                                                    </MultiBinding>
                                                                                </TextBlock.Visibility>
                                                                            </TextBlock>
                                                                            <!-- Layer 1: Video strip - 3 frames for faster performance (0%, 50%, 100% segment) -->
                                                                            <ItemsControl x:Name="SegmentStripItems" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Panel.ZIndex="1" AlternationCount="10">
                                                                                <ItemsControl.ItemsSource>
                                                                                    <MultiBinding Converter="{StaticResource SegmentStripTimesConverter}">
                                                                                        <Binding Path="DataContext" RelativeSource="{RelativeSource Self}"/>
                                                                                        <Binding Path="DataContext.ProjectViewModel.CurrentProject.Assets" RelativeSource="{RelativeSource AncestorType={x:Type local:TimelineView}}"/>
                                                                                        <Binding Path="DataContext.EndTime" RelativeSource="{RelativeSource Self}"/>
                                                                                        <Binding Path="DataContext.IsDeferringThumbnailUpdate" RelativeSource="{RelativeSource AncestorType={x:Type local:TimelineView}}"/>
                                                                                    </MultiBinding>
                                                                                </ItemsControl.ItemsSource>
                                                                                <ItemsControl.ItemsPanel>
                                                                                    <ItemsPanelTemplate>
                                                                                        <Grid>
                                                                                            <Grid.ColumnDefinitions>
                                                                                                <ColumnDefinition Width="*"/>
                                                                                                <ColumnDefinition Width="*"/>
                                                                                                <ColumnDefinition Width="*"/>
                                                                                            </Grid.ColumnDefinitions>
                                                                                        </Grid>
                                                                                    </ItemsPanelTemplate>
                                                                                </ItemsControl.ItemsPanel>
                                                                                <ItemsControl.ItemContainerStyle>
                                                                                    <Style TargetType="ContentPresenter">
                                                                                        <Setter Property="Grid.Column" Value="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource Self}}"/>
                                                                                    </Style>
                                                                                </ItemsControl.ItemContainerStyle>
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate>
                                                                                        <Border Margin="1,0" CornerRadius="2" ClipToBounds="True"
                                                                                                CacheMode="BitmapCache"
                                                                                                RenderOptions.CachingHint="Cache">
                                                                                            <Image Stretch="UniformToFill" 
                                                                                                   RenderOptions.BitmapScalingMode="Fant"
                                                                                                   RenderOptions.EdgeMode="Aliased">
                                                                                                <Image.Source>
                                                                                                    <MultiBinding Converter="{StaticResource VideoFrameAtTimeConverter}">
                                                                                                        <Binding Path="."/>
                                                                                                        <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                                                                        <Binding Path="DataContext.ProjectViewModel.CurrentProject.Assets" RelativeSource="{RelativeSource AncestorType={x:Type local:TimelineView}}"/>
                                                                                                        <Binding Path="DataContext.IsDeferringThumbnailUpdate" RelativeSource="{RelativeSource AncestorType={x:Type local:TimelineView}}"/>
                                                                                                    </MultiBinding>
                                                                                                </Image.Source>
                                                                                            </Image>
                                                                                        </Border>
                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>
                                                                            <!-- Single thumbnail (image or video first frame when strip empty); hidden when segment has asset -->
                                                                            <Image Stretch="UniformToFill" 
                                                                                   RenderOptions.BitmapScalingMode="HighQuality" 
                                                                                   RenderOptions.CachingHint="Cache"
                                                                                   CacheMode="BitmapCache"
                                                                                   HorizontalAlignment="Left" Width="44" Margin="2,0" Panel.ZIndex="2">
                                                                                <Image.Source>
                                                                                    <MultiBinding Converter="{StaticResource SegmentThumbnailSourceConverter}">
                                                                                        <Binding Path="BackgroundAssetId"/>
                                                                                        <Binding Path="DataContext.ProjectViewModel.CurrentProject.Assets" RelativeSource="{RelativeSource AncestorType={x:Type local:TimelineView}}"/>
                                                                                    </MultiBinding>
                                                                                </Image.Source>
                                                                                <Image.Visibility>
                                                                                    <MultiBinding Converter="{StaticResource AssetIdToSingleThumbVisibilityConverter}">
                                                                                        <Binding Path="BackgroundAssetId"/>
                                                                                        <Binding Path="DataContext.ProjectViewModel.CurrentProject.Assets" RelativeSource="{RelativeSource AncestorType={x:Type local:TimelineView}}"/>
                                                                                    </MultiBinding>
                                                                                </Image.Visibility>
                                                                            </Image>
                                                                        </Grid>
                                                                    </Border>
                                                                    <!-- Audio segments: waveform fills full segment height -->
                                                                    <Border Grid.Column="0" CornerRadius="3" VerticalAlignment="Stretch" MinWidth="60"
                                                                            Background="#1a3a4a" ClipToBounds="True"
                                                                            Visibility="{Binding Kind, Converter={StaticResource KindToVisibilityConverter}, ConverterParameter=audio}">
                                                                        <controls:WaveformControl VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                                                                                  Peaks="{Binding WaveformPeaks}"
                                                                                                  PixelsPerSecond="{Binding DataContext.PixelsPerSecond, RelativeSource={RelativeSource AncestorType={x:Type local:TimelineView}}}"
                                                                                                  TotalDuration="{Binding DataContext.TotalDuration, RelativeSource={RelativeSource AncestorType={x:Type local:TimelineView}}}"/>
                                                                    </Border>
                                                                    <!-- Floating label: segment name/text; vertically centered for text-kind tracks -->
                                                                    <TextBlock Text="{Binding Text}"
                                                                               HorizontalAlignment="Left"
                                                                               Foreground="White" FontWeight="SemiBold"
                                                                               Margin="4,2,4,0" Padding="2,1"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               Background="#80000000"
                                                                               Panel.ZIndex="5">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="VerticalAlignment" Value="Top"/>
                                                                                <Setter Property="FontSize" Value="9"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Kind}" Value="text">
                                                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                                                        <Setter Property="FontSize" Value="10"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </Grid>
                                                                <Thumb x:Name="ResizeLeftThumb" Style="{StaticResource ResizeThumbStyle}"
                                                                      HorizontalAlignment="Left"
                                                                      Width="8"
                                                                      Cursor="SizeWE"
                                                                      Opacity="0"
                                                                      Panel.ZIndex="2"
                                                                      DragDelta="ResizeLeftThumb_DragDelta"
                                                                      DragStarted="ResizeLeftThumb_DragStarted"
                                                                      DragCompleted="ResizeLeftThumb_DragCompleted"/>
                                                                <Thumb x:Name="ResizeThumb" Style="{StaticResource ResizeThumbStyle}"
                                                                      HorizontalAlignment="Right"
                                                                      Width="8"
                                                                      Cursor="SizeWE"
                                                                      Opacity="0"
                                                                      Panel.ZIndex="2"
                                                                      DragDelta="ResizeThumb_DragDelta"
                                                                      DragStarted="ResizeThumb_DragStarted"
                                                                      DragCompleted="ResizeThumb_DragCompleted"/>
                                                            </Grid>
                                                        </Border>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Canvas>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Row 2: Waveform -->
                        <Border Grid.Row="2" Background="#2a2a2a" BorderBrush="#37474f" BorderThickness="0,1,0,0" Height="48" ClipToBounds="True">
                            <controls:WaveformControl x:Name="WaveformControl"
                                                      ClipToBounds="True"
                                                      Height="48"
                                                      Width="{Binding AudioContentWidth}"
                                                      HorizontalAlignment="Left"
                                                      Peaks="{Binding AudioPeaks}"
                                                      PixelsPerSecond="{Binding PixelsPerSecond}"
                                                      TotalDuration="{Binding TotalDuration}"/>
                        </Border>

                        <!-- Playhead: spans across ruler + tracks + waveform -->
                        <Canvas Grid.Row="0" Grid.RowSpan="3"
                                Width="{Binding TimelineWidth}"
                                IsHitTestVisible="False" ClipToBounds="True">
                            <Line x:Name="PlayheadLine"
                                 X1="0" Y1="0" X2="0" Y2="10000"
                                 Stroke="#64b5f6" StrokeThickness="2"
                                 Canvas.Left="0" Canvas.Top="0"
                                 StrokeDashArray="5,5"/>
                        </Canvas>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </ScrollViewer>

        <!-- BGM Row: background music configuration strip at the bottom of the timeline -->
        <Border Grid.Row="2" Background="#1a1a2a" BorderBrush="#3a3a5a" BorderThickness="0,1,0,0" Padding="6,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="56"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!-- Label matching track header width -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="BGM" Foreground="#7986cb" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center"/>
                    <CheckBox IsChecked="{Binding BgmIsEnabled}" HorizontalAlignment="Center" ToolTip="Enable BGM in render"/>
                </StackPanel>
                <!-- Controls -->
                <WrapPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBox x:Name="BgmPathBox"
                             Text="{Binding BgmFilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Width="200" MaxHeight="26" Margin="0,0,4,0"
                             Background="#252535" Foreground="#e0e0e0" BorderBrush="#5c6bc0"
                             VerticalContentAlignment="Center" Padding="4,0"
                             IsReadOnly="True" ToolTip="{Binding BgmFilePath}"
                             FontSize="11"/>
                    <Button Content="Browse" Command="{Binding BrowseBgmFileCommand}"
                            Background="#3949ab" Foreground="White" Padding="8,4" Margin="0,0,8,0"
                            MinHeight="26" VerticalContentAlignment="Center" FontSize="11"/>
                    <TextBlock Text="Vol:" Foreground="#9fa8da" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="11"/>
                    <Slider Value="{Binding BgmVolume, Mode=TwoWay}" Minimum="0" Maximum="1"
                            Width="80" VerticalAlignment="Center" Margin="0,0,4,0"
                            ToolTip="{Binding BgmVolume, StringFormat='Volume: {0:P0}'}"/>
                    <TextBlock Text="Fade↑" Foreground="#9fa8da" VerticalAlignment="Center" Margin="0,0,2,0" FontSize="11"/>
                    <TextBox Text="{Binding BgmFadeIn, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                             Width="36" MaxHeight="26" Margin="0,0,6,0"
                             Background="#252535" Foreground="#e0e0e0" BorderBrush="#5c6bc0"
                             VerticalContentAlignment="Center" Padding="2,0" FontSize="11"
                             ToolTip="Fade-in seconds"/>
                    <TextBlock Text="↓" Foreground="#9fa8da" VerticalAlignment="Center" Margin="0,0,2,0" FontSize="11"/>
                    <TextBox Text="{Binding BgmFadeOut, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                             Width="36" MaxHeight="26" Margin="0,0,8,0"
                             Background="#252535" Foreground="#e0e0e0" BorderBrush="#5c6bc0"
                             VerticalContentAlignment="Center" Padding="2,0" FontSize="11"
                             ToolTip="Fade-out seconds"/>
                    <CheckBox Content="Loop" IsChecked="{Binding BgmIsLooping, Mode=TwoWay}"
                              Foreground="#9fa8da" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="11"
                              ToolTip="Loop BGM to fill project duration"/>
                    <Button Content="✕" Command="{Binding ClearBgmCommand}"
                            Background="#c62828" Foreground="White" Width="26" Height="26"
                            FontWeight="Bold" ToolTip="Remove BGM" Margin="0,0,0,0"/>
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>

</UserControl>
