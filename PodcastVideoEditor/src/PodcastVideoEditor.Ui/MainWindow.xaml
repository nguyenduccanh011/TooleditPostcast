<Window x:Class="PodcastVideoEditor.Ui.MainWindow"
        x:Name="MainWindowRoot"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:PodcastVideoEditor.Ui.Controls"
        xmlns:views="clr-namespace:PodcastVideoEditor.Ui.Views"
        Title="Podcast Video Editor" Height="820" MinHeight="680" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        Foreground="#FFFFFF"
        Loaded="MainWindow_Loaded"
        Closing="MainWindow_Closing">
    <Window.InputBindings>
        <KeyBinding Key="B" Modifiers="Control"
                    Command="{Binding TimelineViewModel.SplitSelectedSegmentAtPlayheadCommand}"/>
    </Window.InputBindings>
    <DockPanel>
        <Menu DockPanel.Dock="Top" Background="#252526">
            <MenuItem Header="File">
                <MenuItem Header="New Project" Click="NewProjectButton_Click" />
                <MenuItem Header="Open Selected" Click="OpenSelectedMenu_Click" />
                <Separator />
                <MenuItem Header="Exit" Click="ExitMenu_Click" />
            </MenuItem>
            <MenuItem Header="Edit">
                <MenuItem Header="Settings" Click="SettingsMenu_Click" />
            </MenuItem>
            <MenuItem Header="Help">
                <MenuItem Header="About" Click="AboutMenu_Click" />
            </MenuItem>
        </Menu>

        <!--
            Render toolbar – docked below the menu, visible only when Editor tab is active.
            DataContext is RenderViewModel (set via code-behind on tab switch).
        -->
        <Border x:Name="RenderToolbar"
                DockPanel.Dock="Top"
                Background="#2D2D30"
                BorderBrush="#3E3E42" BorderThickness="0,1,0,1"
                Padding="8,3"
                Visibility="Collapsed"
                DataContext="{Binding DataContext.RenderViewModel, RelativeSource={RelativeSource AncestorType=Window}}">
            <Border.Resources>
                <!-- Compact outline dropdown button -->
                <Style x:Key="DropBtn" TargetType="Button">
                    <Setter Property="Background"     Value="Transparent"/>
                    <Setter Property="Foreground"     Value="#CCCCCC"/>
                    <Setter Property="BorderBrush"    Value="#3E3E42"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="Padding"        Value="7,3"/>
                    <Setter Property="FontSize"       Value="12"/>
                    <Setter Property="Height"         Value="26"/>
                    <Setter Property="Cursor"         Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="3" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#3A3D3F"/>
                                        <Setter Property="Foreground"               Value="#FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Border.Resources>

            <DockPanel LastChildFill="True">

                <!-- Left: option dropdowns (Resolution / Quality / Scale) -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,8,0">

                    <!-- Resolution -->
                    <Button x:Name="TB_ResolutionButton"
                            Style="{StaticResource DropBtn}"
                            Content="{Binding SelectedResolution}"
                            ToolTip="Resolution"
                            Margin="0,0,4,0"
                            Click="RenderTB_DropdownClick">
                        <Button.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                <MenuItem Header="480p"  Command="{Binding SetResolutionCommand}" CommandParameter="480p"/>
                                <MenuItem Header="720p"  Command="{Binding SetResolutionCommand}" CommandParameter="720p"/>
                                <MenuItem Header="1080p" Command="{Binding SetResolutionCommand}" CommandParameter="1080p"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>

                    <!-- Quality -->
                    <Button x:Name="TB_QualityButton"
                            Style="{StaticResource DropBtn}"
                            Content="{Binding SelectedQuality}"
                            ToolTip="Quality"
                            Margin="0,0,4,0"
                            Click="RenderTB_DropdownClick">
                        <Button.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                <MenuItem Header="Low"    Command="{Binding SetQualityCommand}" CommandParameter="Low"/>
                                <MenuItem Header="Medium" Command="{Binding SetQualityCommand}" CommandParameter="Medium"/>
                                <MenuItem Header="High"   Command="{Binding SetQualityCommand}" CommandParameter="High"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>

                    <!-- Scale -->
                    <Button x:Name="TB_ScaleButton"
                            Style="{StaticResource DropBtn}"
                            Content="{Binding SelectedScaleMode}"
                            ToolTip="Scale mode"
                            Margin="0,0,8,0"
                            Click="RenderTB_DropdownClick">
                        <Button.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                <MenuItem Header="Fill"    Command="{Binding SetScaleModeCommand}" CommandParameter="Fill"/>
                                <MenuItem Header="Fit"     Command="{Binding SetScaleModeCommand}" CommandParameter="Fit"/>
                                <MenuItem Header="Stretch" Command="{Binding SetScaleModeCommand}" CommandParameter="Stretch"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>

                    <!-- Separator -->
                    <Rectangle Width="1" Fill="#3E3E42" Margin="0,4,8,4"/>

                    <!-- Output folder -->
                    <Button Style="{StaticResource DropBtn}"
                            ToolTip="{Binding OutputFolder, StringFormat='Output: {0}'}"
                            Command="{Binding BrowseOutputFolderCommand}"
                            Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📁" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="{Binding OutputFolder}" FontSize="11" Foreground="#AAAAAA"
                                       VerticalAlignment="Center" MaxWidth="160"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Right: Render / Cancel buttons -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="8,0,0,0">

                    <!-- Cancel -->
                    <Button Content="Cancel"
                            Width="70" Height="26" Margin="4,0,0,0"
                            Background="#C0392B" Foreground="White" BorderThickness="0"
                            IsEnabled="{Binding CanCancel}"
                            Visibility="{Binding IsRendering, Converter={StaticResource BoolToVisibilityConverter}}"
                            Command="{Binding CancelRenderCommand}"
                            Cursor="Hand"/>

                    <!-- Start Render -->
                    <Button Width="100" Height="26" Margin="4,0,0,0"
                            Background="#007ACC" Foreground="White" BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="{Binding StatusMessage}"
                            Command="{Binding StartRenderCommand}"
                            CommandParameter="{Binding DataContext.ProjectViewModel.CurrentProject, RelativeSource={RelativeSource AncestorType=Window}}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Content" Value="▶ Render"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRendering}" Value="True">
                                        <Setter Property="Content"     Value="Rendering…"/>
                                        <Setter Property="Background"  Value="#555555"/>
                                        <Setter Property="IsEnabled"   Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- Middle: slim progress + error notification (fills remaining space) -->
                <Grid VerticalAlignment="Center" Margin="8,0">
                    <!-- Progress bar (visible while rendering) -->
                    <ProgressBar Value="{Binding RenderProgress}" Maximum="100"
                                 IsIndeterminate="{Binding RenderProgressIsIndeterminate}"
                                 Height="6" Background="#3E3E42" Foreground="#28A745"
                                 Visibility="{Binding IsRendering, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <!-- Error notification (visible on HasError) -->
                    <Border Background="#3A1010" BorderBrush="#C0392B" BorderThickness="1"
                            CornerRadius="3" Padding="8,2"
                            Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{Binding StatusMessage}" Foreground="#FF6B6B"
                                   FontSize="11" TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"/>
                    </Border>
                </Grid>

            </DockPanel>
        </Border>

        <TabControl x:Name="MainTabControl" Background="#1E1E1E" Foreground="#FFFFFF" SelectionChanged="MainTabControl_SelectionChanged"
                    DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
            <TabItem Header="Home" DataContext="{Binding ProjectViewModel}">
                <ScrollViewer>
                    <StackPanel Margin="20">
                        <TextBlock Text="Welcome to Podcast Video Editor" FontSize="22" FontWeight="Bold" Foreground="#007ACC" />
                        <TextBlock Text="Create a new project or open a recent one." Margin="0,6,0,20" Foreground="#CCCCCC" />

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <Button Content="New Project" Width="130" Height="36" Margin="0,0,10,0"
                                    Background="#28A745" Foreground="#FFFFFF" BorderThickness="0"
                                    Click="NewProjectButton_Click" />
                            <Button Content="Open Selected" Width="130" Height="36" Margin="0,0,10,0"
                                    Background="#007ACC" Foreground="#FFFFFF" BorderThickness="0"
                                    Click="OpenSelectedMenu_Click" />
                            <Button Content="Delete Selected" Width="130" Height="36" Margin="0,0,10,0"
                                    Background="#D13438" Foreground="#FFFFFF" BorderThickness="0"
                                    Command="{Binding DeleteProjectCommand}" CommandParameter="{Binding CurrentProject}" />
                            <Button Content="Refresh" Width="100" Height="36"
                                    Background="#3E3E42" Foreground="#FFFFFF" BorderThickness="0"
                                    Command="{Binding LoadProjectsCommand}" />
                        </StackPanel>

                        <Border Background="#252526" BorderBrush="#3E3E42" BorderThickness="1" Padding="10">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="Recent Projects" FontSize="14" FontWeight="Bold" />
                                    <TextBlock Text="{Binding Projects.Count, StringFormat=' ({0})'}" FontSize="14" FontWeight="Bold" Foreground="#AAAAAA" Margin="5,0,0,0" />
                                </StackPanel>
                                <ListBox x:Name="ProjectsListBox"
                                         ItemsSource="{Binding Projects}"
                                         SelectedItem="{Binding CurrentProject, Mode=TwoWay}"
                                         IsSynchronizedWithCurrentItem="True"
                                         Height="240"
                                         Background="#1E1E1E" Foreground="#FFFFFF" BorderThickness="0"
                                         SelectionChanged="ProjectsListBox_SelectionChanged"
                                         MouseDoubleClick="ProjectsList_MouseDoubleClick">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="Padding" Value="8,6" />
                                            <Setter Property="Margin" Value="0,1" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#2A2D2E" />
                                                    <Setter Property="Cursor" Value="Hand" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#094771" />
                                                    <Setter Property="Foreground" Value="#FFFFFF" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,4" Background="Transparent">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding AudioPath}" FontSize="11" Foreground="#AAAAAA" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>

                        <!-- Debug Info Panel (uncomment when debugging selection issues)
                        <StackPanel Margin="0,15,0,0">
                            <TextBlock Text="Debug Info" FontWeight="Bold" Margin="0,0,0,6" />
                            <Border Background="#252526" BorderBrush="#3E3E42" BorderThickness="1" Padding="10">
                                <StackPanel>
                                    <TextBlock TextWrapping="Wrap">
                                        <Run Text="Selected Project: " />
                                        <Run Text="{Binding CurrentProject.Name, FallbackValue='None'}" FontWeight="Bold" Foreground="#FFA500" />
                                    </TextBlock>
                                    <TextBlock Text="{Binding CurrentProject.Id, StringFormat='ID: {0}', FallbackValue='No project selected'}" FontSize="10" Foreground="#888" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        -->

                        <StackPanel Margin="0,15,0,0">
                            <TextBlock Text="Status" FontWeight="Bold" Margin="0,0,0,6" />
                            <Border Background="#252526" BorderBrush="#3E3E42" BorderThickness="1" Padding="10">
                                <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Resizable split-panel Editor -->
            <TabItem Header="Editor">
                <!--
                    Row GridSplitters:  HorizontalAlignment=Stretch + VerticalAlignment=Center
                    Column GridSplitters: VerticalAlignment=Stretch + HorizontalAlignment=Center
                    No custom template – lets WPF hit-test the full area reliably.
                -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="3*" MinHeight="200"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="2*" MinHeight="160"/>
                    </Grid.RowDefinitions>

                    <!-- ═══════════ Row 0 : Three-column top area ═══════════ -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"  MinWidth="180"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="2*" MinWidth="280"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"  MinWidth="200"/>
                        </Grid.ColumnDefinitions>

                        <!-- Col 0: Elements / Media -->
                        <Border Grid.Column="0" Background="#252526" BorderBrush="#3E3E42" BorderThickness="0,0,0,1" Padding="8">
                            <views:ElementsMediaPanelView DataContext="{Binding}" />
                        </Border>

                        <!-- Vertical splitter between Elements and Canvas -->
                        <GridSplitter Grid.Column="1"
                                      VerticalAlignment="Stretch" HorizontalAlignment="Center"
                                      Width="6" Background="#3E3E42" Cursor="SizeWE"
                                      ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"/>

                        <!-- Col 2: Preview / Canvas -->
                        <Border Grid.Column="2" Background="#252526" BorderBrush="#3E3E42" BorderThickness="0,0,0,1">
                            <views:CanvasView DataContext="{Binding CanvasViewModel}" />
                        </Border>

                        <!-- Vertical splitter between Canvas and Properties -->
                        <GridSplitter Grid.Column="3"
                                      VerticalAlignment="Stretch" HorizontalAlignment="Center"
                                      Width="6" Background="#3E3E42" Cursor="SizeWE"
                                      ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"/>

                        <!-- Col 4: Properties -->
                        <Border Grid.Column="4" Background="#252526" BorderBrush="#3E3E42" BorderThickness="0,0,0,1">
                            <views:UnifiedPropertiesPanel DataContext="{Binding}" />
                        </Border>
                    </Grid>

                    <!-- Horizontal splitter: Top panels ↕ Timeline -->
                    <GridSplitter Grid.Row="1"
                                  HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                  Height="8" Background="#3E3E42" Cursor="SizeNS"
                                  ResizeDirection="Rows" ResizeBehavior="PreviousAndNext"/>

                    <!-- ═══════════ Row 2 : Timeline ═══════════ -->
                    <Border Grid.Row="2" Background="#252526" BorderBrush="#3E3E42" BorderThickness="0" Padding="10,4">
                        <views:TimelineView DataContext="{Binding TimelineViewModel}" />
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Settings">
                <ScrollViewer>
                    <StackPanel Margin="20">
                        <TextBlock Text="Settings" FontSize="22" FontWeight="Bold" Foreground="#007ACC" />
                        <TextBlock Text="Configure FFmpeg and application paths." Margin="0,6,0,20" Foreground="#CCCCCC" />

                        <TextBlock Text="FFmpeg Path" Margin="0,0,0,6" />
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="FFmpegPathTextBox" Grid.Column="0" Height="32" Padding="8"
                                     Background="#252526" Foreground="#FFFFFF" BorderBrush="#3E3E42" BorderThickness="1" />
                            <Button Grid.Column="1" Width="90" Height="32" Margin="10,0,0,0" Content="Browse"
                                    Background="#3E3E42" Foreground="#FFFFFF" BorderThickness="0" Click="BrowseFFmpeg_Click" />
                            <Button Grid.Column="2" Width="90" Height="32" Margin="10,0,0,0" Content="Validate"
                                    Background="#007ACC" Foreground="#FFFFFF" BorderThickness="0" Click="ValidateFFmpeg_Click" />
                        </Grid>

                        <TextBlock x:Name="FFmpegStatusText" Foreground="#CCCCCC" Margin="0,0,0,20" TextWrapping="Wrap" />

                        <TextBlock Text="App Data Path" Margin="0,0,0,6" />
                        <TextBox x:Name="AppDataPathText" Height="32" Padding="8" IsReadOnly="True"
                                 Background="#252526" Foreground="#FFFFFF" BorderBrush="#3E3E42" BorderThickness="1" />

                        <StackPanel Margin="0,20,0,0">
                            <TextBlock Text="About" FontSize="16" FontWeight="Bold" Margin="0,0,0,6" />
                            <TextBlock Text="Podcast Video Editor - Phase 1" Foreground="#CCCCCC" />
                            <TextBlock Text="Built with .NET 8 WPF" Foreground="#AAAAAA" />
                        </StackPanel>

                        <!-- ─── AI Analysis Settings ─────────────────────────────── -->
                        <Separator Margin="0,24,0,16" Background="#3E3E42"/>
                        <TextBlock Text="AI Analysis (YesScale)" FontSize="16" FontWeight="Bold" Foreground="#ce93d8" Margin="0,0,0,8"/>
                        <TextBlock Text="YesScale API Key" Margin="0,0,0,5" Foreground="#CCCCCC"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <PasswordBox x:Name="YesScaleApiKeyBox" Grid.Column="0" Height="32" Padding="8"
                                         Background="#252526" Foreground="#FFFFFF" BorderBrush="#3E3E42" BorderThickness="1"
                                         PasswordChanged="YesScaleApiKeyBox_PasswordChanged"/>
                            <Button Grid.Column="1" Content="Lưu" Width="70" Height="32" Margin="8,0,0,0"
                                    Background="#7b1fa2" Foreground="#FFFFFF" BorderThickness="0"
                                    Click="SaveAISettings_Click"/>
                        </Grid>

                        <TextBlock Text="Model" Margin="0,0,0,5" Foreground="#CCCCCC"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="YesScaleModelBox" Grid.Column="0" Height="32"
                                      Background="#252526" Foreground="#FFFFFF" BorderBrush="#3E3E42" BorderThickness="1"
                                      IsEditable="True" Text="gpt-4o-mini" Padding="6,0"/>
                            <Button x:Name="FetchModelsButton" Grid.Column="1" Content="↻ Tải models"
                                    Height="32" Margin="8,0,0,0" Padding="10,0"
                                    Background="#4a148c" Foreground="#FFFFFF" BorderThickness="0"
                                    Click="FetchModels_Click"/>
                        </Grid>
                        <TextBlock x:Name="ModelFetchStatus" Foreground="#AAAAAA" Margin="0,0,0,12"
                                   FontSize="11" TextWrapping="Wrap" Visibility="Collapsed"/>

                        <!-- ─── Image Search Settings ─────────────────────────────── -->
                        <TextBlock Text="Tìm kiếm ảnh" FontSize="16" FontWeight="Bold" Foreground="#80cbc4" Margin="0,0,0,8"/>

                        <TextBlock Text="Pexels API Key" Margin="0,0,0,5" Foreground="#CCCCCC"/>
                        <PasswordBox x:Name="PexelsApiKeyBox" Height="32" Padding="8" Margin="0,0,0,12"
                                     Background="#252526" Foreground="#FFFFFF" BorderBrush="#3E3E42" BorderThickness="1"/>

                        <TextBlock Text="Pixabay API Key" Margin="0,0,0,5" Foreground="#CCCCCC"/>
                        <PasswordBox x:Name="PixabayApiKeyBox" Height="32" Padding="8" Margin="0,0,0,12"
                                     Background="#252526" Foreground="#FFFFFF" BorderBrush="#3E3E42" BorderThickness="1"/>

                        <TextBlock Text="Unsplash Access Key" Margin="0,0,0,5" Foreground="#CCCCCC"/>
                        <PasswordBox x:Name="UnsplashApiKeyBox" Height="32" Padding="8" Margin="0,0,0,12"
                                     Background="#252526" Foreground="#FFFFFF" BorderBrush="#3E3E42" BorderThickness="1"/>

                        <Button Content="Lưu cấu hình ảnh" HorizontalAlignment="Left"
                                Width="160" Height="32" Background="#00695c" Foreground="#FFFFFF" BorderThickness="0"
                                Click="SaveImageSettings_Click" Margin="0,4,0,0"/>

                        <TextBlock x:Name="AISettingsStatusText" Foreground="#81c784" Margin="0,10,0,0"
                                   FontSize="11" TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
