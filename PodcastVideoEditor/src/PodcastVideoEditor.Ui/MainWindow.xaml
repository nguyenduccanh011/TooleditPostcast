<Window x:Class="PodcastVideoEditor.Ui.MainWindow"
        x:Name="MainWindowRoot"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:PodcastVideoEditor.Ui.Controls"
        xmlns:views="clr-namespace:PodcastVideoEditor.Ui.Views"
        xmlns:conv="clr-namespace:PodcastVideoEditor.Ui.Converters"
        Title="Podcast Video Editor" Height="820" MinHeight="680" Width="1100"
        Icon="Assets/PodcastVideoEditor.ico"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="#1E1E1E"
        Foreground="#FFFFFF"
        Loaded="MainWindow_Loaded"
        Closing="MainWindow_Closing"
        StateChanged="MainWindow_StateChanged">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="38" ResizeBorderThickness="5"
                      GlassFrameThickness="0" CornerRadius="0"
                      NonClientFrameEdges="None"/>
    </WindowChrome.WindowChrome>
    <Window.InputBindings>
        <KeyBinding Key="B" Modifiers="Control"
                    Command="{Binding TimelineViewModel.SplitSelectedSegmentAtPlayheadCommand}"/>
        <KeyBinding Key="G" Modifiers="Control"
                    Command="{Binding TimelineViewModel.CloseGapsOnTrackCommand}"/>
        <KeyBinding Key="S" Modifiers="Control"
                    Command="{Binding ProjectViewModel.SaveProjectCommand}"/>
    </Window.InputBindings>
    <Border x:Name="WindowBorder" BorderBrush="#3E3E42" BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════ Custom Title Bar ═══════════ -->
        <Grid Grid.Row="0" Background="#1e1e1e">
            <Grid.Resources>
                <!-- Title bar tab button (RadioButton styled as flat tab) -->
                <Style x:Key="TitleBarTab" TargetType="RadioButton">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#888888"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="Padding" Value="14,0"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="RadioButton">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                                    <Grid>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          Margin="0,2,0,4"/>
                                        <Rectangle x:Name="Line" Height="2" VerticalAlignment="Bottom" Fill="Transparent"/>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="Line" Property="Fill" Value="#0E639C"/>
                                        <Setter Property="Foreground" Value="#FFFFFF"/>
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsMouseOver" Value="True"/>
                                            <Condition Property="IsChecked" Value="False"/>
                                        </MultiTrigger.Conditions>
                                        <Setter TargetName="Bd" Property="Background" Value="#2A2D2E"/>
                                        <Setter Property="Foreground" Value="#CCCCCC"/>
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
                <!-- Window control button -->
                <Style x:Key="WinBtn" TargetType="Button">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#CCCCCC"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Width" Value="46"/>
                    <Setter Property="Height" Value="38"/>
                    <Setter Property="FontSize" Value="10"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                    <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#3E3E42"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#555555"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
                <!-- Close button with red hover -->
                <Style x:Key="CloseBtn" TargetType="Button" BasedOn="{StaticResource WinBtn}">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#E81123"/>
                                        <Setter Property="Foreground" Value="#FFFFFF"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#F1707A"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Grid.Resources>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Icon + Title -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,8,0">
                <TextBlock Text="🎙" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="Podcast Video Editor" FontSize="12" Foreground="#CCCCCC"
                           VerticalAlignment="Center" FontWeight="SemiBold"/>
            </StackPanel>

            <!-- Menu -->
            <Menu Grid.Column="1" Background="Transparent" VerticalAlignment="Center"
                  WindowChrome.IsHitTestVisibleInChrome="True">
                <MenuItem Header="File">
                    <MenuItem Header="New Project" Click="NewProjectButton_Click"/>
                                        <MenuItem Header="New Project From Template" Click="NewProjectFromTemplateButton_Click"/>
                    <MenuItem Header="Save Current As Template" Click="SaveCurrentAsTemplateMenu_Click"/>
                    <MenuItem Header="Export Current As Template Package" Click="ExportCurrentAsTemplatePackageMenu_Click"/>
                    <MenuItem Header="Import Template Package" Click="ImportTemplatePackageMenu_Click"/>
                    <MenuItem Header="Open Selected" Click="OpenSelectedMenu_Click"/>
                    <Separator/>
                    <MenuItem Header="Exit" Click="ExitMenu_Click"/>
                </MenuItem>
                <MenuItem Header="Edit">
                    <MenuItem Header="Settings" Click="SettingsMenu_Click"/>
                </MenuItem>
                <MenuItem Header="Help">
                    <MenuItem Header="Check for Updates" Click="CheckForUpdatesMenu_Click"/>
                    <Separator/>
                    <MenuItem Header="About" Click="AboutMenu_Click"/>
                </MenuItem>
            </Menu>

            <!-- Tab Buttons (center) -->
            <StackPanel Grid.Column="2" Orientation="Horizontal"
                        HorizontalAlignment="Center" VerticalAlignment="Stretch">
                <RadioButton x:Name="TabBtnHome" Content="Home" GroupName="MainTabs"
                             IsChecked="True" Click="TabButton_Click" Tag="0"
                             Style="{StaticResource TitleBarTab}"/>
                <RadioButton x:Name="TabBtnEditor" Content="Editor" GroupName="MainTabs"
                             Click="TabButton_Click" Tag="1"
                             Style="{StaticResource TitleBarTab}"/>
                <RadioButton x:Name="TabBtnSettings" Content="Settings" GroupName="MainTabs"
                             Click="TabButton_Click" Tag="2"
                             Style="{StaticResource TitleBarTab}"/>
            </StackPanel>

            <!-- Render button (visible only on Editor tab) -->
            <Button x:Name="TitleBarRenderBtn" Grid.Column="3"
                    Content="▶ Render" Background="#007ACC" Foreground="White"
                    FontSize="12" Padding="14,5" Height="26" Margin="0,0,8,0"
                    WindowChrome.IsHitTestVisibleInChrome="True"
                    Visibility="Collapsed"
                    Click="OpenRenderDialog_Click"/>

            <!-- Window control buttons -->
            <StackPanel Grid.Column="4" Orientation="Horizontal">
                <Button Content="─" Click="MinimizeButton_Click" Style="{StaticResource WinBtn}"/>
                <Button x:Name="MaximizeBtn" Content="□" Click="MaximizeButton_Click" Style="{StaticResource WinBtn}"/>
                <Button Content="✕" Click="CloseButton_Click" Style="{StaticResource CloseBtn}"/>
            </StackPanel>
        </Grid>

        <!-- ═══════════ Content: Tab pages (headers hidden) ═══════════ -->
        <TabControl x:Name="MainTabControl" Grid.Row="1" SelectedIndex="0"
                    Background="#1E1E1E" Foreground="#FFFFFF"
                    SelectionChanged="MainTabControl_SelectionChanged"
                    DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <ContentPresenter x:Name="PART_SelectedContentHost" ContentSource="SelectedContent"
                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                </ControlTemplate>
            </TabControl.Template>
            <TabItem Header="Home" DataContext="{Binding ProjectViewModel}">
                <ScrollViewer>
                    <StackPanel Margin="20">
                        <TextBlock Text="Welcome to Podcast Video Editor" FontSize="22" FontWeight="Bold" Foreground="#007ACC" />
                        <TextBlock Text="Create a new project or open a recent one." Margin="0,6,0,20" Foreground="#CCCCCC" />

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <Button Content="New Project" Width="130" Height="36" Margin="0,0,10,0"
                                    Background="#28A745" Foreground="#FFFFFF" BorderThickness="0"
                                    Click="NewProjectButton_Click" />
                            <Button Content="From Template" Width="130" Height="36" Margin="0,0,10,0"
                                Background="#6F42C1" Foreground="#FFFFFF" BorderThickness="0"
                                Click="NewProjectFromTemplateButton_Click" />
                            <Button Content="Open Selected" Width="130" Height="36" Margin="0,0,10,0"
                                    Background="#007ACC" Foreground="#FFFFFF" BorderThickness="0"
                                    Click="OpenSelectedMenu_Click" />
                            <Button Content="Delete Selected" Width="130" Height="36" Margin="0,0,10,0"
                                    Background="#D13438" Foreground="#FFFFFF" BorderThickness="0"
                                    Command="{Binding DeleteProjectCommand}" CommandParameter="{Binding CurrentProject}" />
                            <Button Content="Refresh" Width="100" Height="36"
                                    Background="#3E3E42" Foreground="#FFFFFF" BorderThickness="0"
                                    Command="{Binding LoadProjectsCommand}" />
                        </StackPanel>

                        <Border Background="#252526" BorderBrush="#3E3E42" BorderThickness="1" Padding="10">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="Recent Projects" FontSize="14" FontWeight="Bold" />
                                    <TextBlock Text="{Binding Projects.Count, StringFormat=' ({0})'}" FontSize="14" FontWeight="Bold" Foreground="#AAAAAA" Margin="5,0,0,0" />
                                </StackPanel>
                                <ListBox x:Name="ProjectsListBox"
                                         ItemsSource="{Binding Projects}"
                                         SelectedItem="{Binding CurrentProject, Mode=TwoWay}"
                                         Height="240"
                                         Background="#1E1E1E" Foreground="#FFFFFF" BorderThickness="0"
                                         MouseDoubleClick="ProjectsList_MouseDoubleClick">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                            <Setter Property="Padding" Value="8,6" />
                                            <Setter Property="Margin" Value="0,1" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="Cursor" Value="Hand" />
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,4" Background="Transparent">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding AudioPath}" FontSize="11" Foreground="#AAAAAA" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>

                        <StackPanel Margin="0,15,0,0">
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock Text="Template Quick Start" FontWeight="Bold" VerticalAlignment="Center" />
                                <Button DockPanel.Dock="Right"
                                        Content="Import Template"
                                        Height="28"
                                        Padding="12,0"
                                        Background="#3E3E42"
                                        Foreground="#FFFFFF"
                                        BorderThickness="0"
                                        Click="ImportTemplatePackageMenu_Click" />
                            </DockPanel>
                            <Border Background="#252526" BorderBrush="#3E3E42" BorderThickness="1" Padding="10">
                                <ItemsControl ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=HomeTemplateOptions}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="300" Margin="0,0,12,12" Padding="10" Background="#1E1E1E" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="4">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" Foreground="#FFFFFF" />
                                                    <TextBlock Text="{Binding AspectRatio, StringFormat='Aspect: {0}'}" Margin="0,4,0,0" Foreground="#AAAAAA" FontSize="11" />
                                                    <TextBlock Text="{Binding Description}" Margin="0,6,0,10" Foreground="#CCCCCC" FontSize="11" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxHeight="48" />
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Content="Use Template" Height="28" Margin="0,0,8,0" Padding="12,0"
                                                                Background="#007ACC" Foreground="#FFFFFF" BorderThickness="0"
                                                                Click="HomeTemplateQuickCreateButton_Click" />
                                                        <Button Content="Export" Height="28" Padding="12,0"
                                                                Background="#3E3E42" Foreground="#FFFFFF" BorderThickness="0"
                                                                Click="HomeTemplateExportButton_Click">
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Id}" Value="blank">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                        </StackPanel>

                        <!-- Debug Info Panel (uncomment when debugging selection issues)
                        <StackPanel Margin="0,15,0,0">
                            <TextBlock Text="Debug Info" FontWeight="Bold" Margin="0,0,0,6" />
                            <Border Background="#252526" BorderBrush="#3E3E42" BorderThickness="1" Padding="10">
                                <StackPanel>
                                    <TextBlock TextWrapping="Wrap">
                                        <Run Text="Selected Project: " />
                                        <Run Text="{Binding CurrentProject.Name, FallbackValue='None'}" FontWeight="Bold" Foreground="#FFA500" />
                                    </TextBlock>
                                    <TextBlock Text="{Binding CurrentProject.Id, StringFormat='ID: {0}', FallbackValue='No project selected'}" FontSize="10" Foreground="#888" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        -->

                        <StackPanel Margin="0,15,0,0">
                            <TextBlock Text="Status" FontWeight="Bold" Margin="0,0,0,6" />
                            <Border Background="#252526" BorderBrush="#3E3E42" BorderThickness="1" Padding="10">
                                <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Resizable split-panel Editor -->
            <TabItem Header="Editor">
                <!--
                    Row GridSplitters:  HorizontalAlignment=Stretch + VerticalAlignment=Center
                    Column GridSplitters: VerticalAlignment=Stretch + HorizontalAlignment=Center
                    No custom template – lets WPF hit-test the full area reliably.
                -->
                <Grid Background="#1e1e1e" Margin="4,4,4,4">
                    <Grid.Resources>
                        <conv:RoundedClipConverter x:Key="RoundedClipConverter"/>
                    </Grid.Resources>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="3*" MinHeight="200"/>
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="2*" MinHeight="160"/>
                    </Grid.RowDefinitions>

                    <!-- ═══════════ Row 0 : Three-column top area ═══════════ -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"  MinWidth="180"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="2*" MinWidth="280"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"  MinWidth="200"/>
                        </Grid.ColumnDefinitions>

                        <!-- Col 0: Elements / Media -->
                        <Border Grid.Column="0" Background="#252526" CornerRadius="6">
                            <Border.Clip>
                                <MultiBinding Converter="{StaticResource RoundedClipConverter}">
                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource Self}"/>
                                    <Binding Path="ActualHeight" RelativeSource="{RelativeSource Self}"/>
                                </MultiBinding>
                            </Border.Clip>
                            <views:ElementsMediaPanelView DataContext="{Binding}" />
                        </Border>

                        <!-- Vertical splitter between Elements and Canvas -->
                        <GridSplitter Grid.Column="1"
                                      VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                      Width="4" Background="Transparent" Cursor="SizeWE"
                                      ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"/>

                        <!-- Col 2: Preview / Canvas -->
                        <Border Grid.Column="2" Background="#252526" CornerRadius="6" Padding="0,4,0,0">
                            <Border.Clip>
                                <MultiBinding Converter="{StaticResource RoundedClipConverter}">
                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource Self}"/>
                                    <Binding Path="ActualHeight" RelativeSource="{RelativeSource Self}"/>
                                </MultiBinding>
                            </Border.Clip>
                            <views:CanvasView DataContext="{Binding CanvasViewModel}" />
                        </Border>

                        <!-- Vertical splitter between Canvas and Properties -->
                        <GridSplitter Grid.Column="3"
                                      VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                      Width="4" Background="Transparent" Cursor="SizeWE"
                                      ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"/>

                        <!-- Col 4: Properties -->
                        <Border Grid.Column="4" Background="#252526" CornerRadius="6">
                            <Border.Clip>
                                <MultiBinding Converter="{StaticResource RoundedClipConverter}">
                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource Self}"/>
                                    <Binding Path="ActualHeight" RelativeSource="{RelativeSource Self}"/>
                                </MultiBinding>
                            </Border.Clip>
                            <views:UnifiedPropertiesPanel DataContext="{Binding}" />
                        </Border>
                    </Grid>

                    <!-- Horizontal splitter: Top panels ↕ Timeline -->
                    <GridSplitter Grid.Row="1"
                                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                  Height="4" Background="Transparent" Cursor="SizeNS"
                                  ResizeDirection="Rows" ResizeBehavior="PreviousAndNext"/>

                    <!-- ═══════════ Row 2 : Timeline ═══════════ -->
                    <Border Grid.Row="2" Background="#252526" CornerRadius="6">
                        <Border.Clip>
                            <MultiBinding Converter="{StaticResource RoundedClipConverter}">
                                <Binding Path="ActualWidth" RelativeSource="{RelativeSource Self}"/>
                                <Binding Path="ActualHeight" RelativeSource="{RelativeSource Self}"/>
                            </MultiBinding>
                        </Border.Clip>
                        <views:TimelineView DataContext="{Binding TimelineViewModel}" />
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Settings">
                <ScrollViewer>
                    <StackPanel x:Name="SettingsPanel" Margin="20">
                        <TextBlock Text="Settings" FontSize="22" FontWeight="Bold" Foreground="#007ACC" />
                        <TextBlock Text="Configure FFmpeg, application paths, and shared API keys." Margin="0,6,0,20" Foreground="#CCCCCC" />

                        <TextBlock Text="FFmpeg Path" Margin="0,0,0,6" />
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="FFmpegPathTextBox" Grid.Column="0" Height="32" Padding="8"
                                     Text="{Binding FfmpegPath, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#252526" Foreground="#FFFFFF" BorderBrush="#3E3E42" BorderThickness="1" />
                            <Button Grid.Column="1" Width="90" Height="32" Margin="10,0,0,0" Content="Browse"
                                    Background="#3E3E42" Foreground="#FFFFFF" BorderThickness="0" Click="BrowseFFmpeg_Click" />
                            <Button Grid.Column="2" Width="90" Height="32" Margin="10,0,0,0" Content="Validate"
                                    Background="#007ACC" Foreground="#FFFFFF" BorderThickness="0" Click="ValidateFFmpeg_Click" />
                        </Grid>

                        <TextBlock x:Name="FFmpegStatusText" Foreground="#CCCCCC" Margin="0,0,0,20" TextWrapping="Wrap" />

                        <TextBlock Text="App Data Path" Margin="0,0,0,6" />
                        <TextBox x:Name="AppDataPathText" Height="32" Padding="8" IsReadOnly="True"
                                 Background="#252526" Foreground="#FFFFFF" BorderBrush="#3E3E42" BorderThickness="1" />

                        <Border Margin="0,16,0,0" Padding="16" Background="#252526" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="6">
                            <StackPanel>
                                <TextBlock Text="Updates And Build Info" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" />
                                <TextBlock x:Name="InstalledVersionText" Margin="0,8,0,0" Foreground="#CCCCCC" />
                                <TextBlock x:Name="InstallDirectoryText" Margin="0,4,0,0" Foreground="#BBBBBB" TextWrapping="Wrap" />
                                <TextBlock x:Name="BundledFfmpegText" Margin="0,4,0,0" Foreground="#BBBBBB" TextWrapping="Wrap" />
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button Width="150" Height="32"
                                            Content="Check For Updates"
                                            Background="#0E639C"
                                            Foreground="#FFFFFF"
                                            BorderThickness="0"
                                            Click="CheckForUpdatesButton_Click" />
                                    <TextBlock x:Name="UpdateStatusText"
                                               Margin="12,8,0,0"
                                               Foreground="#CCCCCC"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,24,0,0" Padding="16" Background="#252526" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="6">
                            <Border.Resources>
                                <CollectionViewSource x:Key="GroupedModelsView" Source="{Binding GroupedModels}">
                                    <CollectionViewSource.GroupDescriptions>
                                        <PropertyGroupDescription PropertyName="ProfileName" />
                                    </CollectionViewSource.GroupDescriptions>
                                </CollectionViewSource>
                            </Border.Resources>
                            <StackPanel>
                                <TextBlock Text="AI Analysis (YeScale)" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" />
                                <TextBlock Text="Add API keys and select a model for AI-powered script analysis." Margin="0,6,0,14" Foreground="#BBBBBB" TextWrapping="Wrap" />

                                <!-- ═══ STEP 1: Add API Key ═══ -->
                                <Border Padding="12" Background="#1a1a1a" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="4" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Add API Key" FontWeight="SemiBold" Margin="0,0,0,4" Foreground="#FFFFFF" />
                                        <TextBlock Text="Get your key at yescale.vip. Each key gives access to a group of models." Margin="0,0,0,8" Foreground="#AAAAAA" FontSize="11" TextWrapping="Wrap" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <!-- Labels row -->
                                            <TextBlock Text="Name" Foreground="#888888" FontSize="10" Margin="4,0,0,2" />
                                            <TextBlock Grid.Column="1" Text="API Key" Foreground="#888888" FontSize="10" Margin="10,0,0,2" />
                                            <!-- Inputs row -->
                                            <TextBox Grid.Row="1" Height="32" Padding="6,6"
                                                     Text="{Binding NewProfileName, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="#252526" Foreground="#FFFFFF" BorderBrush="#3E3E42" BorderThickness="1"
                                                     ToolTip="e.g. Primary, Backup-1" />
                                            <TextBox Grid.Row="1" Grid.Column="1" Height="32" Padding="6,6" Margin="6,0,0,0"
                                                     Text="{Binding NewProfileApiKey, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="#252526" Foreground="#FFFFFF" BorderBrush="#3E3E42" BorderThickness="1"
                                                     ToolTip="Paste your YeScale API key" />
                                            <Button Grid.Row="1" Grid.Column="2" Height="32" Width="80" Margin="6,0,0,0"
                                                    Content="+ Add"
                                                    Command="{Binding AddProfileCommand}"
                                                    Background="#007ACC" Foreground="#FFFFFF" BorderThickness="0"
                                                    ToolTip="Add this API key" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- ═══ STEP 2: Configured Keys List ═══ -->
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Your API Keys" FontWeight="SemiBold" Foreground="#FFFFFF" VerticalAlignment="Center" />
                                    <Button Grid.Column="1" Height="24" Padding="10,0" FontSize="11"
                                            Content="Delete Selected"
                                            Command="{Binding RemoveProfileCommand}"
                                            Background="#C1365B" Foreground="#FFFFFF" BorderThickness="0"
                                            ToolTip="Remove the selected key from the list" />
                                </Grid>
                                <ListBox Height="90"
                                         Background="#252526" Foreground="#FFFFFF" BorderBrush="#3E3E42" BorderThickness="1"
                                         ItemsSource="{Binding Profiles}"
                                         SelectedItem="{Binding SelectedProfile, Mode=TwoWay}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="4,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="120" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="60" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="SemiBold" Foreground="#FFFFFF" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1" Text="{Binding MaskedKey}" Foreground="#999999" Margin="12,0,0,0" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="2" Text="●" Foreground="#4EC9B0" TextAlignment="Right" VerticalAlignment="Center" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock Margin="0,4,0,0" Foreground="#666666" FontSize="10" FontStyle="Italic"
                                           Text="Models from all keys are merged. The first key is used as the primary key for API calls." TextWrapping="Wrap" />

                                <!-- ═══ STEP 3: Select Model + Fallback (unified) ═══ -->
                                <Border Padding="12" Background="#1a1a1a" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="4" Margin="0,12,0,0">
                                    <StackPanel>
                                        <!-- Primary Model selection -->
                                        <TextBlock Text="⭐ Primary Model" FontWeight="SemiBold" Margin="0,0,0,4" Foreground="#FFFFFF" FontSize="13" />
                                        <TextBlock Text="Main model used for AI analysis. Pick from the list or type a model ID." Margin="0,0,0,8" Foreground="#AAAAAA" FontSize="11" TextWrapping="Wrap" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <ComboBox Grid.Column="0"
                                                      Height="32"
                                                      IsEditable="True"
                                                      ItemsSource="{Binding AvailableYesScaleModels}"
                                                      Text="{Binding YesScaleModel, UpdateSourceTrigger=PropertyChanged}"
                                                      SelectedItem="{Binding YesScaleModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      Background="#252526" Foreground="#FFFFFF" BorderBrush="#3E3E42" BorderThickness="1" />
                                            <Button Grid.Column="1"
                                                    Width="90" Height="32" Margin="8,0,0,0"
                                                    Content="↻ Refresh"
                                                    Command="{Binding RefreshYesScaleModelsCommand}"
                                                    Background="#3E3E42" Foreground="#FFFFFF" BorderThickness="0"
                                                    ToolTip="Reload available models from all configured keys" />
                                        </Grid>
                                        <TextBlock Margin="0,6,0,0" Foreground="#888888" FontSize="10"
                                                   Text="{Binding YesScaleModelStatus}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <!-- ═══ Grouped Model Browser (models grouped by API key) ═══ -->
                                <Border Padding="12" Background="#1a1a1a" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="4" Margin="0,8,0,0">
                                    <StackPanel>
                                        <TextBlock Text="All Models by API Key" FontWeight="SemiBold" Margin="0,0,0,4" Foreground="#FFFFFF" FontSize="13" />
                                        <TextBlock Text="Click ☆ to add/remove a model from the fallback chain. Models are grouped by the API key that provides them." Margin="0,0,0,8" Foreground="#AAAAAA" FontSize="11" TextWrapping="Wrap" />

                                        <ListBox Height="200"
                                                 Background="#252526" Foreground="#FFFFFF" BorderBrush="#3E3E42" BorderThickness="1"
                                                 ItemsSource="{Binding Source={StaticResource GroupedModelsView}}"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                            <ListBox.GroupStyle>
                                                <GroupStyle>
                                                    <GroupStyle.HeaderTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#2D2D30" Padding="8,4" Margin="0,2,0,0">
                                                                <TextBlock Text="{Binding Name}" Foreground="#4EC9B0" FontWeight="Bold" FontSize="12" />
                                                            </Border>
                                                        </DataTemplate>
                                                    </GroupStyle.HeaderTemplate>
                                                </GroupStyle>
                                            </ListBox.GroupStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="4,1" ToolTip="{Binding ProfileName}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <Button Grid.Column="0" Width="24" Height="22" Padding="0" Margin="0,0,6,0"
                                                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                                Command="{Binding DataContext.ToggleFallbackCommand, ElementName=SettingsPanel}"
                                                                CommandParameter="{Binding}"
                                                                ToolTip="Toggle fallback">
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Setter Property="Content" Value="☆" />
                                                                    <Setter Property="Foreground" Value="#666666" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsInFallback}" Value="True">
                                                                            <Setter Property="Content" Value="★" />
                                                                            <Setter Property="Foreground" Value="#FFD700" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                        <TextBlock Grid.Column="1" Text="{Binding ModelId}" Foreground="#FFFFFF" VerticalAlignment="Center" FontSize="12" />
                                                        <TextBlock Grid.Column="2" Text="{Binding ProfileName}" Foreground="#666666" VerticalAlignment="Center" FontSize="10" Margin="8,0,4,0" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>
                                </Border>

                                <!-- ═══ Fallback Chain ═══ -->
                                <Border Padding="12" Background="#1a1a1a" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="4" Margin="0,8,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Fallback Chain" FontWeight="SemiBold" Margin="0,0,0,4" Foreground="#FFFFFF" FontSize="13" />
                                        <TextBlock Text="If the primary model fails, these are tried in order. Click ★ above or use the picker below to add." Margin="0,0,0,8" Foreground="#AAAAAA" FontSize="11" TextWrapping="Wrap" />

                                        <ListBox Height="90" Margin="0,0,0,8"
                                                 Background="#252526" Foreground="#FFFFFF" BorderBrush="#3E3E42" BorderThickness="1"
                                                 ItemsSource="{Binding FallbackEntries}"
                                                 SelectedItem="{Binding SelectedFallbackEntry, Mode=TwoWay}"
                                                 AlternationCount="999">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="4,2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="24" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Foreground="#888888" VerticalAlignment="Center" FontSize="11" FontWeight="Bold"
                                                                   Text="{Binding Path=(ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ListBoxItem}, StringFormat={}{0}.}" />
                                                        <TextBlock Grid.Column="1" Text="{Binding ModelId}" Foreground="#FFFFFF" VerticalAlignment="Center" FontSize="12" />
                                                        <Border Grid.Column="2" Background="#2D2D30" CornerRadius="3" Padding="6,2" Margin="8,0,4,0">
                                                            <TextBlock Text="{Binding ProfileName}" Foreground="#4EC9B0" VerticalAlignment="Center" FontSize="10" />
                                                        </Border>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>

                                        <!-- Fallback picker: profile → filtered model list → Add -->
                                        <TextBlock Text="Add fallback manually:" Foreground="#888888" FontSize="11" Margin="0,0,0,4" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <!-- Labels -->
                                            <TextBlock Text="API Key" Foreground="#666666" FontSize="10" Margin="2,0,0,2" />
                                            <TextBlock Grid.Column="1" Text="Model (filtered)" Foreground="#666666" FontSize="10" Margin="8,0,0,2" />
                                            <!-- Inputs -->
                                            <ComboBox Grid.Row="1" Height="28"
                                                      ItemsSource="{Binding Profiles}"
                                                      SelectedItem="{Binding SelectedFallbackProfile, Mode=TwoWay}"
                                                      DisplayMemberPath="Name"
                                                      Background="#252526" Foreground="#FFFFFF" BorderBrush="#3E3E42" BorderThickness="1"
                                                      ToolTip="Select an API key — models will be filtered to only those this key supports" />
                                            <ComboBox Grid.Row="1" Grid.Column="1" Height="28" Margin="6,0,0,0"
                                                      IsEditable="True"
                                                      ItemsSource="{Binding FallbackAvailableModels}"
                                                      Text="{Binding SelectedFallbackModel, UpdateSourceTrigger=PropertyChanged}"
                                                      SelectedItem="{Binding SelectedFallbackModel, Mode=TwoWay}"
                                                      Background="#252526" Foreground="#FFFFFF" BorderBrush="#3E3E42" BorderThickness="1"
                                                      ToolTip="Only models available with the selected API key are shown" />
                                            <Button Grid.Row="1" Grid.Column="2" Width="70" Height="28" Margin="6,0,0,0" Content="+ Add"
                                                    Command="{Binding AddFallbackEntryCommand}"
                                                    Background="#007ACC" Foreground="#FFFFFF" BorderThickness="0"
                                                    ToolTip="Add this model as a fallback" />
                                        </Grid>

                                        <!-- Fallback management buttons -->
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                                            <Button Width="70" Height="26" Content="Remove"
                                                    Command="{Binding RemoveFallbackEntryCommand}"
                                                    Background="#C1365B" Foreground="#FFFFFF" BorderThickness="0" Margin="0,0,4,0" />
                                            <Button Width="32" Height="26" Content="↑"
                                                    Command="{Binding MoveFallbackEntryUpCommand}"
                                                    Background="#3E3E42" Foreground="#FFFFFF" BorderThickness="0" FontWeight="Bold" Margin="0,0,4,0" />
                                            <Button Width="32" Height="26" Content="↓"
                                                    Command="{Binding MoveFallbackEntryDownCommand}"
                                                    Background="#3E3E42" Foreground="#FFFFFF" BorderThickness="0" FontWeight="Bold" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- ═══ Base URL (collapsed by default) ═══ -->
                                <Expander IsExpanded="False" Margin="0,8,0,0" Foreground="#FFFFFF">
                                    <Expander.Header>
                                        <TextBlock Text="Base URL (Advanced)" Foreground="#CCCCCC" FontWeight="SemiBold" FontSize="13" />
                                    </Expander.Header>
                                    <StackPanel Margin="0,6,0,0">
                                        <TextBox Height="32" Padding="8"
                                                 Text="{Binding YesScaleBaseUrl, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="#252526" Foreground="#FFFFFF" BorderBrush="#3E3E42" BorderThickness="1" />
                                        <TextBlock Margin="0,4,0,0" Foreground="#888888" FontSize="10" FontStyle="Italic">
                                            Default: https://api.yescale.vip/v1
                                        </TextBlock>
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,16,0,0" Padding="16" Background="#252526" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="6">
                            <StackPanel>
                                <TextBlock Text="Image Search APIs" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" />
                                <TextBlock Text="These API keys are shared across all projects and used when searching stock images." Margin="0,6,0,14" Foreground="#BBBBBB" TextWrapping="Wrap" />

                                <TextBlock Text="Pexels API Key" Margin="0,0,0,6" />
                                <TextBox Height="32" Padding="8"
                                         Text="{Binding PexelsApiKey, UpdateSourceTrigger=PropertyChanged}"
                                         Background="#1E1E1E" Foreground="#FFFFFF" BorderBrush="#3E3E42" BorderThickness="1" />

                                <TextBlock Text="Pixabay API Key" Margin="0,12,0,6" />
                                <TextBox Height="32" Padding="8"
                                         Text="{Binding PixabayApiKey, UpdateSourceTrigger=PropertyChanged}"
                                         Background="#1E1E1E" Foreground="#FFFFFF" BorderBrush="#3E3E42" BorderThickness="1" />

                                <TextBlock Text="Unsplash API Key" Margin="0,12,0,6" />
                                <TextBox Height="32" Padding="8"
                                         Text="{Binding UnsplashApiKey, UpdateSourceTrigger=PropertyChanged}"
                                         Background="#1E1E1E" Foreground="#FFFFFF" BorderBrush="#3E3E42" BorderThickness="1" />
                            </StackPanel>
                        </Border>

                        <!-- ═══ Actions ═══ -->
                        <Grid Margin="0,16,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Primary action -->
                            <StackPanel Orientation="Horizontal">
                                <Button Width="140" Height="36"
                                        Content="💾  Save Settings"
                                        Command="{Binding SaveSettingsCommand}"
                                        Background="#007ACC" Foreground="#FFFFFF" BorderThickness="0"
                                        FontWeight="SemiBold" FontSize="13" />
                                <Button Width="160" Height="36" Margin="10,0,0,0"
                                        Content="↺  Reset AI Defaults"
                                        Command="{Binding ResetAIDefaultsCommand}"
                                        Background="#5a3e3e" Foreground="#FFFFFF" BorderThickness="0"
                                        FontSize="13"
                                        ToolTip="Xóa cấu hình AI hiện tại và khôi phục về mặc định từ appsettings.json (model, API keys, fallback chain)" />
                            </StackPanel>

                            <!-- Status message -->
                            <TextBlock Grid.Row="1" Margin="0,8,0,0"
                                       Text="{Binding StatusMessage}"
                                       FontSize="12" TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#4EC9B0" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                                                <Setter Property="Foreground" Value="#F44747" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Secondary actions: Export / Import -->
                            <Expander Grid.Row="2" IsExpanded="False" Margin="0,12,0,0" Foreground="#FFFFFF">
                                <Expander.Header>
                                    <TextBlock Text="Export / Import Settings" Foreground="#CCCCCC" FontWeight="SemiBold" FontSize="12" />
                                </Expander.Header>
                                <Border Padding="12" Background="#1a1a1a" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="4" Margin="0,6,0,0">
                                    <StackPanel>
                                        <TextBlock Foreground="#AAAAAA" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"
                                                   Text="Export saves all settings (API keys, models, fallback chain) to a JSON file. Import overwrites ALL current settings with the file contents." />
                                        <StackPanel Orientation="Horizontal">
                                            <Button Width="120" Height="30"
                                                    Content="📤  Export"
                                                    Click="ExportSettings_Click"
                                                    Background="#3E3E42" Foreground="#FFFFFF" BorderThickness="0"
                                                    ToolTip="Save all settings to a JSON file for backup or sharing" />
                                            <Button Width="120" Height="30" Margin="10,0,0,0"
                                                    Content="📥  Import"
                                                    Click="ImportSettings_Click"
                                                    Background="#3E3E42" Foreground="#FFFFFF" BorderThickness="0"
                                                    ToolTip="Load settings from a JSON file — this will overwrite all current settings" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Expander>
                        </Grid>

                        <StackPanel Margin="0,20,0,0">
                            <TextBlock Text="Quản lý dung lượng" FontSize="16" FontWeight="Bold" Margin="0,0,0,6" />
                            <Border Padding="12" Background="#1a1a1a" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="4">
                                <StackPanel>
                                    <TextBlock Foreground="#CCCCCC" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"
                                               Text="Ảnh AI tải về được lưu trong AppData theo từng dự án. Khi re-analyze hoặc xoá dự án, dữ liệu cũ có thể tồn đọng. Dọn dẹp định kỳ để giải phóng dung lượng." />

                                    <!-- Storage info row -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Foreground="#AAAAAA" FontSize="11">
                                                <Run Text="Project assets: " />
                                                <Run Text="{Binding AssetsStorageText}" Foreground="#FFFFFF" FontWeight="SemiBold" />
                                            </TextBlock>
                                            <TextBlock Foreground="#AAAAAA" FontSize="11" Margin="0,3,0,0">
                                                <Run Text="Video thumbnails: " />
                                                <Run Text="{Binding ThumbnailStorageText}" Foreground="#FFFFFF" FontWeight="SemiBold" />
                                            </TextBlock>
                                            <TextBlock Foreground="#AAAAAA" FontSize="11" Margin="0,3,0,0">
                                                <Run Text="Audio cache: " />
                                                <Run Text="{Binding AudioCacheStorageText}" Foreground="#FFFFFF" FontWeight="SemiBold" />
                                            </TextBlock>
                                        </StackPanel>
                                        <Button Grid.Column="1" Width="80" Height="26" Content="🔄 Refresh"
                                                Command="{Binding RefreshStorageInfoCommand}"
                                                Background="#3E3E42" Foreground="#FFFFFF" BorderThickness="0" VerticalAlignment="Top"
                                                ToolTip="Cập nhật lại thông tin dung lượng" />
                                    </Grid>

                                    <!-- Action buttons -->
                                    <WrapPanel Orientation="Horizontal">
                                        <Button Width="160" Height="30" Margin="0,0,8,6"
                                                Content="🗑  Dọn thumbnail"
                                                Command="{Binding CleanupThumbnailsCommand}"
                                                Background="#5a3e3e" Foreground="#FFFFFF" BorderThickness="0"
                                                ToolTip="Xoá toàn bộ thumbnail video đã cache (sẽ tự tạo lại khi cần)" />
                                        <Button Width="160" Height="30" Margin="0,0,8,6"
                                                Content="🗑  Dọn audio cache"
                                                Command="{Binding CleanupAudioCacheCommand}"
                                                Background="#5a3e3e" Foreground="#FFFFFF" BorderThickness="0"
                                                ToolTip="Xoá file WAV cache của audio (sẽ tự tạo lại khi phát)" />
                                        <Button Width="160" Height="30" Margin="0,0,0,6"
                                                Content="📂  Mở AppData"
                                                Command="{Binding OpenAppDataFolderCommand}"
                                                Background="#3E3E42" Foreground="#FFFFFF" BorderThickness="0"
                                                ToolTip="Mở thư mục AppData\PodcastVideoEditor trong Explorer" />
                                    </WrapPanel>

                                    <TextBlock Text="{Binding StorageStatusMessage}" Foreground="#4EC9B0" FontSize="11" Margin="0,6,0,0"
                                               Visibility="{Binding StorageStatusMessage, Converter={StaticResource NullOrEmptyToCollapsedConverter}}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Margin="0,20,0,0">
                            <TextBlock Text="Diagnostics" FontSize="16" FontWeight="Bold" Margin="0,0,0,6" />
                            <Border Padding="12" Background="#1a1a1a" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="4">
                                <StackPanel>
                                    <TextBlock Foreground="#CCCCCC" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"
                                               Text="Log file ghi toàn bộ hoạt động của app, bao gồm timing từng bước AI (AI-PIPELINE, AI-HTTP). File ai-prompts-*.txt chứa đầy đủ prompt gửi đi và response nhận về từ AI. Sau khi chạy phân tích AI, mở thư mục Logs để xem chi tiết." />
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="LogPathText" Foreground="#AAAAAA" FontSize="11" VerticalAlignment="Center"
                                                   FontFamily="Consolas" Margin="0,0,10,0" />
                                        <Button Width="100" Height="26"
                                                Content="📂  Mở Logs"
                                                x:Name="OpenLogFolderBtn"
                                                Click="OpenLogFolder_Click"
                                                Background="#3E3E42" Foreground="#FFFFFF" BorderThickness="0"
                                                ToolTip="Mở thư mục chứa log file trong Explorer" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Margin="0,20,0,0">
                            <TextBlock Text="About" FontSize="16" FontWeight="Bold" Margin="0,0,0,6" />
                            <TextBlock x:Name="AboutProductText" Foreground="#CCCCCC" />
                            <TextBlock x:Name="AboutVersionText" Foreground="#AAAAAA" />
                            <TextBlock Text="Built with .NET 8 WPF" Foreground="#AAAAAA" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
    </Border>
</Window>
