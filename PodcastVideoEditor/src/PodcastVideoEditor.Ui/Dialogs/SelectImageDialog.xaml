<Window x:Class="PodcastVideoEditor.Ui.Dialogs.SelectImageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Image" SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource PrimaryBackgroundBrush}"
        Foreground="{DynamicResource PrimaryForegroundBrush}"
        Width="600" Height="500"
        ShowInTaskbar="False"
        ResizeMode="CanResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" FontSize="16" FontWeight="Bold" Margin="0,0,0,12">
            Select Image File
        </TextBlock>

        <!-- File Browser Grid -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>

            <!-- Left: File List -->
            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                <TextBlock Text="Folder:" FontSize="12" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                <TextBlock Name="CurrentPathTextBlock" Text="C:\" FontSize="11" Margin="0,4,0,8" TextWrapping="Wrap"/>

                <TextBlock Text="Files:" FontSize="12" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                <ListBox Name="FileListBox" Height="350" Margin="0,4,0,0"
                         Background="{DynamicResource SecondaryBackgroundBrush}"
                         Foreground="{DynamicResource PrimaryForegroundBrush}"
                         SelectionChanged="FileListBox_SelectionChanged"/>

                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <Button Name="BrowseButton" Content="Browse..." Click="Browse_Click" 
                            Padding="12,6" Background="{DynamicResource AccentBrush}" Margin="0,0,8,0"/>
                    <TextBlock Name="SelectedFileTextBlock" VerticalAlignment="Center" 
                               Foreground="{DynamicResource SecondaryForegroundBrush}" 
                               TextWrapping="Wrap" Text="No file selected"/>
                </StackPanel>
            </StackPanel>

            <!-- Right: Preview -->
            <StackPanel Grid.Column="1" VerticalAlignment="Top">
                <TextBlock Text="Preview:" FontSize="12" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                <Border BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" 
                        Width="180" Height="180" Margin="0,4,0,8"
                        Background="{DynamicResource SecondaryBackgroundBrush}">
                    <Image Name="PreviewImage" Stretch="UniformToFill"/>
                </Border>
                
                <StackPanel>
                    <TextBlock Name="PreviewInfoTextBlock" FontSize="10" 
                               Foreground="{DynamicResource SecondaryForegroundBrush}"
                               TextWrapping="Wrap" Text="No file selected"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- File Info -->
        <Border Grid.Row="2" Padding="12" Margin="0,12,0,0"
                Background="{DynamicResource SecondaryBackgroundBrush}"
                BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
            <StackPanel>
                <TextBlock Text="Format: PNG, JPG, JPEG, WEBP, BMP, GIF, SVG (max 50 MB)" 
                           FontSize="11" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                <TextBlock Name="ErrorMessageTextBlock" FontSize="11" Foreground="Red" TextWrapping="Wrap" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Name="CancelButton" Content="Cancel" Click="Cancel_Click" Padding="16,6" IsCancel="True" Margin="0,0,8,0"/>
            <Button Name="OkButton" Content="Open" Click="Ok_Click" Padding="16,6" 
                    Background="{DynamicResource AccentBrush}" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
