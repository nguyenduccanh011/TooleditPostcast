<UserControl x:Class="PodcastVideoEditor.Ui.Controls.AudioPlayerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
        <Border Style="{StaticResource CardContainerStyle}" Margin="10">
        <StackPanel Background="Transparent">
        <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
            <TextBlock Text="{Binding AudioFileName}" 
                       VerticalAlignment="Center" 
                                           Foreground="{StaticResource SecondaryForegroundBrush}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Margin="0,0,10,0"/>
            
            <Button Content="Select Audio" 
                    Width="120" 
                    Height="32"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                    Click="SelectAudioButton_Click"
                    Cursor="Hand"/>
        </StackPanel>

        <StackPanel Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                <TextBlock Text="{Binding PositionDisplay}" 
                           Foreground="#A0A0A0"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Width="40"/>
                
                <Slider Margin="10,0"
                        Minimum="0" 
                        Maximum="{Binding TotalDuration}"
                        Value="{Binding CurrentPosition, Mode=OneWay}"
                        PreviewMouseLeftButtonDown="ProgressSlider_PreviewMouseLeftButtonDown"
                        PreviewMouseLeftButtonUp="ProgressSlider_PreviewMouseLeftButtonUp"
                        VerticalAlignment="Center"
                        Width="400"/>
                
                <TextBlock Text="{Binding DurationDisplay}" 
                           Foreground="#A0A0A0"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Width="40"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Orientation="Horizontal" 
                    HorizontalAlignment="Center"
                    Margin="0,10,0,10">
            
            <Button Name="PlayButton"
                    Content="Play" 
                    Width="80" 
                    Height="36"
                    Style="{StaticResource SuccessActionButtonStyle}"
                    Command="{Binding PlayCommand}"
                    Cursor="Hand"
                    Margin="0,0,10,0"/>
            
            <Button Name="PauseButton"
                    Content="Pause" 
                    Width="80" 
                    Height="36"
                    Style="{StaticResource NeutralActionButtonStyle}"
                    Command="{Binding PauseCommand}"
                    Cursor="Hand"
                    Margin="0,0,10,0"/>
            
            <Button Name="StopButton"
                    Content="Stop" 
                    Width="80" 
                    Height="36"
                    Style="{StaticResource DangerActionButtonStyle}"
                    Command="{Binding StopCommand}"
                    Cursor="Hand"/>
        </StackPanel>

        <TextBlock Name="StatusText"
                   Text="Ready"
                                   Foreground="#8F9AA5"
                   FontSize="11"
                   Margin="0,10,0,0"/>
    </StackPanel>
        </Border>
</UserControl>
