{
  "App": {
    "Name": "Podcast Video Editor",
    "AppDataPath": "%APPDATA%\\PodcastVideoEditor"
  },
  "Update": {
    "Enabled": true,
    "Provider": "GitHubReleases",
    "Repository": "nguyenduccanh011/TooleditPostcast",
    "Channel": "stable",
    "CheckOnStartup": true,
    "CheckIntervalHours": 24
  },
  "FFmpeg": {
    "Path": "ffmpeg.exe",
    "UseGpu": true,
    "PresetProfile": "fast"
  },
  "Database": {
    "Name": "app.db"
  },
  "Performance": {
    "ThumbnailCacheSize": 1000,
    "PreGenerateThumbnails": true,
    "MaxConcurrentFFmpeg": 2,
    "SeekDebounceMs": 50,
    "ThumbnailDecodeWidth": 60,
    "EnableAsyncThumbnails": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  },
  "AIAnalysis": {
    "YesScaleApiKey": "",
    "BaseUrl": "https://api.yescale.vip/v1",
    "DefaultModel": "gpt-4o-mini"
  },
  "ImageSearch": {
    "PexelsApiKey": "",
    "PixabayApiKey": "",
    "UnsplashApiKey": ""
  }
}
