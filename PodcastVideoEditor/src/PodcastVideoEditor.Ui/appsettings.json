{
  "App": {
    "Name": "Podcast Video Editor",
    "AppDataPath": "%APPDATA%\\PodcastVideoEditor"
  },
  "Update": {
    "Enabled": true,
    "Provider": "GitHubReleases",
    "Repository": "nguyenduccanh011/TooleditPostcast",
    "Channel": "stable",
    "CheckOnStartup": true,
    "CheckIntervalHours": 24
  },
  "FFmpeg": {
    "Path": "ffmpeg.exe",
    "UseGpu": true,
    "PresetProfile": "fast"
  },
  "Database": {
    "Name": "app.db"
  },
  "Performance": {
    "ThumbnailCacheSize": 1000,
    "PreGenerateThumbnails": true,
    "MaxConcurrentFFmpeg": 2,
    "SeekDebounceMs": 50,
    "ThumbnailDecodeWidth": 60,
    "EnableAsyncThumbnails": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  },
  "AIAnalysis": {
    "YesScaleApiKey": "jqDoJgfL2fBd98rwGRpwwq69TRjG8mLT4dhhozFqt5tNAol3",
    "BaseUrl": "https://api.yescale.vip/v1",
    "DefaultModel": "gemini-2.0-flash"
  },
  "ImageSearch": {
    "PexelsApiKey": "G2TWI3QBYJfqaYQ3osvkkdyrO03dtM1OA4erGbgzoSia6rukHGjEC0NB",
    "PixabayApiKey": "54263677-c41ab3491917d11d9f697da9d",
    "UnsplashApiKey": "AYUyXMeiWY5Prps7Yw2blQZGLndILb2thaEKkt1_DbE"
  }
}
